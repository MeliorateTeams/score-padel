{
	"compatibility_date": "2026-04-09",
	"compatibility_flags": [
		"global_fetch_strictly_public"
	],
	"name": "scorepadel",
	"main": "@astrojs/cloudflare/entrypoints/server",
	"assets": {
		"directory": "./dist/client",
		"binding": "ASSETS"
	},
	"observability": {
		"enabled": true
	},
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "scorepadel-db",
			"database_id": "722506cb-2ec3-4d22-982e-b4b4d2086c61"
		}
	]
}
