---
import AppLayout from '../layouts/AppLayout.astro'
const user = (Astro.locals as any).user
if (user) return Astro.redirect('/app')

const error = Astro.url.searchParams.get('error')
const errorMsg: Record<string, string> = {
  campos: 'Todos los campos son obligatorios.',
  password: 'La contraseña debe tener al menos 8 caracteres.',
  email: 'Solo se permiten cuentas de Gmail, Outlook, Hotmail, Yahoo o iCloud.',
  existe: 'Ya existe una cuenta con ese email.',
  privacidad: 'Debes aceptar la política de privacidad.',
  server: 'Error del servidor. Inténtalo de nuevo.',
}
---

<AppLayout title="Crear cuenta">
  <div class="min-h-screen flex items-center justify-center px-6 bg-bg">
    <div class="w-full max-w-sm">
      <a
        href="/"
        class="flex items-center justify-center gap-2 font-display font-bold text-xl tracking-tight mb-10 text-navy"
      >
        <svg class="w-8 h-8" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
          <rect width="40" height="40" rx="10" fill="#E5553B"/>
          <path d="M20 8C14.5 8 10 12 10 17c0 3.5 2 6.5 5 8l-1 9h12l-1-9c3-1.5 5-4.5 5-8 0-5-4.5-9-10-9z" fill="white" opacity="0.15"/>
          <circle cx="15" cy="15" r="1.5" fill="white" opacity="0.4"/>
          <circle cx="20" cy="15" r="1.5" fill="white" opacity="0.4"/>
          <circle cx="25" cy="15" r="1.5" fill="white" opacity="0.4"/>
          <circle cx="15" cy="20" r="1.5" fill="white" opacity="0.4"/>
          <circle cx="20" cy="20" r="1.5" fill="white" opacity="0.4"/>
          <circle cx="25" cy="20" r="1.5" fill="white" opacity="0.4"/>
          <text x="20" y="23" text-anchor="middle" dominant-baseline="central" font-family="system-ui" font-weight="900" font-size="18" fill="white">S</text>
          <circle cx="31" cy="10" r="4" fill="#0D9488"/>
        </svg>
        Score<span class="text-coral">Padel</span>
      </a>

      <h1 class="font-display text-2xl font-extrabold text-center mb-2 text-navy">
        Crea tu cuenta
      </h1>
      <p class="text-sm text-muted text-center mb-8">
        Empieza a construir tu historia en el pádel.
      </p>

      {
        error && (
          <div class="bg-red-50 border border-red-200 text-red-600 text-xs p-3 rounded-xl mb-6">
            {errorMsg[error] || 'Error desconocido.'}
          </div>
        )
      }

      <form method="POST" action="/api/auth/register" class="space-y-4">
        <div>
          <label for="name" class="text-xs font-semibold text-navy block mb-1.5"
            >Nombre completo</label
          >
          <input
            type="text"
            id="name"
            name="name"
            required
            autocomplete="name"
            class="w-full px-4 py-3 bg-white border border-gray-200 rounded-xl text-sm text-navy placeholder:text-muted/50 focus:outline-none focus:border-coral focus:ring-2 focus:ring-coral/10 transition-all"
          />
        </div>
        <div>
          <label for="email" class="text-xs font-semibold text-navy block mb-1.5">Email</label>
          <input
            type="email"
            id="email"
            name="email"
            required
            autocomplete="email"
            class="w-full px-4 py-3 bg-white border border-gray-200 rounded-xl text-sm text-navy placeholder:text-muted/50 focus:outline-none focus:border-coral focus:ring-2 focus:ring-coral/10 transition-all"
          />
          <p class="text-xs text-muted/50 mt-1">Gmail, Outlook, Hotmail, Yahoo o iCloud</p>
        </div>
        <div>
          <label for="password" class="text-xs font-semibold text-navy block mb-1.5"
            >Contraseña</label
          >
          <input
            type="password"
            id="password"
            name="password"
            required
            minlength="8"
            autocomplete="new-password"
            class="w-full px-4 py-3 bg-white border border-gray-200 rounded-xl text-sm text-navy placeholder:text-muted/50 focus:outline-none focus:border-coral focus:ring-2 focus:ring-coral/10 transition-all"
          />
          <p class="text-xs text-muted/50 mt-1">Mínimo 8 caracteres</p>
        </div>
        <div class="flex items-start gap-2">
          <input
            type="checkbox"
            id="privacy"
            name="privacy"
            required
            class="mt-0.5 h-4 w-4 rounded border-gray-300 text-coral focus:ring-coral/20"
          />
          <label for="privacy" class="text-xs text-muted leading-relaxed">
            He leído y acepto la <a
              href="/politica-privacidad"
              target="_blank"
              class="text-coral hover:underline">Política de Privacidad</a
            >.
          </label>
        </div>
        <button
          type="submit"
          class="w-full py-3 bg-coral text-white text-sm font-semibold rounded-full hover:bg-coral-dark transition-colors shadow-sm"
        >
          Crear cuenta
        </button>
      </form>

      <p class="text-xs text-muted text-center mt-6">
        ¿Ya tienes cuenta? <a href="/login" class="text-coral font-semibold hover:underline"
          >Inicia sesión</a
        >
      </p>
    </div>
  </div>
</AppLayout>
