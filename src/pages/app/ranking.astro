---
import AppLayout from '../../layouts/AppLayout.astro'

const user = (Astro.locals as any).user
if (!user) return Astro.redirect('/login')

const db = (Astro.locals as any).db
const period = Astro.url.searchParams.get('period') || 'week'

const days = period === 'month' ? 30 : 7
const since = new Date(Date.now() - days * 86400000).toISOString()

// Players with most wins in period
const topWinners = await db
  .prepare(
    `
  SELECT u.id, u.name, p.rating, p.location,
    COUNT(*) as period_matches,
    SUM(CASE WHEN (m.team1_player1 = u.id AND m.team1_games > m.team2_games)
                 OR (m.team2_player1 = u.id AND m.team2_games > m.team1_games)
                 OR (m.team1_player2 = u.id AND m.team1_games > m.team2_games)
                 OR (m.team2_player2 = u.id AND m.team2_games > m.team1_games)
            THEN 1 ELSE 0 END) as period_wins
  FROM users u
  JOIN matches m ON (m.team1_player1 = u.id OR m.team1_player2 = u.id OR m.team2_player1 = u.id OR m.team2_player2 = u.id)
  LEFT JOIN profiles p ON u.id = p.user_id
  WHERE m.created_at >= ?
  GROUP BY u.id
  HAVING period_matches > 0
  ORDER BY period_wins DESC, period_matches DESC
  LIMIT 20
`,
  )
  .bind(since)
  .all()

// Rating movers (biggest rating change in period)
const ratingMovers = await db
  .prepare(
    `
  SELECT u.id, u.name, p.rating,
    MIN(rh.old_rating) as min_rating,
    MAX(rh.new_rating) as max_rating,
    (SELECT rh2.new_rating FROM rating_history rh2 WHERE rh2.user_id = u.id ORDER BY rh2.created_at DESC LIMIT 1) -
    (SELECT rh3.old_rating FROM rating_history rh3 WHERE rh3.user_id = u.id AND rh3.created_at >= ? ORDER BY rh3.created_at ASC LIMIT 1) as rating_change
  FROM users u
  JOIN rating_history rh ON rh.user_id = u.id
  LEFT JOIN profiles p ON u.id = p.user_id
  WHERE rh.created_at >= ?
  GROUP BY u.id
  HAVING rating_change IS NOT NULL
  ORDER BY rating_change DESC
  LIMIT 10
`,
  )
  .bind(since, since)
  .all()

const star = (topWinners.results?.length ?? 0) > 0 ? (topWinners.results![0] as any) : null
---

<AppLayout title="Destacados de la semana" user={user}>
  <div class="max-w-2xl mx-auto space-y-6">
    <div class="flex items-center gap-3">
      <div class="w-10 h-10 rounded-xl bg-amber/10 flex items-center justify-center">
        <svg
          class="w-5 h-5 text-amber"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
          ><path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z"
          ></path></svg
        >
      </div>
      <div>
        <h1 class="font-display text-xl font-bold text-navy">
          Destacados {period === 'month' ? 'del mes' : 'de la semana'}
        </h1>
        <p class="text-xs text-muted">Los más activos y los que más suben.</p>
      </div>
    </div>

    <!-- Period selector -->
    <div class="flex gap-2">
      <a
        href="?period=week"
        class:list={[
          'px-4 py-2 text-sm font-medium rounded-full transition-colors',
          period === 'week'
            ? 'bg-coral text-white'
            : 'bg-white border border-gray-200 text-muted hover:text-coral',
        ]}>Semanal</a
      >
      <a
        href="?period=month"
        class:list={[
          'px-4 py-2 text-sm font-medium rounded-full transition-colors',
          period === 'month'
            ? 'bg-coral text-white'
            : 'bg-white border border-gray-200 text-muted hover:text-coral',
        ]}>Mensual</a
      >
    </div>

    <!-- Player of the period -->
    {
      star && (
        <div class="card p-6 bg-linear-to-r from-amber/10 to-coral/5 border-amber/20">
          <div class="flex items-center gap-4">
            <div class="w-14 h-14 rounded-2xl bg-amber/20 flex items-center justify-center">
              <span class="text-2xl">⭐</span>
            </div>
            <div class="flex-1">
              <div class="text-[10px] font-semibold text-amber uppercase tracking-wider">
                Jugador de la {period === 'month' ? 'mes' : 'semana'}
              </div>
              <a
                href={`/app/jugadores/${star.id}`}
                class="font-display text-lg font-bold text-navy hover:text-coral transition-colors"
              >
                {star.name}
              </a>
              <div class="text-xs text-muted mt-0.5">
                {star.period_wins} victorias en {star.period_matches} partidos
              </div>
            </div>
            <div class="text-right">
              <div class="font-display text-2xl font-extrabold text-coral">
                {Number(star.rating || 1).toFixed(1)}
              </div>
            </div>
          </div>
        </div>
      )
    }

    <!-- Top winners -->
    <div class="card overflow-hidden">
      <div class="px-5 py-3 border-b border-gray-100">
        <h2 class="font-display text-sm font-bold text-navy uppercase tracking-wider">
          Más victorias
        </h2>
      </div>
      {
        (topWinners.results?.length ?? 0) === 0 ? (
          <div class="p-8 text-center text-sm text-muted">Sin partidos en este periodo.</div>
        ) : (
          <div class="divide-y divide-gray-100">
            {topWinners.results?.map((p: any, i: number) => (
              <div
                class:list={[
                  'flex items-center justify-between px-5 py-3 hover:bg-gray-50/50 transition-colors',
                  p.id === user.id && 'bg-coral/5',
                ]}
              >
                <div class="flex items-center gap-3">
                  <span
                    class:list={[
                      'w-6 h-6 rounded-full flex items-center justify-center text-[10px] font-bold',
                      i < 3 ? 'bg-amber/20 text-amber-700' : 'bg-gray-100 text-muted',
                    ]}
                  >
                    {i + 1}
                  </span>
                  <a
                    href={`/app/jugadores/${p.id}`}
                    class="text-sm font-medium text-navy hover:text-coral transition-colors"
                  >
                    {p.name}
                  </a>
                  {p.id === user.id && (
                    <span class="text-[10px] bg-coral/10 text-coral px-1.5 py-0.5 rounded-full">
                      Tú
                    </span>
                  )}
                </div>
                <div class="flex items-center gap-4">
                  <div class="text-xs text-muted">
                    <span class="font-semibold text-teal">{p.period_wins}V</span> /{' '}
                    {p.period_matches}P
                  </div>
                  <span class="text-xs font-display font-bold text-coral">
                    {Number(p.rating || 1).toFixed(1)}
                  </span>
                </div>
              </div>
            ))}
          </div>
        )
      }
    </div>

    <!-- Rating movers -->
    {
      (ratingMovers.results?.length ?? 0) > 0 && (
        <div class="card overflow-hidden">
          <div class="px-5 py-3 border-b border-gray-100">
            <h2 class="font-display text-sm font-bold text-navy uppercase tracking-wider">
              Mayor subida de rating
            </h2>
          </div>
          <div class="divide-y divide-gray-100">
            {ratingMovers.results?.map((p: any) => {
              const change = Number(p.rating_change ?? 0)
              return (
                <div class="flex items-center justify-between px-5 py-3 hover:bg-gray-50/50 transition-colors">
                  <a
                    href={`/app/jugadores/${p.id}`}
                    class="text-sm font-medium text-navy hover:text-coral transition-colors"
                  >
                    {p.name}
                  </a>
                  <div class="flex items-center gap-3">
                    <span class="text-xs font-display font-bold text-coral">
                      {Number(p.rating || 1).toFixed(1)}
                    </span>
                    <span
                      class:list={[
                        'text-xs font-semibold px-2 py-0.5 rounded-full',
                        change >= 0 ? 'bg-teal/10 text-teal' : 'bg-red-500/10 text-red-500',
                      ]}
                    >
                      {change >= 0 ? '+' : ''}
                      {change.toFixed(2)}
                    </span>
                  </div>
                </div>
              )
            })}
          </div>
        </div>
      )
    }
  </div>
</AppLayout>
