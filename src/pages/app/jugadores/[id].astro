---
import AppLayout from '../../../layouts/AppLayout.astro'

const user = (Astro.locals as any).user
if (!user) return Astro.redirect('/login')

const db = (Astro.locals as any).db
const { id } = Astro.params

const player = await db
  .prepare(
    `
  SELECT u.id, u.name, u.created_at as joined_at,
         p.bio, p.location, p.experience_years, p.racquet_sports,
         p.rating, p.matches_played, p.matches_won
  FROM users u
  LEFT JOIN profiles p ON u.id = p.user_id
  WHERE u.id = ?
`,
  )
  .bind(id)
  .first()

if (!player) return Astro.redirect('/app/jugadores')

// Handle delete (admin only, can't delete yourself)
if (Astro.request.method === 'POST' && user.role !== 'guest') {
  const form = await Astro.request.formData()
  const action = form.get('action')?.toString()
  if (action === 'delete' && id !== user.id && user.role === 'admin') {
    await db.prepare('DELETE FROM rating_history WHERE user_id = ?').bind(id).run()
    await db
      .prepare(
        'DELETE FROM rating_history WHERE match_id IN (SELECT id FROM matches WHERE team1_player1 = ? OR team1_player2 = ? OR team2_player1 = ? OR team2_player2 = ?)',
      )
      .bind(id, id, id, id)
      .run()
    await db
      .prepare(
        'DELETE FROM matches WHERE team1_player1 = ? OR team1_player2 = ? OR team2_player1 = ? OR team2_player2 = ?',
      )
      .bind(id, id, id, id)
      .run()
    await db.prepare('DELETE FROM tournament_players WHERE user_id = ?').bind(id).run()
    await db.prepare('DELETE FROM sessions WHERE user_id = ?').bind(id).run()
    await db.prepare('DELETE FROM profiles WHERE user_id = ?').bind(id).run()
    await db.prepare('DELETE FROM users WHERE id = ?').bind(id).run()
    return Astro.redirect('/app/jugadores')
  }
  if (action === 'challenge' && id !== user.id) {
    const msg = form.get('challenge_msg')?.toString()?.trim() || ''
    const date = form.get('challenge_date')?.toString() || ''
    const loc = form.get('challenge_location')?.toString()?.trim() || ''
    const cId = crypto.randomUUID()
    await db
      .prepare(
        'INSERT INTO challenges (id, challenger_id, challenged_id, message, proposed_date, proposed_location) VALUES (?, ?, ?, ?, ?, ?)',
      )
      .bind(cId, user.id, id, msg, date, loc)
      .run()
    const nId = crypto.randomUUID()
    await db
      .prepare(
        'INSERT INTO notifications (id, user_id, type, message, link) VALUES (?, ?, ?, ?, ?)',
      )
      .bind(
        nId,
        id,
        'challenge',
        `${user.name} te ha retado a jugar${date ? ' el ' + new Date(date).toLocaleDateString('es', { day: 'numeric', month: 'short' }) : ''}`,
        `/app/jugadores/${user.id}`,
      )
      .run()
  }
}

const ratingLevel = (r: number) => {
  if (r < 2.0) return { nombre: 'Iniciación Pádel', div: 'C' }
  if (r < 2.5) return { nombre: 'Consistencia Inicial', div: 'C' }
  if (r < 3.0) return { nombre: 'Precisión en Desarrollo', div: 'C' }
  if (r < 3.5) return { nombre: 'Confianza Intermedia', div: 'C' }
  if (r < 4.0) return { nombre: 'Control y Ritmo', div: 'B' }
  if (r < 4.5) return { nombre: 'Estrategas del Pádel', div: 'B' }
  if (r < 5.0) return { nombre: 'Jugadores Ingeniosos', div: 'B' }
  if (r < 5.5) return { nombre: 'Competidores de Torneo', div: 'B' }
  if (r < 6.0) return { nombre: 'Estrellas Nacionales', div: 'B' }
  if (r < 6.5) return { nombre: 'Semiprofesionales en Ascenso', div: 'A' }
  if (r < 7.0) return { nombre: 'Profesionales de Élite', div: 'A' }
  return { nombre: 'Élite Mundial del Pádel', div: 'A' }
}

const level = ratingLevel(player.rating ?? 1.0)
const winRate =
  (player.matches_played ?? 0) > 0
    ? Math.round(((player.matches_won ?? 0) / (player.matches_played ?? 1)) * 100)
    : 0

// Partidos recientes del jugador
const recentMatches = await db
  .prepare(
    `
  SELECT m.team1_games, m.team2_games, m.set_scores, m.created_at,
         m.team1_player1, m.team2_player1,
         u1.name as team1_name, u2.name as team2_name
  FROM matches m
  LEFT JOIN users u1 ON m.team1_player1 = u1.id
  LEFT JOIN users u2 ON m.team2_player1 = u2.id
  WHERE m.team1_player1 = ? OR m.team1_player2 = ? OR m.team2_player1 = ? OR m.team2_player2 = ?
  ORDER BY m.created_at DESC LIMIT 10
`,
  )
  .bind(id, id, id, id)
  .all()

// Rating history del jugador
const ratingHistory = await db
  .prepare(
    `
  SELECT old_rating, new_rating, created_at FROM rating_history
  WHERE user_id = ? ORDER BY created_at DESC LIMIT 15
`,
  )
  .bind(id)
  .all()

// Calcular racha actual
let streak = 0
let streakType = ''
for (const m of (recentMatches.results ?? []) as any[]) {
  const isTeam1 = m.team1_player1 === id
  const won = isTeam1 ? m.team1_games > m.team2_games : m.team2_games > m.team1_games
  const currentType = won ? 'W' : 'L'
  if (!streakType) streakType = currentType
  if (currentType === streakType) streak++
  else break
}

// Games won/lost totals
let gamesWon = 0,
  gamesLost = 0
for (const m of (recentMatches.results ?? []) as any[]) {
  const isTeam1 = m.team1_player1 === id
  gamesWon += isTeam1 ? m.team1_games : m.team2_games
  gamesLost += isTeam1 ? m.team2_games : m.team1_games
}

// Torneos del jugador
const tournaments = await db
  .prepare(
    `
  SELECT t.id, t.name, t.location, t.event_date, t.status
  FROM tournament_players tp
  JOIN tournaments t ON tp.tournament_id = t.id
  WHERE tp.user_id = ?
  ORDER BY t.event_date DESC LIMIT 5
`,
  )
  .bind(id)
  .all()

const isOwnProfile = id === user.id

// Head-to-head: partidos donde ambos jugaron (yo y este jugador)
let h2h = { wins: 0, losses: 0, draws: 0, matches: [] as any[] }
if (!isOwnProfile) {
  const h2hMatches = await db
    .prepare(
      `
    SELECT m.team1_games, m.team2_games, m.set_scores, m.created_at,
      m.team1_player1, m.team1_player2, m.team2_player1, m.team2_player2
    FROM matches m
    WHERE (m.team1_player1 = ? OR m.team1_player2 = ? OR m.team2_player1 = ? OR m.team2_player2 = ?)
      AND (m.team1_player1 = ? OR m.team1_player2 = ? OR m.team2_player1 = ? OR m.team2_player2 = ?)
    ORDER BY m.created_at DESC LIMIT 20
  `,
    )
    .bind(user.id, user.id, user.id, user.id, id, id, id, id)
    .all()

  for (const m of (h2hMatches.results ?? []) as any[]) {
    const myTeam1 = m.team1_player1 === user.id || m.team1_player2 === user.id
    const sameTeam =
      (myTeam1 && (m.team1_player1 === id || m.team1_player2 === id)) ||
      (!myTeam1 && (m.team2_player1 === id || m.team2_player2 === id))
    if (sameTeam) continue // Skip if we played on the same team
    const myWon = myTeam1 ? m.team1_games > m.team2_games : m.team2_games > m.team1_games
    const draw = m.team1_games === m.team2_games
    if (draw) h2h.draws++
    else if (myWon) h2h.wins++
    else h2h.losses++
    h2h.matches.push(m)
  }
}

// Pending challenge
const pendingChallenge = !isOwnProfile
  ? await db
      .prepare(
        "SELECT id FROM challenges WHERE challenger_id = ? AND challenged_id = ? AND status = 'pending'",
      )
      .bind(user.id, id)
      .first()
  : null

// Achievements/Badges
const tournamentsCount = tournaments.results?.length ?? 0
const matchesPlayed = player.matches_played ?? 0
const matchesWon = player.matches_won ?? 0
const wr = matchesPlayed > 0 ? (matchesWon / matchesPlayed) * 100 : 0
const ratingGain =
  (ratingHistory.results?.length ?? 0) > 0
    ? Number((ratingHistory.results as any[])[0].new_rating) -
      Number(
        (ratingHistory.results as any[])[(ratingHistory.results as any[]).length - 1].old_rating,
      )
    : 0
const bestStreak = (() => {
  let best = 0,
    cur = 0
  for (const m of (recentMatches.results ?? []) as any[]) {
    const isT1 = m.team1_player1 === id
    const won = isT1 ? m.team1_games > m.team2_games : m.team2_games > m.team1_games
    if (won) {
      cur++
      if (cur > best) best = cur
    } else cur = 0
  }
  return best
})()

const badges = [
  { icon: '⚡', name: 'Primer partido', desc: '1 partido jugado', earned: matchesPlayed >= 1 },
  { icon: '🏆', name: 'Primera victoria', desc: '1 victoria', earned: matchesWon >= 1 },
  { icon: '🔥', name: '10 Victorias', desc: '10 victorias totales', earned: matchesWon >= 10 },
  { icon: '💎', name: '25 Victorias', desc: '25 victorias totales', earned: matchesWon >= 25 },
  {
    icon: '🎯',
    name: 'Precisión',
    desc: '60%+ win rate (10+ partidos)',
    earned: matchesPlayed >= 10 && wr >= 60,
  },
  { icon: '🔥', name: 'Racha de 5', desc: '5 victorias consecutivas', earned: bestStreak >= 5 },
  { icon: '🏅', name: 'Torneísta', desc: 'Inscrito en un torneo', earned: tournamentsCount >= 1 },
  { icon: '📈', name: 'En ascenso', desc: 'Rating subió +1.0', earned: ratingGain >= 1.0 },
]
---

<AppLayout title={player.name} user={user}>
  <div class="max-w-2xl mx-auto space-y-6">
    <!-- Back link -->
    <a
      href="/app/jugadores"
      class="text-xs text-muted hover:text-coral transition-colors inline-flex items-center gap-1"
    >
      <svg
        class="w-3.5 h-3.5"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="2"
        ><path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18"></path></svg
      >
      Volver a jugadores
    </a>

    <!-- Hero Card -->
    <div class="card overflow-hidden">
      <div class="h-20 bg-gradient-to-r from-coral to-orange-400 relative">
        <div class="absolute -bottom-8 left-6">
          <div
            class="w-16 h-16 rounded-2xl bg-white shadow-md border-2 border-white flex items-center justify-center"
          >
            <span class="font-display text-2xl font-extrabold text-coral"
              >{(player.name as string)?.charAt(0)?.toUpperCase()}</span
            >
          </div>
        </div>
      </div>
      <div class="pt-12 px-6 pb-6">
        <div class="flex items-start justify-between">
          <div>
            <h1 class="font-display text-xl font-extrabold text-navy">{player.name}</h1>
            <div class="flex items-center gap-2 mt-1">
              {
                player.location && (
                  <span class="text-xs text-muted flex items-center gap-1">
                    <svg
                      class="w-3 h-3"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                      stroke-width="2"
                    >
                      <>
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"
                        />
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"
                        />
                      </>
                    </svg>
                    {player.location}
                  </span>
                )
              }
              {
                player.experience_years > 0 && (
                  <span class="text-xs text-muted flex items-center gap-1">
                    <svg
                      class="w-3 h-3"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                      stroke-width="2"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"
                      />
                    </svg>
                    {player.experience_years} años
                  </span>
                )
              }
            </div>
            {player.bio && <p class="text-sm text-navy/70 mt-3 leading-relaxed">{player.bio}</p>}
          </div>
          <div class="text-right shrink-0 ml-4">
            <div class="font-display text-3xl font-extrabold text-coral">
              {Number(player.rating || 1).toFixed(1)}
            </div>
            <div class="text-[11px] text-muted mt-0.5">{level.nombre}</div>
            <span
              class:list={[
                'inline-block mt-1 text-[10px] font-semibold px-2 py-0.5 rounded-full',
                level.div === 'A'
                  ? 'bg-coral/10 text-coral'
                  : level.div === 'B'
                    ? 'bg-amber-100 text-amber-700'
                    : 'bg-blue-100 text-blue-700',
              ]}>División {level.div}</span
            >
          </div>
        </div>
      </div>
    </div>

    <!-- Stats -->
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
      <div class="card p-4 text-center">
        <div class="font-display text-2xl font-extrabold text-navy">
          {player.matches_played ?? 0}
        </div>
        <div class="text-[11px] text-muted mt-0.5">Partidos</div>
      </div>
      <div class="card p-4 text-center">
        <div class="font-display text-2xl font-extrabold text-teal">{player.matches_won ?? 0}</div>
        <div class="text-[11px] text-muted mt-0.5">Victorias</div>
      </div>
      <div class="card p-4 text-center">
        <div class="font-display text-2xl font-extrabold text-navy">{winRate}%</div>
        <div class="text-[11px] text-muted mt-0.5">Win rate</div>
      </div>
      <div class="card p-4 text-center">
        <div
          class:list={[
            'font-display text-2xl font-extrabold',
            streakType === 'W' ? 'text-teal' : streak > 0 ? 'text-red-500' : 'text-navy',
          ]}
        >
          {streak > 0 ? `${streak}${streakType}` : '-'}
        </div>
        <div class="text-[11px] text-muted mt-0.5">Racha</div>
      </div>
    </div>

    <!-- Games ratio bar -->
    <div class="flex justify-end -mt-3">
      <button
        id="btn-share-card"
        type="button"
        class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-semibold text-coral border border-coral/20 rounded-lg hover:bg-coral/5 transition-colors"
      >
        <svg
          class="w-3.5 h-3.5"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
          ><path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5m-13.5-9L12 3m0 0l4.5 4.5M12 3v13.5"
          ></path></svg
        >
        Compartir ficha
      </button>
    </div>
    {
      gamesWon + gamesLost > 0 && (
        <div class="card p-4">
          <div class="flex items-center justify-between text-xs text-muted mb-2">
            <span>
              Games ganados: <span class="font-semibold text-teal">{gamesWon}</span>
            </span>
            <span>
              Games perdidos: <span class="font-semibold text-red-500">{gamesLost}</span>
            </span>
          </div>
          <div class="w-full h-2 bg-gray-100 rounded-full overflow-hidden flex">
            <div
              class="h-full bg-teal rounded-l-full"
              style={`width: ${Math.round((gamesWon / (gamesWon + gamesLost)) * 100)}%`}
            />
            <div class="h-full bg-red-400 rounded-r-full flex-1" />
          </div>
        </div>
      )
    }

    <!-- Logros / Badges -->
    {
      badges.some((b) => b.earned) && (
        <div class="card p-5">
          <h2 class="font-display text-sm font-bold text-navy uppercase tracking-wider flex items-center gap-2 mb-3">
            <svg
              class="w-4 h-4 text-amber"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z"
              />
            </svg>
            Logros
          </h2>
          <div class="flex flex-wrap gap-2">
            {badges.map((b) => (
              <div
                class:list={[
                  'inline-flex items-center gap-1.5 px-3 py-1.5 rounded-xl text-xs border',
                  b.earned
                    ? 'bg-amber/10 border-amber/20 text-navy'
                    : 'bg-gray-50 border-gray-100 text-muted/40',
                ]}
              >
                <span>{b.icon}</span>
                <span class="font-medium">{b.name}</span>
              </div>
            ))}
          </div>
        </div>
      )
    }

    {
      player.racquet_sports && (
        <div class="card p-5">
          <h2 class="font-display text-sm font-bold text-navy uppercase tracking-wider flex items-center gap-2 mb-3">
            <svg
              class="w-4 h-4 text-teal"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z"
              />
            </svg>
            Otros deportes de raqueta
          </h2>
          <div class="flex flex-wrap gap-2">
            {(player.racquet_sports as string)
              .split(',')
              .map((s: string) => s.trim())
              .filter(Boolean)
              .map((sport: string) => (
                <span class="px-3 py-1 bg-gray-50 text-xs font-medium text-navy rounded-lg border border-gray-100">
                  {sport}
                </span>
              ))}
          </div>
        </div>
      )
    }

    <!-- Recent matches -->
    <div class="card p-6">
      <h2
        class="font-display text-sm font-bold text-navy uppercase tracking-wider flex items-center gap-2 mb-4"
      >
        <svg
          class="w-4 h-4 text-coral"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
          ><path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M16.5 18.75h-9m9 0a3 3 0 013 3h-15a3 3 0 013-3m9 0v-3.375c0-.621-.503-1.125-1.125-1.125h-.871M7.5 18.75v-3.375c0-.621.504-1.125 1.125-1.125h.872m5.007 0H9.497m5.007 0a7.454 7.454 0 01-.982-3.172M9.497 14.25a7.454 7.454 0 00.981-3.172M5.25 4.236c-.982.143-1.954.317-2.916.52A6.003 6.003 0 007.73 9.728M5.25 4.236V4.5c0 2.108.966 3.99 2.48 5.228M5.25 4.236V2.721C7.456 2.41 9.71 2.25 12 2.25c2.291 0 4.545.16 6.75.47v1.516M18.75 4.236c.982.143 1.954.317 2.916.52A6.003 6.003 0 0016.27 9.728M18.75 4.236V4.5c0 2.108-.966 3.99-2.48 5.228m0 0a6.003 6.003 0 01-5.54 0"
          ></path></svg
        >
        Partidos recientes
      </h2>
      {
        (recentMatches.results?.length ?? 0) === 0 ? (
          <div class="text-center py-6">
            <svg
              class="w-10 h-10 text-muted/30 mx-auto mb-2"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="1.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"
              />
            </svg>
            <p class="text-sm text-muted">Sin partidos registrados.</p>
          </div>
        ) : (
          <div class="space-y-2">
            {recentMatches.results?.map((m: any) => {
              const isTeam1 = m.team1_player1 === id
              const won = isTeam1 ? m.team1_games > m.team2_games : m.team2_games > m.team1_games
              const tied = m.team1_games === m.team2_games
              const sets = (() => {
                try {
                  return JSON.parse(m.set_scores || '[]')
                } catch {
                  return []
                }
              })()
              return (
                <div class="flex items-center justify-between p-3 rounded-xl bg-gray-50 border border-gray-100">
                  <div class="flex items-center gap-3">
                    <span
                      class:list={[
                        'text-[10px] font-semibold px-2 py-0.5 rounded-full uppercase',
                        won
                          ? 'bg-teal/10 text-teal'
                          : tied
                            ? 'bg-amber-100 text-amber-700'
                            : 'bg-red-500/10 text-red-500',
                      ]}
                    >
                      {won ? 'V' : tied ? 'E' : 'D'}
                    </span>
                    <div>
                      <div class="text-sm text-navy">
                        {m.team1_name}
                        <span class="text-muted mx-1.5 text-xs">vs</span>
                        {m.team2_name}
                      </div>
                      {sets.length > 0 && (
                        <div class="flex gap-1.5 mt-1">
                          {sets.map((s: any) => (
                            <span class="text-[10px] font-mono bg-white px-1.5 py-0.5 rounded border border-gray-200 text-navy/70">
                              {s.team1}-{s.team2}
                            </span>
                          ))}
                        </div>
                      )}
                    </div>
                  </div>
                  <div class="flex items-center gap-3">
                    <span class="text-sm font-display font-bold text-navy">
                      {m.team1_games}–{m.team2_games}
                    </span>
                    <span class="text-[11px] text-muted">
                      {new Date(m.created_at).toLocaleDateString('es-ES', {
                        day: 'numeric',
                        month: 'short',
                      })}
                    </span>
                  </div>
                </div>
              )
            })}
          </div>
        )
      }
    </div>

    <!-- Rating evolution -->
    {
      (ratingHistory.results?.length ?? 0) > 0 && (
        <div class="card p-6">
          <h2 class="font-display text-sm font-bold text-navy uppercase tracking-wider flex items-center gap-2 mb-4">
            <svg
              class="w-4 h-4 text-amber"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M2.25 18L9 11.25l4.306 4.307a11.95 11.95 0 015.814-5.519l2.74-1.22m0 0l-5.94-2.28m5.94 2.28l-2.28 5.941"
              />
            </svg>
            Evolución de valoración
          </h2>
          <div class="space-y-1.5">
            {ratingHistory.results?.map((h: any) => {
              const diff = Number(h.new_rating) - Number(h.old_rating)
              return (
                <div class="flex items-center justify-between p-2.5 rounded-lg bg-gray-50 border border-gray-100">
                  <div class="flex items-center gap-2 text-sm">
                    <span class="text-muted">{Number(h.old_rating).toFixed(2)}</span>
                    <span class="text-muted">→</span>
                    <span
                      class:list={[
                        diff >= 0 ? 'text-teal font-semibold' : 'text-red-500 font-semibold',
                      ]}
                    >
                      {Number(h.new_rating).toFixed(2)}
                    </span>
                    <span
                      class:list={[
                        'text-[10px] px-1.5 py-0.5 rounded-full font-medium',
                        diff >= 0 ? 'bg-teal/10 text-teal' : 'bg-red-500/10 text-red-500',
                      ]}
                    >
                      {diff >= 0 ? '+' : ''}
                      {diff.toFixed(2)}
                    </span>
                  </div>
                  <span class="text-[11px] text-muted">
                    {new Date(h.created_at).toLocaleDateString('es-ES', {
                      day: 'numeric',
                      month: 'short',
                    })}
                  </span>
                </div>
              )
            })}
          </div>
        </div>
      )
    }

    <!-- Tournaments -->
    {
      (tournaments.results?.length ?? 0) > 0 && (
        <div class="card p-6">
          <h2 class="font-display text-sm font-bold text-navy uppercase tracking-wider flex items-center gap-2 mb-4">
            <svg
              class="w-4 h-4 text-coral"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M16.5 18.75h-9m9 0a3 3 0 013 3h-15a3 3 0 013-3m9 0v-3.375c0-.621-.503-1.125-1.125-1.125h-.871M7.5 18.75v-3.375c0-.621.504-1.125 1.125-1.125h.872m5.007 0H9.497m5.007 0a7.454 7.454 0 01-.982-3.172M9.497 14.25a7.454 7.454 0 00.981-3.172M5.25 4.236c-.982.143-1.954.317-2.916.52A6.003 6.003 0 007.73 9.728M5.25 4.236V4.5c0 2.108.966 3.99 2.48 5.228M5.25 4.236V2.721C7.456 2.41 9.71 2.25 12 2.25c2.291 0 4.545.16 6.75.47v1.516M18.75 4.236c.982.143 1.954.317 2.916.52A6.003 6.003 0 0016.27 9.728M18.75 4.236V4.5c0 2.108-.966 3.99-2.48 5.228m0 0a6.003 6.003 0 01-5.54 0"
              />
            </svg>
            Torneos
          </h2>
          <div class="space-y-2">
            {tournaments.results?.map((t: any) => (
              <a
                href={`/app/torneos/${t.id}`}
                class="flex items-center justify-between p-3 rounded-xl bg-gray-50 border border-gray-100 hover:border-coral/30 transition-colors"
              >
                <div>
                  <div class="text-sm font-semibold text-navy">{t.name}</div>
                  {t.location && <div class="text-[11px] text-muted">{t.location}</div>}
                </div>
                <div class="flex items-center gap-2">
                  <span class="text-[11px] text-muted">
                    {new Date(t.event_date).toLocaleDateString('es-ES', {
                      day: 'numeric',
                      month: 'short',
                      year: 'numeric',
                    })}
                  </span>
                  <svg
                    class="w-3.5 h-3.5 text-muted/50"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M8.25 4.5l7.5 7.5-7.5 7.5"
                    />
                  </svg>
                </div>
              </a>
            ))}
          </div>
        </div>
      )
    }

    <!-- Head-to-Head -->
    {
      !isOwnProfile && h2h.wins + h2h.losses + h2h.draws > 0 && (
        <div class="card p-6">
          <h2 class="font-display text-sm font-bold text-navy uppercase tracking-wider flex items-center gap-2 mb-4">
            <svg
              class="w-4 h-4 text-coral"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M7.5 21L3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5"
              />
            </svg>
            Head-to-Head vs {player.name}
          </h2>
          <div class="grid grid-cols-3 gap-3 mb-4">
            <div class="text-center p-3 rounded-xl bg-teal/10">
              <div class="font-display text-2xl font-extrabold text-teal">{h2h.wins}</div>
              <div class="text-[10px] text-muted uppercase">Victorias</div>
            </div>
            <div class="text-center p-3 rounded-xl bg-gray-100">
              <div class="font-display text-2xl font-extrabold text-muted">{h2h.draws}</div>
              <div class="text-[10px] text-muted uppercase">Empates</div>
            </div>
            <div class="text-center p-3 rounded-xl bg-red-500/10">
              <div class="font-display text-2xl font-extrabold text-red-500">{h2h.losses}</div>
              <div class="text-[10px] text-muted uppercase">Derrotas</div>
            </div>
          </div>
          {h2h.matches.length > 0 && (
            <div class="space-y-1.5">
              {h2h.matches.slice(0, 5).map((m: any) => {
                const myTeam1 = m.team1_player1 === user.id || m.team1_player2 === user.id
                const myWon = myTeam1
                  ? m.team1_games > m.team2_games
                  : m.team2_games > m.team1_games
                return (
                  <div class="flex items-center justify-between p-2 rounded-lg bg-gray-50 border border-gray-100 text-xs">
                    <span
                      class:list={[
                        myWon ? 'text-teal font-semibold' : 'text-red-500 font-semibold',
                      ]}
                    >
                      {myWon ? 'Victoria' : 'Derrota'}
                    </span>
                    <span class="font-mono text-navy">
                      {myTeam1
                        ? `${m.team1_games}–${m.team2_games}`
                        : `${m.team2_games}–${m.team1_games}`}
                    </span>
                    <span class="text-muted">
                      {new Date(m.created_at).toLocaleDateString('es', {
                        day: 'numeric',
                        month: 'short',
                      })}
                    </span>
                  </div>
                )
              })}
            </div>
          )}
        </div>
      )
    }

    <!-- Challenge / CTA -->
    {
      !isOwnProfile && user.role !== 'guest' && (
        <div class="card p-5">
          {pendingChallenge ? (
            <div class="text-center">
              <span class="inline-flex items-center gap-2 px-4 py-2 bg-amber/10 text-amber-700 text-sm font-medium rounded-xl">
                <svg
                  class="w-4 h-4"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"
                  />
                </svg>
                Reto enviado — esperando respuesta
              </span>
            </div>
          ) : (
            <details class="group">
              <summary class="flex items-center justify-center gap-2 cursor-pointer text-sm font-semibold text-coral hover:text-coral-dark transition-colors list-none">
                <svg
                  class="w-4 h-4"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M15.362 5.214A8.252 8.252 0 0112 21 8.25 8.25 0 016.038 7.048 6.75 6.75 0 009 4.5a6.753 6.753 0 006.362.714z"
                  />
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M12 18a3.75 3.75 0 00.495-7.467 5.99 5.99 0 00-1.925 3.546 5.974 5.974 0 01-2.133-1A3.75 3.75 0 0012 18z"
                  />
                </svg>
                Retar a {player.name}
              </summary>
              <form method="POST" class="mt-4 space-y-3">
                <input type="hidden" name="action" value="challenge" />
                <div class="grid grid-cols-2 gap-3">
                  <div>
                    <label class="text-xs text-muted block mb-1">Fecha propuesta</label>
                    <input
                      type="date"
                      name="challenge_date"
                      class="w-full px-3 py-2 text-sm border border-gray-200 rounded-xl"
                    />
                  </div>
                  <div>
                    <label class="text-xs text-muted block mb-1">Lugar</label>
                    <input
                      type="text"
                      name="challenge_location"
                      placeholder="Club, pista..."
                      class="w-full px-3 py-2 text-sm border border-gray-200 rounded-xl"
                    />
                  </div>
                </div>
                <div>
                  <label class="text-xs text-muted block mb-1">Mensaje (opcional)</label>
                  <input
                    type="text"
                    name="challenge_msg"
                    placeholder="¡Vamos a jugar!"
                    class="w-full px-3 py-2 text-sm border border-gray-200 rounded-xl"
                  />
                </div>
                <button
                  type="submit"
                  class="w-full py-2.5 bg-coral text-white text-sm font-semibold rounded-xl hover:bg-coral-dark transition-colors"
                >
                  Enviar reto
                </button>
              </form>
            </details>
          )}
        </div>
      )
    }

    {
      isOwnProfile && (
        <div class="text-center">
          <a
            href="/app/perfil"
            class="text-sm text-coral hover:underline inline-flex items-center gap-1"
          >
            <svg
              class="w-3.5 h-3.5"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10"
              />
            </svg>
            Editar mi perfil
          </a>
        </div>
      )
    }

    {
      user.role === 'admin' && !isOwnProfile && (
        <form
          method="POST"
          onsubmit="return confirm('¿Eliminar a este jugador? Se borrarán todos sus datos, partidos e historial. Esta acción no se puede deshacer.')"
          class="text-center"
        >
          <input type="hidden" name="action" value="delete" />
          <button
            type="submit"
            class="inline-flex items-center gap-1.5 px-4 py-2 text-xs text-red-500 border border-red-500/20 rounded-xl hover:bg-red-500/10 transition-colors"
          >
            <svg
              class="w-3.5 h-3.5"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0"
              />
            </svg>
            Eliminar jugador
          </button>
        </form>
      )
    }
  </div>

  <canvas id="share-canvas" class="hidden" width="600" height="340"></canvas>

  <script
    define:vars={{
      cardName: player.name,
      cardRating: Number(player.rating || 1).toFixed(1),
      cardLevel: level.nombre,
      cardDiv: level.div,
      cardMatches: player.matches_played ?? 0,
      cardWins: player.matches_won ?? 0,
      cardWinRate: winRate,
      cardStreak: streak > 0 ? `${streak}${streakType}` : '-',
    }}
  >
    document.getElementById('btn-share-card')?.addEventListener('click', async () => {
      const c = document.getElementById('share-canvas')
      if (!c) return
      const ctx = c.getContext('2d')
      if (!ctx) return
      // Background
      ctx.fillStyle = '#0A0A0A'
      ctx.fillRect(0, 0, 600, 340)
      // Header bar
      const grad = ctx.createLinearGradient(0, 0, 600, 0)
      grad.addColorStop(0, '#FF6A00')
      grad.addColorStop(1, '#FFB347')
      ctx.fillStyle = grad
      ctx.fillRect(0, 0, 600, 80)
      // Brand
      ctx.fillStyle = '#fff'
      ctx.font = 'bold 14px sans-serif'
      ctx.fillText('SCORE PADEL', 24, 30)
      ctx.font = '11px sans-serif'
      ctx.fillText('scorepadel.padelzone.workers.dev', 24, 50)
      // Avatar circle
      ctx.fillStyle = '#fff'
      ctx.beginPath()
      ctx.arc(70, 130, 40, 0, Math.PI * 2)
      ctx.fill()
      ctx.fillStyle = '#FF6A00'
      ctx.font = 'bold 32px sans-serif'
      ctx.textAlign = 'center'
      ctx.fillText(cardName.charAt(0).toUpperCase(), 70, 142)
      ctx.textAlign = 'left'
      // Name
      ctx.fillStyle = '#F0F0F0'
      ctx.font = 'bold 22px sans-serif'
      ctx.fillText(cardName, 130, 125)
      // Level
      ctx.fillStyle = '#8A8A8A'
      ctx.font = '13px sans-serif'
      ctx.fillText(cardLevel + '  ·  División ' + cardDiv, 130, 148)
      // Big rating
      ctx.fillStyle = '#FF6A00'
      ctx.font = 'bold 44px sans-serif'
      ctx.textAlign = 'right'
      ctx.fillText(cardRating, 576, 140)
      ctx.textAlign = 'left'
      // Stats row
      const stats = [
        { label: 'Partidos', value: String(cardMatches) },
        { label: 'Victorias', value: String(cardWins) },
        { label: 'Win Rate', value: cardWinRate + '%' },
        { label: 'Racha', value: cardStreak },
      ]
      const sw = 120
      const sy = 200
      stats.forEach((s, i) => {
        const sx = 40 + i * sw + i * 12
        ctx.fillStyle = '#1C1C1C'
        ctx.beginPath()
        ctx.roundRect(sx, sy, sw, 70, 10)
        ctx.fill()
        ctx.fillStyle = '#F0F0F0'
        ctx.font = 'bold 26px sans-serif'
        ctx.textAlign = 'center'
        ctx.fillText(s.value, sx + sw / 2, sy + 35)
        ctx.fillStyle = '#9CA3AF'
        ctx.font = '11px sans-serif'
        ctx.fillText(s.label, sx + sw / 2, sy + 55)
        ctx.textAlign = 'left'
      })
      // Footer
      ctx.fillStyle = '#D1D5DB'
      ctx.font = '10px sans-serif'
      ctx.textAlign = 'center'
      ctx.fillText('Generado con Score Padel · ' + new Date().toLocaleDateString('es'), 300, 326)
      ctx.textAlign = 'left'
      // Download or share
      c.toBlob(async (blob) => {
        if (!blob) return
        const file = new File([blob], cardName.replace(/\s+/g, '_') + '_scorepadel.png', {
          type: 'image/png',
        })
        if (navigator.share && navigator.canShare?.({ files: [file] })) {
          try {
            await navigator.share({ files: [file], title: cardName + ' · Score Padel' })
          } catch {}
        } else {
          const a = document.createElement('a')
          a.href = URL.createObjectURL(blob)
          a.download = file.name
          a.click()
          URL.revokeObjectURL(a.href)
        }
      }, 'image/png')
    })
  </script>
</AppLayout>
