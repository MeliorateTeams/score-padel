---
import AppLayout from '../../../layouts/AppLayout.astro'

const user = (Astro.locals as any).user
if (!user) return Astro.redirect('/login')
const isAdmin = user.role === 'admin'

const db = (Astro.locals as any).db
const tournaments = await db
  .prepare(
    `
  SELECT t.*, u.name as creator_name,
    COALESCE(tct.competition_type, 'tournament') as competition_type,
    (SELECT COUNT(*) FROM tournament_players tp WHERE tp.tournament_id = t.id) as player_count
  FROM tournaments t
  LEFT JOIN tournament_competition_types tct ON tct.tournament_id = t.id
  JOIN users u ON t.creator_id = u.id
  ORDER BY t.event_date DESC
  LIMIT 50
`,
  )
  .all()
---

<AppLayout title="Torneos" user={user}>
  <div class="flex items-center justify-between mb-8">
    <div>
      <h1 class="font-display text-2xl font-bold mb-1">Torneos</h1>
      <p class="text-sm text-muted">Encuentra o crea competiciones de pádel.</p>
    </div>
    {
      isAdmin ? (
        <a
          href="/app/torneos/crear"
          class="px-5 py-2.5 bg-coral text-white text-sm font-semibold rounded-full hover:bg-coral-dark transition-colors"
        >
          Crear torneo
        </a>
      ) : (
        <span class="text-xs font-medium text-muted bg-gray-50 border border-gray-100 px-3 py-2 rounded-full">
          Solo administradores pueden crear torneos
        </span>
      )
    }
  </div>

  {
    (tournaments.results?.length ?? 0) === 0 ? (
      <div class="card rounded-xl p-10 text-center">
        <p class="text-muted mb-4">No hay torneos creados aún.</p>
        {isAdmin ? (
          <a href="/app/torneos/crear" class="text-coral text-sm hover:underline">
            Sé el primero en organizar uno
          </a>
        ) : (
          <p class="text-xs text-muted">Un administrador puede abrir el primer torneo.</p>
        )}
      </div>
    ) : (
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {tournaments.results?.map((t: any) => (
          <a href={`/app/torneos/${t.id}`} class="card-hover p-6 block">
            <div class="flex items-center justify-between mb-3">
              <div class="flex items-center gap-2">
                <span
                  class:list={[
                    'text-xs font-medium px-2 py-0.5 rounded-full',
                    t.status === 'open' ? 'bg-teal/10 text-teal' : 'bg-muted/10 text-muted',
                  ]}
                >
                  {t.status === 'open' ? 'Abierto' : 'Cerrado'}
                </span>
                <span
                  class:list={[
                    'text-[10px] font-semibold px-2 py-0.5 rounded-full uppercase tracking-wide',
                    t.competition_type === 'validated_league'
                      ? 'bg-amber/10 text-amber-700'
                      : 'bg-coral/10 text-coral',
                  ]}
                >
                  {t.competition_type === 'validated_league' ? 'Liga validada' : 'Torneo oficial'}
                </span>
              </div>
              <span class="text-xs text-muted">
                {t.player_count}/{t.max_players}
              </span>
            </div>
            <h3 class="font-display text-sm font-semibold text-navy mb-1">{t.name}</h3>
            <p class="text-xs text-muted mb-2">{t.location || 'Sin ubicación'}</p>
            <div class="text-xs text-muted">
              {new Date(t.event_date).toLocaleDateString('es', {
                day: 'numeric',
                month: 'long',
                year: 'numeric',
              })}
            </div>
            <div class="text-xs text-muted/50 mt-2">Organiza: {t.creator_name}</div>
          </a>
        ))}
      </div>
    )
  }
</AppLayout>
