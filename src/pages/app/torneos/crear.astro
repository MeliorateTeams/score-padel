---
import AppLayout from '../../../layouts/AppLayout.astro'
import { generateId } from '../../../lib/auth'

const user = (Astro.locals as any).user
if (!user) return Astro.redirect('/login')
if (user.role === 'guest') return Astro.redirect('/app?error=guest')

const db = (Astro.locals as any).db

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData()
  const name = form.get('name')?.toString().trim()
  const description = form.get('description')?.toString() ?? ''
  const location = form.get('location')?.toString() ?? ''
  const event_date = form.get('event_date')?.toString()
  const max_players = parseInt(form.get('max_players')?.toString() ?? '16') || 16

  if (name && event_date) {
    const id = generateId()
    await db
      .prepare(
        'INSERT INTO tournaments (id, creator_id, name, description, location, event_date, max_players) VALUES (?, ?, ?, ?, ?, ?, ?)',
      )
      .bind(id, user.id, name, description, location, event_date, max_players)
      .run()
    // Auto-join creator
    await db
      .prepare('INSERT INTO tournament_players (tournament_id, user_id) VALUES (?, ?)')
      .bind(id, user.id)
      .run()
    return Astro.redirect(`/app/torneos/${id}`)
  }
}
---

<AppLayout title="Crear torneo" user={user}>
  <div class="max-w-2xl mx-auto space-y-6">
    <!-- Header -->
    <div class="flex items-center gap-3">
      <div class="w-10 h-10 rounded-xl bg-teal/10 flex items-center justify-center">
        <svg
          class="w-5 h-5 text-teal"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
          ><path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M16.5 18.75h-9m9 0a3 3 0 013 3h-15a3 3 0 013-3m9 0v-3.375c0-.621-.503-1.125-1.125-1.125h-.871M7.5 18.75v-3.375c0-.621.504-1.125 1.125-1.125h.872m5.007 0H9.497m5.007 0a7.454 7.454 0 01-.982-3.172M9.497 14.25a7.454 7.454 0 00.981-3.172M5.25 4.236c-.982.143-1.954.317-2.916.52A6.003 6.003 0 007.73 9.728M5.25 4.236V4.5c0 2.108.966 3.99 2.48 5.228M5.25 4.236V2.721C7.456 2.41 9.71 2.25 12 2.25c2.291 0 4.545.16 6.75.47v1.516M18.75 4.236c.982.143 1.954.317 2.916.52A6.003 6.003 0 0016.27 9.728M18.75 4.236V4.5c0 2.108-.966 3.99-2.48 5.228m0 0a6.003 6.003 0 01-5.54 0"
          ></path></svg
        >
      </div>
      <div>
        <h1 class="font-display text-xl font-bold text-navy">Crear torneo</h1>
        <p class="text-xs text-muted">
          Organiza una competición y suma puntos para todos los participantes.
        </p>
      </div>
    </div>

    <form method="POST" class="space-y-6">
      <!-- Organizador -->
      <div class="card p-6 space-y-4">
        <h2
          class="font-display text-sm font-bold text-navy uppercase tracking-wider flex items-center gap-2"
        >
          <svg
            class="w-4 h-4 text-teal"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
            ><path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"
            ></path></svg
          >
          Organizador
        </h2>
        <div class="flex items-center gap-3 bg-gray-50 rounded-xl p-3">
          <div class="w-8 h-8 rounded-lg bg-teal/10 flex items-center justify-center">
            <span class="text-sm font-bold text-teal">{user.name?.charAt(0)?.toUpperCase()}</span>
          </div>
          <div>
            <div class="text-sm font-medium text-navy">{user.name}</div>
            <div class="text-[11px] text-muted">{user.email}</div>
          </div>
          <span
            class="ml-auto text-[10px] font-semibold text-teal bg-teal/10 px-2 py-0.5 rounded-full uppercase"
            >Creador</span
          >
        </div>
        <p class="text-[11px] text-muted/60 flex items-center gap-1">
          <svg
            class="w-3 h-3"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
            ><path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M11.25 11.25l.041-.02a.75.75 0 011.063.852l-.708 2.836a.75.75 0 001.063.853l.041-.021M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9-3.75h.008v.008H12V8.25z"
            ></path></svg
          >
          Te inscribirás automáticamente como participante del torneo.
        </p>
      </div>

      <!-- Información del torneo -->
      <div class="card p-6 space-y-4">
        <h2
          class="font-display text-sm font-bold text-navy uppercase tracking-wider flex items-center gap-2"
        >
          <svg
            class="w-4 h-4 text-coral"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
            ><path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10"
            ></path></svg
          >
          Información del torneo
        </h2>
        <div>
          <label for="name" class="text-xs font-medium text-muted block mb-1.5"
            >Nombre del torneo</label
          >
          <input
            type="text"
            id="name"
            name="name"
            required
            placeholder="Torneo de Primavera 2026"
            class="w-full px-3.5 py-2.5 bg-white border border-gray-200 rounded-xl text-sm text-navy placeholder:text-muted/50 focus:outline-none focus:border-coral/50 transition-colors"
          />
        </div>
        <div>
          <label for="description" class="text-xs font-medium text-muted block mb-1.5"
            >Descripción</label
          >
          <textarea
            id="description"
            name="description"
            rows="3"
            placeholder="Detalles del torneo, reglas, premios..."
            class="w-full px-3.5 py-2.5 bg-white border border-gray-200 rounded-xl text-sm text-navy placeholder:text-muted/50 focus:outline-none focus:border-coral/50 transition-colors resize-none"
          ></textarea>
        </div>
      </div>

      <!-- Ubicación y fecha -->
      <div class="card p-6 space-y-4">
        <h2
          class="font-display text-sm font-bold text-navy uppercase tracking-wider flex items-center gap-2"
        >
          <svg
            class="w-4 h-4 text-coral"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
            ><path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5"
            ></path></svg
          >
          Lugar y fecha
        </h2>
        <div class="grid sm:grid-cols-2 gap-4">
          <div>
            <label for="location" class="text-xs font-medium text-muted block mb-1.5">
              <span class="flex items-center gap-1">
                <svg
                  class="w-3 h-3"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2"
                  ><path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"></path><path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"
                  ></path></svg
                >
                Ubicación
              </span>
            </label>
            <input
              type="text"
              id="location"
              name="location"
              placeholder="Club Pádel Madrid"
              class="w-full px-3.5 py-2.5 bg-white border border-gray-200 rounded-xl text-sm text-navy placeholder:text-muted/50 focus:outline-none focus:border-coral/50 transition-colors"
            />
          </div>
          <div>
            <label for="event_date" class="text-xs font-medium text-muted block mb-1.5">
              <span class="flex items-center gap-1">
                <svg
                  class="w-3 h-3"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2"
                  ><path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg
                >
                Fecha del evento
              </span>
            </label>
            <input
              type="date"
              id="event_date"
              name="event_date"
              required
              class="w-full px-3.5 py-2.5 bg-white border border-gray-200 rounded-xl text-sm text-navy focus:outline-none focus:border-coral/50 transition-colors"
            />
          </div>
        </div>
      </div>

      <!-- Configuración -->
      <div class="card p-6 space-y-4">
        <h2
          class="font-display text-sm font-bold text-navy uppercase tracking-wider flex items-center gap-2"
        >
          <svg
            class="w-4 h-4 text-teal"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
            ><path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.324.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 011.37.49l1.296 2.247a1.125 1.125 0 01-.26 1.431l-1.003.827c-.293.24-.438.613-.431.992a6.759 6.759 0 010 .255c-.007.378.138.75.43.99l1.005.828c.424.35.534.954.26 1.43l-1.298 2.247a1.125 1.125 0 01-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.57 6.57 0 01-.22.128c-.331.183-.581.495-.644.869l-.213 1.28c-.09.543-.56.941-1.11.941h-2.594c-.55 0-1.02-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 01-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 01-1.369-.49l-1.297-2.247a1.125 1.125 0 01.26-1.431l1.004-.827c.292-.24.437-.613.43-.992a6.932 6.932 0 010-.255c.007-.378-.138-.75-.43-.99l-1.004-.828a1.125 1.125 0 01-.26-1.43l1.297-2.247a1.125 1.125 0 011.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.087.22-.128.332-.183.582-.495.644-.869l.214-1.281z"
            ></path><path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path></svg
          >
          Configuración
        </h2>
        <div>
          <label for="max_players" class="text-xs font-medium text-muted block mb-1.5"
            >Máximo de jugadores</label
          >
          <div class="relative">
            <input
              type="number"
              id="max_players"
              name="max_players"
              min="4"
              max="128"
              value="16"
              class="w-full px-3.5 py-2.5 bg-white border border-gray-200 rounded-xl text-sm text-navy focus:outline-none focus:border-coral/50 transition-colors"
            />
          </div>
          <div class="flex items-center gap-4 mt-3">
            {
              [8, 16, 32, 64].map((n) => (
                <button
                  type="button"
                  data-players={n}
                  class="player-preset flex-1 py-1.5 text-xs font-semibold rounded-lg border border-gray-200 text-muted hover:border-coral/50 hover:text-coral transition-colors cursor-pointer"
                >
                  {n}
                </button>
              ))
            }
          </div>
          <p class="text-[11px] text-muted/60 mt-2">
            Selecciona un valor rápido o escribe uno personalizado.
          </p>
        </div>
      </div>

      <!-- Preview resumen -->
      <div class="card overflow-hidden">
        <div class="bg-gradient-to-r from-coral to-orange-400 p-4">
          <div
            class="flex items-center gap-2 text-white/80 text-[10px] font-semibold uppercase tracking-wider"
          >
            <svg
              class="w-3.5 h-3.5"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z"
              ></path><path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path></svg
            >
            Vista previa
          </div>
          <div class="text-white font-display font-bold mt-1" id="preview-name">
            Nombre del torneo
          </div>
        </div>
        <div class="p-4 grid grid-cols-3 gap-4 text-center">
          <div>
            <div class="text-[10px] text-muted uppercase tracking-wider mb-0.5">Ubicación</div>
            <div class="text-xs font-medium text-navy" id="preview-location">—</div>
          </div>
          <div>
            <div class="text-[10px] text-muted uppercase tracking-wider mb-0.5">Fecha</div>
            <div class="text-xs font-medium text-navy" id="preview-date">—</div>
          </div>
          <div>
            <div class="text-[10px] text-muted uppercase tracking-wider mb-0.5">Plazas</div>
            <div class="text-xs font-medium text-navy" id="preview-players">16</div>
          </div>
        </div>
      </div>

      <!-- Submit -->
      <button
        type="submit"
        class="w-full py-3 bg-coral text-white text-sm font-semibold rounded-xl hover:bg-coral-dark transition-colors flex items-center justify-center gap-2 shadow-sm"
      >
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"
          ><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"
          ></path></svg
        >
        Crear torneo
      </button>
    </form>
  </div>

  <script>
    // Quick-select player presets
    document.querySelectorAll('.player-preset').forEach((btn) => {
      btn.addEventListener('click', () => {
        const val = (btn as HTMLElement).dataset.players!
        ;(document.getElementById('max_players') as HTMLInputElement).value = val
        document.getElementById('preview-players')!.textContent = val
      })
    })

    // Live preview
    const nameInput = document.getElementById('name') as HTMLInputElement
    const locInput = document.getElementById('location') as HTMLInputElement
    const dateInput = document.getElementById('event_date') as HTMLInputElement
    const playersInput = document.getElementById('max_players') as HTMLInputElement

    nameInput?.addEventListener('input', () => {
      document.getElementById('preview-name')!.textContent = nameInput.value || 'Nombre del torneo'
    })
    locInput?.addEventListener('input', () => {
      document.getElementById('preview-location')!.textContent = locInput.value || '—'
    })
    dateInput?.addEventListener('input', () => {
      if (dateInput.value) {
        const d = new Date(dateInput.value + 'T12:00:00')
        document.getElementById('preview-date')!.textContent = d.toLocaleDateString('es-ES', {
          day: 'numeric',
          month: 'short',
        })
      } else {
        document.getElementById('preview-date')!.textContent = '—'
      }
    })
    playersInput?.addEventListener('input', () => {
      document.getElementById('preview-players')!.textContent = playersInput.value || '16'
    })
  </script>
</AppLayout>
