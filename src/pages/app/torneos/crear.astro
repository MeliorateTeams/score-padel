---
import AppLayout from '../../../layouts/AppLayout.astro'
import { generateId } from '../../../lib/auth'

const user = (Astro.locals as any).user
if (!user) return Astro.redirect('/login')

const db = (Astro.locals as any).db

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData()
  const name = form.get('name')?.toString().trim()
  const description = form.get('description')?.toString() ?? ''
  const location = form.get('location')?.toString() ?? ''
  const event_date = form.get('event_date')?.toString()
  const max_players = parseInt(form.get('max_players')?.toString() ?? '16') || 16

  if (name && event_date) {
    const id = generateId()
    await db
      .prepare(
        'INSERT INTO tournaments (id, creator_id, name, description, location, event_date, max_players) VALUES (?, ?, ?, ?, ?, ?, ?)',
      )
      .bind(id, user.id, name, description, location, event_date, max_players)
      .run()
    // Auto-join creator
    await db
      .prepare('INSERT INTO tournament_players (tournament_id, user_id) VALUES (?, ?)')
      .bind(id, user.id)
      .run()
    return Astro.redirect(`/app/torneos/${id}`)
  }
}
---

<AppLayout title="Crear torneo" user={user}>
  <div class="max-w-xl">
    <h1 class="font-display text-2xl font-bold mb-1">Crear torneo</h1>
    <p class="text-sm text-muted mb-8">
      Organiza una competición y suma puntos para todos los participantes.
    </p>

    <form method="POST" class="space-y-5">
      <div>
        <label for="name" class="text-xs font-medium text-muted block mb-1.5"
          >Nombre del torneo</label
        >
        <input
          type="text"
          id="name"
          name="name"
          required
          placeholder="Torneo de Primavera 2026"
          class="w-full px-3.5 py-2.5 bg-surface border border-white/10 rounded-lg text-sm text-text placeholder:text-muted/50 focus:outline-none focus:border-emerald/50 transition-colors"
        />
      </div>
      <div>
        <label for="description" class="text-xs font-medium text-muted block mb-1.5"
          >Descripción</label
        >
        <textarea
          id="description"
          name="description"
          rows="3"
          placeholder="Detalles del torneo..."
          class="w-full px-3.5 py-2.5 bg-surface border border-white/10 rounded-lg text-sm text-text placeholder:text-muted/50 focus:outline-none focus:border-emerald/50 transition-colors resize-none"
        ></textarea>
      </div>
      <div class="grid sm:grid-cols-2 gap-4">
        <div>
          <label for="location" class="text-xs font-medium text-muted block mb-1.5">Ubicación</label
          >
          <input
            type="text"
            id="location"
            name="location"
            placeholder="Club Pádel Madrid"
            class="w-full px-3.5 py-2.5 bg-surface border border-white/10 rounded-lg text-sm text-text placeholder:text-muted/50 focus:outline-none focus:border-emerald/50 transition-colors"
          />
        </div>
        <div>
          <label for="event_date" class="text-xs font-medium text-muted block mb-1.5">Fecha</label>
          <input
            type="date"
            id="event_date"
            name="event_date"
            required
            class="w-full px-3.5 py-2.5 bg-surface border border-white/10 rounded-lg text-sm text-text focus:outline-none focus:border-emerald/50 transition-colors"
          />
        </div>
      </div>
      <div>
        <label for="max_players" class="text-xs font-medium text-muted block mb-1.5"
          >Máximo de jugadores</label
        >
        <input
          type="number"
          id="max_players"
          name="max_players"
          min="4"
          max="128"
          value="16"
          class="w-full px-3.5 py-2.5 bg-surface border border-white/10 rounded-lg text-sm text-text focus:outline-none focus:border-emerald/50 transition-colors"
        />
      </div>
      <button
        type="submit"
        class="px-6 py-2.5 bg-emerald text-bg text-sm font-semibold rounded-lg hover:bg-emerald-glow transition-colors"
      >
        Crear torneo
      </button>
    </form>
  </div>
</AppLayout>
