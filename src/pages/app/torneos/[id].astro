---
import AppLayout from '../../../layouts/AppLayout.astro'

const user = (Astro.locals as any).user
if (!user) return Astro.redirect('/login')

const db = (Astro.locals as any).db
const { id } = Astro.params

const tournament = await db
  .prepare(
    `
  SELECT t.*, u.name as creator_name FROM tournaments t
  JOIN users u ON t.creator_id = u.id WHERE t.id = ?
`,
  )
  .bind(id)
  .first()

if (!tournament) return Astro.redirect('/app/torneos')

// Handle POST actions
if (Astro.request.method === 'POST' && user.role !== 'guest') {
  const form = await Astro.request.formData()
  const action = form.get('action')?.toString()
  if (action === 'join') {
    try {
      await db
        .prepare('INSERT INTO tournament_players (tournament_id, user_id) VALUES (?, ?)')
        .bind(id, user.id)
        .run()
    } catch {}
  } else if (action === 'leave') {
    await db
      .prepare('DELETE FROM tournament_players WHERE tournament_id = ? AND user_id = ?')
      .bind(id, user.id)
      .run()
  } else if (action === 'delete') {
    const isCreator = (tournament as any).creator_id === user.id
    const isAdmin = user.role === 'admin'
    if (isCreator || isAdmin) {
      // Remove rating_history for matches in this tournament
      await db
        .prepare(
          'DELETE FROM rating_history WHERE match_id IN (SELECT id FROM matches WHERE tournament_id = ?)',
        )
        .bind(id)
        .run()
      // Unlink matches from tournament (keep match records)
      await db
        .prepare('UPDATE matches SET tournament_id = NULL WHERE tournament_id = ?')
        .bind(id)
        .run()
      // Remove tournament players
      await db.prepare('DELETE FROM tournament_players WHERE tournament_id = ?').bind(id).run()
      // Delete tournament
      await db.prepare('DELETE FROM tournaments WHERE id = ?').bind(id).run()
      return Astro.redirect('/app/torneos')
    }
  }
}

const players = await db
  .prepare(
    `
  SELECT u.id, u.name, p.rating, p.location FROM tournament_players tp
  JOIN users u ON tp.user_id = u.id
  LEFT JOIN profiles p ON u.id = p.user_id
  WHERE tp.tournament_id = ?
  ORDER BY p.rating DESC
`,
  )
  .bind(id)
  .all()

const isJoined = players.results?.some((p: any) => p.id === user.id) ?? false
const isFull = (players.results?.length ?? 0) >= (tournament as any).max_players

// Partidos del torneo
const tournamentMatches = await db
  .prepare(
    `
  SELECT m.*, u1.name as t1_name, u2.name as t2_name
  FROM matches m
  JOIN users u1 ON m.team1_player1 = u1.id
  JOIN users u2 ON m.team2_player1 = u2.id
  WHERE m.tournament_id = ?
  ORDER BY m.created_at DESC
`,
  )
  .bind(id)
  .all()
---

<AppLayout title={(tournament as any).name} user={user}>
  <a href="/app/torneos" class="text-xs text-muted hover:text-coral transition-colors mb-6 block"
    >← Volver a torneos</a
  >

  <div class="grid lg:grid-cols-3 gap-6">
    <div class="lg:col-span-2">
      <div class="flex items-start justify-between mb-4">
        <div>
          <h1 class="font-display text-2xl font-bold mb-1">{(tournament as any).name}</h1>
          <p class="text-sm text-muted">
            {(tournament as any).location || 'Sin ubicación'} · {
              new Date((tournament as any).event_date).toLocaleDateString('es', {
                day: 'numeric',
                month: 'long',
                year: 'numeric',
              })
            }
          </p>
        </div>
        <span
          class:list={[
            'text-xs font-medium px-2.5 py-1 rounded-full',
            (tournament as any).status === 'open'
              ? 'bg-teal/10 text-teal'
              : 'bg-muted/10 text-muted',
          ]}
        >
          {(tournament as any).status === 'open' ? 'Abierto' : 'Cerrado'}
        </span>
      </div>

      {
        (tournament as any).description && (
          <p class="text-sm text-muted leading-relaxed mb-6">{(tournament as any).description}</p>
        )
      }

      <div class="text-xs text-muted mb-8">Organizado por {(tournament as any).creator_name}</div>

      {
        (tournament as any).status === 'open' && (
          <form method="POST">
            {isJoined ? (
              <>
                <input type="hidden" name="action" value="leave" />
                <button
                  type="submit"
                  class="px-5 py-2.5 border border-red-500/20 text-red-500 text-sm rounded-full hover:bg-red-500/10 transition-colors"
                >
                  Abandonar torneo
                </button>
              </>
            ) : !isFull ? (
              <>
                <input type="hidden" name="action" value="join" />
                <button
                  type="submit"
                  class="px-5 py-2.5 bg-coral text-white text-sm font-semibold rounded-full hover:bg-coral-dark transition-colors"
                >
                  Inscribirse
                </button>
              </>
            ) : (
              <p class="text-sm text-muted">El torneo está completo.</p>
            )}
          </form>
        )
      }

      {
        ((tournament as any).creator_id === user.id || user.role === 'admin') && (
          <form
            method="POST"
            onsubmit="return confirm('¿Eliminar este torneo? Esta acción no se puede deshacer.')"
            class="mt-4"
          >
            <input type="hidden" name="action" value="delete" />
            <button
              type="submit"
              class="inline-flex items-center gap-1.5 px-4 py-2 text-xs text-red-500 border border-red-500/20 rounded-xl hover:bg-red-500/10 transition-colors"
            >
              <svg
                class="w-3.5 h-3.5"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0"
                />
              </svg>
              Eliminar torneo
            </button>
          </form>
        )
      }

      <!-- Partidos del torneo -->
      <div class="mt-8">
        <h2 class="font-display text-base font-bold text-navy mb-4">Partidos del torneo</h2>
        {
          (tournamentMatches.results?.length ?? 0) === 0 ? (
            <p class="text-sm text-muted">Aún no se han registrado partidos en este torneo.</p>
          ) : (
            <div class="space-y-2">
              {tournamentMatches.results?.map((m: any) => (
                <div class="flex items-center justify-between p-3 rounded-xl bg-surface-2 border border-gray-100">
                  <div class="flex items-center gap-3">
                    <span
                      class:list={[
                        'w-2 h-2 rounded-full',
                        m.team1_games > m.team2_games ? 'bg-teal' : 'bg-red-400',
                      ]}
                    />
                    <div>
                      <div class="text-sm text-navy">
                        {m.t1_name} <span class="text-muted">vs</span> {m.t2_name}
                      </div>
                      <div class="text-xs text-muted mt-0.5">
                        {new Date(m.created_at).toLocaleDateString('es', {
                          day: 'numeric',
                          month: 'short',
                        })}
                      </div>
                    </div>
                  </div>
                  <div class="text-sm font-display font-semibold">
                    <span class:list={[m.team1_games > m.team2_games ? 'text-coral' : 'text-navy']}>
                      {m.team1_games}
                    </span>
                    <span class="text-muted mx-1">-</span>
                    <span class:list={[m.team2_games > m.team1_games ? 'text-coral' : 'text-navy']}>
                      {m.team2_games}
                    </span>
                  </div>
                </div>
              ))}
            </div>
          )
        }
      </div>
    </div>

    <div class="card p-6">
      <h2 class="font-display text-sm font-semibold text-navy mb-4">
        Jugadores inscritos ({players.results?.length ?? 0}/{(tournament as any).max_players})
      </h2>
      {
        (players.results?.length ?? 0) === 0 ? (
          <p class="text-xs text-muted">Nadie inscrito aún.</p>
        ) : (
          <div class="space-y-2">
            {players.results?.map((p: any) => (
              <div class="flex items-center justify-between p-2.5 rounded-xl bg-surface-2 border border-gray-100">
                <div>
                  <div class="text-sm text-navy">{p.name}</div>
                  <div class="text-xs text-muted">{p.location || 'Sin ubicación'}</div>
                </div>
                <span class="text-xs font-medium text-coral">
                  {Number(p.rating || 1).toFixed(1)}
                </span>
              </div>
            ))}
          </div>
        )
      }
    </div>
  </div>
</AppLayout>
