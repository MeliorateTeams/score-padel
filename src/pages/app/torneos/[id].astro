---
import AppLayout from '../../../layouts/AppLayout.astro'

const user = (Astro.locals as any).user
if (!user) return Astro.redirect('/login')

const db = (Astro.locals as any).db
const { id } = Astro.params

const tournament = await db
  .prepare(
    `
  SELECT t.*, u.name as creator_name FROM tournaments t
  JOIN users u ON t.creator_id = u.id WHERE t.id = ?
`,
  )
  .bind(id)
  .first()

if (!tournament) return Astro.redirect('/app/torneos')

// Handle join (guests can't join)
if (Astro.request.method === 'POST' && user.role !== 'guest') {
  const form = await Astro.request.formData()
  const action = form.get('action')?.toString()
  if (action === 'join') {
    try {
      await db
        .prepare('INSERT INTO tournament_players (tournament_id, user_id) VALUES (?, ?)')
        .bind(id, user.id)
        .run()
    } catch {}
  } else if (action === 'leave') {
    await db
      .prepare('DELETE FROM tournament_players WHERE tournament_id = ? AND user_id = ?')
      .bind(id, user.id)
      .run()
  }
}

const players = await db
  .prepare(
    `
  SELECT u.id, u.name, p.rating, p.location FROM tournament_players tp
  JOIN users u ON tp.user_id = u.id
  LEFT JOIN profiles p ON u.id = p.user_id
  WHERE tp.tournament_id = ?
  ORDER BY p.rating DESC
`,
  )
  .bind(id)
  .all()

const isJoined = players.results?.some((p: any) => p.id === user.id) ?? false
const isFull = (players.results?.length ?? 0) >= (tournament as any).max_players
---

<AppLayout title={(tournament as any).name} user={user}>
  <a href="/app/torneos" class="text-xs text-muted hover:text-coral transition-colors mb-6 block"
    >← Volver a torneos</a
  >

  <div class="grid lg:grid-cols-3 gap-6">
    <div class="lg:col-span-2">
      <div class="flex items-start justify-between mb-4">
        <div>
          <h1 class="font-display text-2xl font-bold mb-1">{(tournament as any).name}</h1>
          <p class="text-sm text-muted">
            {(tournament as any).location || 'Sin ubicación'} · {
              new Date((tournament as any).event_date).toLocaleDateString('es', {
                day: 'numeric',
                month: 'long',
                year: 'numeric',
              })
            }
          </p>
        </div>
        <span
          class:list={[
            'text-xs font-medium px-2.5 py-1 rounded-full',
            (tournament as any).status === 'open'
              ? 'bg-teal/10 text-teal'
              : 'bg-muted/10 text-muted',
          ]}
        >
          {(tournament as any).status === 'open' ? 'Abierto' : 'Cerrado'}
        </span>
      </div>

      {
        (tournament as any).description && (
          <p class="text-sm text-muted leading-relaxed mb-6">{(tournament as any).description}</p>
        )
      }

      <div class="text-xs text-muted mb-8">Organizado por {(tournament as any).creator_name}</div>

      {
        (tournament as any).status === 'open' && (
          <form method="POST">
            {isJoined ? (
              <>
                <input type="hidden" name="action" value="leave" />
                <button
                  type="submit"
                  class="px-5 py-2.5 border border-red-500/20 text-red-500 text-sm rounded-full hover:bg-red-500/10 transition-colors"
                >
                  Abandonar torneo
                </button>
              </>
            ) : !isFull ? (
              <>
                <input type="hidden" name="action" value="join" />
                <button
                  type="submit"
                  class="px-5 py-2.5 bg-coral text-white text-sm font-semibold rounded-full hover:bg-coral-dark transition-colors"
                >
                  Inscribirse
                </button>
              </>
            ) : (
              <p class="text-sm text-muted">El torneo está completo.</p>
            )}
          </form>
        )
      }
    </div>

    <div class="card p-6">
      <h2 class="font-display text-sm font-semibold text-navy mb-4">
        Jugadores inscritos ({players.results?.length ?? 0}/{(tournament as any).max_players})
      </h2>
      {
        (players.results?.length ?? 0) === 0 ? (
          <p class="text-xs text-muted">Nadie inscrito aún.</p>
        ) : (
          <div class="space-y-2">
            {players.results?.map((p: any) => (
              <div class="flex items-center justify-between p-2.5 rounded-xl bg-surface-2 border border-gray-100">
                <div>
                  <div class="text-sm text-navy">{p.name}</div>
                  <div class="text-xs text-muted">{p.location || 'Sin ubicación'}</div>
                </div>
                <span class="text-xs font-medium text-coral">
                  {Number(p.rating || 1).toFixed(1)}
                </span>
              </div>
            ))}
          </div>
        )
      }
    </div>
  </div>
</AppLayout>
