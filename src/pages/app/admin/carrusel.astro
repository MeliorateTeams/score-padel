---
import AppLayout from '../../../layouts/AppLayout.astro'

const user = (Astro.locals as any).user
if (!user) return Astro.redirect('/login')
if (user.role !== 'admin') return Astro.redirect('/app')

const db = (Astro.locals as any).db

let images: any[] = []
try {
  const result = await db
    .prepare('SELECT * FROM carousel_images ORDER BY sort_order ASC, id ASC')
    .all()
  images = (result.results ?? []) as any[]
} catch {
  // Table may not exist yet
}
---

<AppLayout title="Carrusel de imágenes" user={user}>
  <div class="max-w-4xl mx-auto space-y-6">
    <div class="flex items-center justify-between">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 rounded-xl bg-coral/10 flex items-center justify-center">
          <svg
            class="w-5 h-5 text-coral"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.41a2.25 2.25 0 013.182 0l2.909 2.91m-18 3.75h16.5a1.5 1.5 0 001.5-1.5V6a1.5 1.5 0 00-1.5-1.5H3.75A1.5 1.5 0 002.25 6v12a1.5 1.5 0 001.5 1.5zm10.5-11.25h.008v.008h-.008V8.25zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z"
            ></path>
          </svg>
        </div>
        <div>
          <h1 class="font-display text-xl font-bold text-navy">Carrusel de imágenes</h1>
          <p class="text-xs text-muted">
            Gestiona las imágenes del carrusel de la página principal.
          </p>
        </div>
      </div>
      <a href="/app/admin" class="text-sm text-muted hover:text-coral transition-colors"
        >&larr; Admin</a
      >
    </div>

    <!-- Add new image -->
    <div class="card p-5">
      <h2 class="font-display text-sm font-bold text-navy uppercase tracking-wider mb-4">
        Añadir imagen
      </h2>
      <form id="add-form" class="flex flex-col sm:flex-row gap-3">
        <input
          type="url"
          name="image_url"
          placeholder="URL de la imagen (https://...)"
          required
          class="flex-1 px-4 py-2.5 text-sm border border-gray-200 rounded-xl bg-white focus:border-coral focus:ring-1 focus:ring-coral outline-none transition-colors"
        />
        <input
          type="text"
          name="alt_text"
          placeholder="Texto alternativo (opcional)"
          class="sm:w-48 px-4 py-2.5 text-sm border border-gray-200 rounded-xl bg-white focus:border-coral focus:ring-1 focus:ring-coral outline-none transition-colors"
        />
        <button
          type="submit"
          class="px-6 py-2.5 text-sm font-semibold bg-coral text-white rounded-xl hover:bg-coral-dark transition-colors shadow-sm"
        >
          Añadir
        </button>
      </form>
      <div id="add-msg" class="hidden mt-3 text-sm"></div>
    </div>

    <!-- Current images -->
    <div class="card overflow-hidden">
      <div class="px-5 py-3 border-b border-gray-100 flex items-center justify-between">
        <h2 class="font-display text-sm font-bold text-navy uppercase tracking-wider">
          Imágenes actuales ({images.length})
        </h2>
      </div>
      {
        images.length === 0 ? (
          <div class="p-8 text-center text-muted text-sm">
            No hay imágenes en el carrusel. Añade una URL arriba para empezar.
          </div>
        ) : (
          <div class="divide-y divide-gray-100" id="images-list">
            {images.map((img: any, i: number) => (
              <div class="flex items-center gap-4 px-5 py-3" data-id={img.id}>
                <span class="text-xs text-muted font-mono w-6 text-center">{i + 1}</span>
                <img
                  src={img.image_url}
                  alt={img.alt_text || ''}
                  class="w-20 h-14 object-cover rounded-lg border border-gray-100"
                  loading="lazy"
                />
                <div class="flex-1 min-w-0">
                  <p class="text-sm text-navy truncate">{img.image_url}</p>
                  <p class="text-xs text-muted">{img.alt_text || 'Sin texto alt'}</p>
                </div>
                <span
                  class={`text-[10px] font-semibold px-2 py-0.5 rounded-full ${img.active ? 'bg-green-100 text-green-700' : 'bg-gray-100 text-gray-500'}`}
                >
                  {img.active ? 'Activa' : 'Inactiva'}
                </span>
                <button
                  class="toggle-btn text-xs px-3 py-1.5 rounded-lg border border-gray-200 hover:border-coral hover:text-coral transition-colors"
                  data-id={img.id}
                >
                  {img.active ? 'Desactivar' : 'Activar'}
                </button>
                <button
                  class="delete-btn text-xs px-3 py-1.5 rounded-lg border border-red-200 text-red-500 hover:bg-red-50 transition-colors"
                  data-id={img.id}
                >
                  Eliminar
                </button>
              </div>
            ))}
          </div>
        )
      }
    </div>
  </div>

  <script>
    // Add image
    const addForm = document.getElementById('add-form') as HTMLFormElement
    const addMsg = document.getElementById('add-msg')!

    addForm?.addEventListener('submit', async (e) => {
      e.preventDefault()
      const fd = new FormData(addForm)
      fd.append('action', 'add')
      fd.append('sort_order', '999')

      const res = await fetch('/api/carousel', { method: 'POST', body: fd })
      const data = await res.json()

      if (data.ok) {
        addMsg.textContent = 'Imagen añadida correctamente.'
        addMsg.className = 'mt-3 text-sm text-green-600'
        addMsg.classList.remove('hidden')
        setTimeout(() => location.reload(), 800)
      } else {
        addMsg.textContent = data.error || 'Error al añadir imagen.'
        addMsg.className = 'mt-3 text-sm text-red-500'
        addMsg.classList.remove('hidden')
      }
    })

    // Toggle active
    document.querySelectorAll('.toggle-btn').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const id = (btn as HTMLElement).dataset.id
        const fd = new FormData()
        fd.append('action', 'toggle')
        fd.append('id', id!)
        await fetch('/api/carousel', { method: 'POST', body: fd })
        location.reload()
      })
    })

    // Delete
    document.querySelectorAll('.delete-btn').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const id = (btn as HTMLElement).dataset.id
        if (!confirm('¿Eliminar esta imagen del carrusel?')) return
        const fd = new FormData()
        fd.append('action', 'delete')
        fd.append('id', id!)
        await fetch('/api/carousel', { method: 'POST', body: fd })
        location.reload()
      })
    })
  </script>
</AppLayout>
