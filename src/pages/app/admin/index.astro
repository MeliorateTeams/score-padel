---
import AppLayout from '../../../layouts/AppLayout.astro'

const user = (Astro.locals as any).user
if (!user) return Astro.redirect('/login')
if (user.role !== 'admin') return Astro.redirect('/app')

const db = (Astro.locals as any).db

const totalUsers = await db
  .prepare("SELECT COUNT(*) as cnt FROM users WHERE role != 'guest'")
  .first()
const totalMatches = await db.prepare('SELECT COUNT(*) as cnt FROM matches').first()
const totalTournaments = await db.prepare('SELECT COUNT(*) as cnt FROM tournaments').first()

const weekAgo = new Date(Date.now() - 7 * 86400000).toISOString()
const matchesThisWeek = await db
  .prepare('SELECT COUNT(*) as cnt FROM matches WHERE created_at >= ?')
  .bind(weekAgo)
  .first()
const newUsersThisWeek = await db
  .prepare("SELECT COUNT(*) as cnt FROM users WHERE created_at >= ? AND role != 'guest'")
  .bind(weekAgo)
  .first()

// Level distribution
const levelDist = await db
  .prepare(
    `
  SELECT
    SUM(CASE WHEN p.rating < 3.5 THEN 1 ELSE 0 END) as div_c,
    SUM(CASE WHEN p.rating >= 3.5 AND p.rating < 6.0 THEN 1 ELSE 0 END) as div_b,
    SUM(CASE WHEN p.rating >= 6.0 THEN 1 ELSE 0 END) as div_a
  FROM profiles p
`,
  )
  .first()

// Most active players
const activeUsers = await db
  .prepare(
    `
  SELECT u.id, u.name, COUNT(*) as match_count, p.rating
  FROM users u
  JOIN matches m ON (m.team1_player1 = u.id OR m.team1_player2 = u.id OR m.team2_player1 = u.id OR m.team2_player2 = u.id)
  LEFT JOIN profiles p ON u.id = p.user_id
  GROUP BY u.id
  ORDER BY match_count DESC LIMIT 10
`,
  )
  .all()

// Recent matches
const recentMatches = await db
  .prepare(
    `
  SELECT m.created_at, u1.name as t1, u2.name as t2, m.team1_games, m.team2_games
  FROM matches m
  JOIN users u1 ON m.team1_player1 = u1.id
  JOIN users u2 ON m.team2_player1 = u2.id
  ORDER BY m.created_at DESC LIMIT 10
`,
  )
  .all()

// Pending challenges
const pendingChallenges = await db
  .prepare("SELECT COUNT(*) as cnt FROM challenges WHERE status = 'pending'")
  .first()
---

<AppLayout title="Admin" user={user}>
  <div class="max-w-4xl mx-auto space-y-6">
    <div class="flex items-center gap-3">
      <div class="w-10 h-10 rounded-xl bg-navy/10 flex items-center justify-center">
        <svg
          class="w-5 h-5 text-navy"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
          ><path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M10.5 6h9.75M10.5 6a1.5 1.5 0 11-3 0m3 0a1.5 1.5 0 10-3 0M3.75 6H7.5m3 12h9.75m-9.75 0a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m-3.75 0H7.5m9-6h3.75m-3.75 0a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m-9.75 0h9.75"
          ></path></svg
        >
      </div>
      <div>
        <h1 class="font-display text-xl font-bold text-navy">Panel de administración</h1>
        <p class="text-xs text-muted">Estadísticas globales y gestión de la plataforma.</p>
      </div>
    </div>

    <!-- Key stats -->
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
      <div class="card p-4 text-center">
        <div class="font-display text-2xl font-extrabold text-coral">{totalUsers?.cnt ?? 0}</div>
        <div class="text-[11px] text-muted mt-0.5">Jugadores</div>
      </div>
      <div class="card p-4 text-center">
        <div class="font-display text-2xl font-extrabold text-teal">{totalMatches?.cnt ?? 0}</div>
        <div class="text-[11px] text-muted mt-0.5">Partidos</div>
      </div>
      <div class="card p-4 text-center">
        <div class="font-display text-2xl font-extrabold text-amber">
          {totalTournaments?.cnt ?? 0}
        </div>
        <div class="text-[11px] text-muted mt-0.5">Torneos</div>
      </div>
      <div class="card p-4 text-center">
        <div class="font-display text-2xl font-extrabold text-navy">
          {pendingChallenges?.cnt ?? 0}
        </div>
        <div class="text-[11px] text-muted mt-0.5">Retos pendientes</div>
      </div>
    </div>

    <!-- This week -->
    <div class="grid sm:grid-cols-2 gap-3">
      <div class="card p-5 flex items-center gap-4">
        <div class="w-10 h-10 rounded-xl bg-teal/10 flex items-center justify-center">
          <svg
            class="w-5 h-5 text-teal"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
            ><path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M2.25 18L9 11.25l4.306 4.307a11.95 11.95 0 015.814-5.519l2.74-1.22m0 0l-5.94-2.28m5.94 2.28l-2.28 5.941"
            ></path></svg
          >
        </div>
        <div>
          <div class="font-display text-lg font-bold text-navy">{matchesThisWeek?.cnt ?? 0}</div>
          <div class="text-xs text-muted">Partidos esta semana</div>
        </div>
      </div>
      <div class="card p-5 flex items-center gap-4">
        <div class="w-10 h-10 rounded-xl bg-coral/10 flex items-center justify-center">
          <svg
            class="w-5 h-5 text-coral"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
            ><path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M19 7.5v3m0 0v3m0-3h3m-3 0h-3m-2.25-4.125a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zM4 19.235v-.11a6.375 6.375 0 0112.75 0v.109A12.318 12.318 0 0110.374 21c-2.331 0-4.512-.645-6.374-1.766z"
            ></path></svg
          >
        </div>
        <div>
          <div class="font-display text-lg font-bold text-navy">{newUsersThisWeek?.cnt ?? 0}</div>
          <div class="text-xs text-muted">Nuevos jugadores esta semana</div>
        </div>
      </div>
    </div>

    <!-- Level distribution -->
    <div class="card p-5">
      <h2 class="font-display text-sm font-bold text-navy uppercase tracking-wider mb-4">
        Distribución por división
      </h2>
      <div class="grid grid-cols-3 gap-3">
        <div class="text-center p-3 rounded-xl bg-blue-50">
          <div class="font-display text-2xl font-extrabold text-blue-500">
            {levelDist?.div_c ?? 0}
          </div>
          <div class="text-[10px] text-muted uppercase font-semibold">División C</div>
          <div class="text-[10px] text-muted">1.0 - 3.0</div>
        </div>
        <div class="text-center p-3 rounded-xl bg-amber/10">
          <div class="font-display text-2xl font-extrabold text-amber-600">
            {levelDist?.div_b ?? 0}
          </div>
          <div class="text-[10px] text-muted uppercase font-semibold">División B</div>
          <div class="text-[10px] text-muted">3.5 - 5.5</div>
        </div>
        <div class="text-center p-3 rounded-xl bg-coral/10">
          <div class="font-display text-2xl font-extrabold text-coral">{levelDist?.div_a ?? 0}</div>
          <div class="text-[10px] text-muted uppercase font-semibold">División A</div>
          <div class="text-[10px] text-muted">6.0 - 7.0</div>
        </div>
      </div>
    </div>

    <div class="grid lg:grid-cols-2 gap-6">
      <!-- Most active -->
      <div class="card overflow-hidden">
        <div class="px-5 py-3 border-b border-gray-100">
          <h2 class="font-display text-sm font-bold text-navy uppercase tracking-wider">
            Jugadores más activos
          </h2>
        </div>
        <div class="divide-y divide-gray-100">
          {
            activeUsers.results?.map((p: any, i: number) => (
              <div class="flex items-center justify-between px-5 py-2.5">
                <div class="flex items-center gap-2">
                  <span
                    class:list={[
                      'w-5 h-5 rounded-full flex items-center justify-center text-[9px] font-bold',
                      i < 3 ? 'bg-amber/20 text-amber-700' : 'bg-gray-100 text-muted',
                    ]}
                  >
                    {i + 1}
                  </span>
                  <a
                    href={`/app/jugadores/${p.id}`}
                    class="text-sm text-navy hover:text-coral transition-colors"
                  >
                    {p.name}
                  </a>
                </div>
                <div class="text-xs text-muted">{p.match_count} partidos</div>
              </div>
            ))
          }
        </div>
      </div>

      <!-- Recent matches -->
      <div class="card overflow-hidden">
        <div class="px-5 py-3 border-b border-gray-100">
          <h2 class="font-display text-sm font-bold text-navy uppercase tracking-wider">
            Últimos partidos
          </h2>
        </div>
        <div class="divide-y divide-gray-100">
          {
            recentMatches.results?.map((m: any) => (
              <div class="flex items-center justify-between px-5 py-2.5">
                <div class="text-sm text-navy">
                  {m.t1} <span class="text-muted text-xs">vs</span> {m.t2}
                </div>
                <div class="flex items-center gap-2">
                  <span class="font-display text-sm font-bold text-coral">
                    {m.team1_games}–{m.team2_games}
                  </span>
                  <span class="text-[10px] text-muted">
                    {new Date(m.created_at).toLocaleDateString('es', {
                      day: 'numeric',
                      month: 'short',
                    })}
                  </span>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>

    <!-- Admin links -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-3">
      <a
        href="/app/admin/carrusel"
        class="card p-5 hover:border-coral/30 transition-colors flex items-center gap-3"
      >
        <div class="w-10 h-10 rounded-xl bg-teal/10 flex items-center justify-center">
          <svg
            class="w-5 h-5 text-teal"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
            ><path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.41a2.25 2.25 0 013.182 0l2.909 2.91m-18 3.75h16.5a1.5 1.5 0 001.5-1.5V6a1.5 1.5 0 00-1.5-1.5H3.75A1.5 1.5 0 002.25 6v12a1.5 1.5 0 001.5 1.5zm10.5-11.25h.008v.008h-.008V8.25zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z"
            ></path></svg
          >
        </div>
        <div>
          <div class="text-sm font-semibold text-navy">Carrusel de imágenes</div>
          <div class="text-xs text-muted">Imágenes de la página principal.</div>
        </div>
      </a>
      <aa
        href="/app/admin/usuarios"
        class="card p-5 hover:border-coral/30 transition-colors flex items-center gap-3"
      >
        <div class="w-10 h-10 rounded-xl bg-coral/10 flex items-center justify-center">
          <svg
            class="w-5 h-5 text-coral"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
            ><path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z"
            ></path></svg
          >
        </div>
        <div>
          <div class="text-sm font-semibold text-navy">Gestión de usuarios</div>
          <div class="text-xs text-muted">Roles, suspensión y contraseñas.</div>
        </div>
      </aa>
      <a
        href="/app/algoritmo"
        class="card p-5 hover:border-coral/30 transition-colors flex items-center gap-3"
      >
        <div class="w-10 h-10 rounded-xl bg-amber/10 flex items-center justify-center">
          <svg
            class="w-5 h-5 text-amber-600"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
            ><path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M9.75 3.104v5.714a2.25 2.25 0 01-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 014.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0112 15a9.065 9.065 0 00-6.23.693L5 14.5m14.8.8l1.402 1.402c1.232 1.232.65 3.318-1.067 3.611A48.309 48.309 0 0112 21c-2.773 0-5.491-.235-8.135-.687-1.718-.293-2.3-2.379-1.067-3.61L5 14.5"
            ></path></svg
          >
        </div>
        <div>
          <div class="text-sm font-semibold text-navy">Algoritmo de valoración</div>
          <div class="text-xs text-muted">Documentación técnica del sistema.</div>
        </div>
      </a>
      <a
        href="/app/clasificacion"
        class="card p-5 hover:border-coral/30 transition-colors flex items-center gap-3"
      >
        <div class="w-10 h-10 rounded-xl bg-teal/10 flex items-center justify-center">
          <svg
            class="w-5 h-5 text-teal"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
            ><path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z"
            ></path></svg
          >
        </div>
        <div>
          <div class="text-sm font-semibold text-navy">Valoraciones globales</div>
          <div class="text-xs text-muted">Rankings y filtros avanzados.</div>
        </div>
      </a>
    </div>
  </div>
</AppLayout>
