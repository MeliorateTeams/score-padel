---
import AppLayout from '../../../../layouts/AppLayout.astro'
import { hashPassword } from '../../../../lib/auth'

const user = (Astro.locals as any).user
if (!user) return Astro.redirect('/login')
if (user.role !== 'admin') return Astro.redirect('/app')

const db = (Astro.locals as any).db
let message = ''

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData()
  const action = form.get('action')?.toString()
  const targetId = form.get('user_id')?.toString()

  if (targetId && targetId !== user.id) {
    if (action === 'change-role') {
      const newRole = form.get('new_role')?.toString()
      if (newRole && ['admin', 'player'].includes(newRole)) {
        await db.prepare('UPDATE users SET role = ? WHERE id = ?').bind(newRole, targetId).run()
        message = 'Rol actualizado.'
      }
    } else if (action === 'suspend') {
      await db.prepare("UPDATE users SET role = 'suspended' WHERE id = ?").bind(targetId).run()
      // Delete sessions to force logout
      await db.prepare('DELETE FROM sessions WHERE user_id = ?').bind(targetId).run()
      message = 'Usuario suspendido.'
    } else if (action === 'unsuspend') {
      await db.prepare("UPDATE users SET role = 'player' WHERE id = ?").bind(targetId).run()
      message = 'Usuario reactivado.'
    } else if (action === 'reset-password') {
      // Generate random temporary password (12 chars, letters+digits+symbols)
      const chars = 'ABCDEFGHJKLMNPQRSTUVWXYZabcdefghjkmnpqrstuvwxyz23456789!@#$%'
      const bytes = crypto.getRandomValues(new Uint8Array(12))
      const tempPass = Array.from(bytes, (b) => chars[b % chars.length]).join('')
      const hash = await hashPassword(tempPass)
      await db.prepare('UPDATE users SET password_hash = ? WHERE id = ?').bind(hash, targetId).run()
      // Also delete sessions to force re-login
      await db.prepare('DELETE FROM sessions WHERE user_id = ?').bind(targetId).run()
      message = `Contraseña temporal: ${tempPass} (el usuario debe cambiarla al iniciar sesión)`
    } else if (action === 'delete-user') {
      await db.prepare('DELETE FROM sessions WHERE user_id = ?').bind(targetId).run()
      await db.prepare('DELETE FROM notifications WHERE user_id = ?').bind(targetId).run()
      await db.prepare('DELETE FROM rating_history WHERE user_id = ?').bind(targetId).run()
      await db.prepare('DELETE FROM match_confirmations WHERE user_id = ?').bind(targetId).run()
      await db
        .prepare('DELETE FROM challenges WHERE challenger_id = ? OR challenged_id = ?')
        .bind(targetId, targetId)
        .run()
      await db.prepare('DELETE FROM tournament_players WHERE user_id = ?').bind(targetId).run()
      await db
        .prepare('UPDATE matches SET team1_player1 = NULL WHERE team1_player1 = ?')
        .bind(targetId)
        .run()
      await db
        .prepare('UPDATE matches SET team1_player2 = NULL WHERE team1_player2 = ?')
        .bind(targetId)
        .run()
      await db
        .prepare('UPDATE matches SET team2_player1 = NULL WHERE team2_player1 = ?')
        .bind(targetId)
        .run()
      await db
        .prepare('UPDATE matches SET team2_player2 = NULL WHERE team2_player2 = ?')
        .bind(targetId)
        .run()
      await db.prepare('DELETE FROM profiles WHERE user_id = ?').bind(targetId).run()
      await db.prepare('DELETE FROM users WHERE id = ?').bind(targetId).run()
      message = 'Usuario eliminado permanentemente.'
    }
  }
}

const users = await db
  .prepare(
    `
  SELECT u.id, u.name, u.email, u.role, u.created_at, p.rating, p.matches_played
  FROM users u
  LEFT JOIN profiles p ON u.id = p.user_id
  ORDER BY u.created_at DESC
`,
  )
  .all()
---

<AppLayout title="Gestión de usuarios" user={user}>
  <div class="max-w-4xl mx-auto space-y-6">
    <div class="flex items-center gap-3">
      <a href="/app/admin" class="text-xs text-muted hover:text-coral transition-colors">← Admin</a>
    </div>
    <div class="flex items-center gap-3">
      <div class="w-10 h-10 rounded-xl bg-coral/10 flex items-center justify-center">
        <svg
          class="w-5 h-5 text-coral"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
          ><path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z"
          ></path></svg
        >
      </div>
      <div>
        <h1 class="font-display text-xl font-bold text-navy">Gestión de usuarios</h1>
        <p class="text-xs text-muted">
          Administra roles, suspende cuentas o restablece contraseñas.
        </p>
      </div>
    </div>

    {
      message && (
        <div class="p-4 rounded-xl bg-teal/10 border border-teal/20 text-sm text-teal font-medium">
          {message}
        </div>
      )
    }

    <div class="card overflow-hidden">
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-gray-100 text-muted text-left">
              <th class="px-4 py-3 font-medium">Usuario</th>
              <th class="px-4 py-3 font-medium">Rol</th>
              <th class="px-4 py-3 font-medium text-center">Partidos</th>
              <th class="px-4 py-3 font-medium text-center">Rating</th>
              <th class="px-4 py-3 font-medium text-right">Acciones</th>
            </tr>
          </thead>
          <tbody>
            {
              users.results?.map((u: any) => {
                const isMe = u.id === user.id
                const isSuspended = u.role === 'suspended'
                return (
                  <tr
                    class:list={[
                      'border-b border-gray-100 hover:bg-gray-50/50 transition-colors',
                      isMe && 'bg-coral/5',
                      isSuspended && 'opacity-50',
                    ]}
                  >
                    <td class="px-4 py-3">
                      <a
                        href={`/app/jugadores/${u.id}`}
                        class="font-medium text-navy hover:text-coral transition-colors"
                      >
                        {u.name}
                      </a>
                      <div class="text-[11px] text-muted">{u.email}</div>
                    </td>
                    <td class="px-4 py-3">
                      <span
                        class:list={[
                          'text-[10px] font-semibold uppercase px-2 py-0.5 rounded-full',
                          u.role === 'admin'
                            ? 'bg-coral/10 text-coral'
                            : u.role === 'suspended'
                              ? 'bg-red-500/10 text-red-500'
                              : 'bg-teal/10 text-teal',
                        ]}
                      >
                        {u.role}
                      </span>
                    </td>
                    <td class="px-4 py-3 text-center text-muted">{u.matches_played ?? 0}</td>
                    <td class="px-4 py-3 text-center font-display font-bold text-coral">
                      {Number(u.rating || 1).toFixed(1)}
                    </td>
                    <td class="px-4 py-3 text-right">
                      {!isMe && (
                        <div class="flex items-center justify-end gap-1">
                          <a
                            href={`/app/admin/usuarios/${u.id}`}
                            class="p-1 text-muted/50 hover:text-coral transition-colors"
                            title="Editar"
                          >
                            <svg
                              class="w-3.5 h-3.5"
                              fill="none"
                              viewBox="0 0 24 24"
                              stroke="currentColor"
                              stroke-width="2"
                            >
                              <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10"
                              />
                            </svg>
                          </a>
                          {!isSuspended ? (
                            <>
                              <form method="POST" class="inline">
                                <input type="hidden" name="action" value="change-role" />
                                <input type="hidden" name="user_id" value={u.id} />
                                <select
                                  name="new_role"
                                  onchange="this.form.submit()"
                                  class="text-[10px] px-2 py-1 border border-gray-200 rounded-lg bg-white"
                                >
                                  <option value="">Cambiar rol...</option>
                                  <option value="admin">Admin</option>
                                  <option value="player">Player</option>
                                </select>
                              </form>
                              <form
                                method="POST"
                                class="inline"
                                id={`form-suspend-${u.id}`}
                              >
                                <input type="hidden" name="action" value="suspend" />
                                <input type="hidden" name="user_id" value={u.id} />
                                <button
                                  type="button"
                                  onclick={`spConfirm('Suspender usuario','¿Suspender a ${u.name}? Se cerrará su sesión y no podrá acceder.',()=>document.getElementById('form-suspend-${u.id}').submit(),'warning')`}
                                  class="p-1 text-muted/50 hover:text-red-500 transition-colors"
                                  title="Suspender"
                                >
                                  <svg
                                    class="w-3.5 h-3.5"
                                    fill="none"
                                    viewBox="0 0 24 24"
                                    stroke="currentColor"
                                    stroke-width="2"
                                  >
                                    <path
                                      stroke-linecap="round"
                                      stroke-linejoin="round"
                                      d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636"
                                    />
                                  </svg>
                                </button>
                              </form>
                              <form
                                method="POST"
                                class="inline"
                                id={`form-reset-${u.id}`}
                              >
                                <input type="hidden" name="action" value="reset-password" />
                                <input type="hidden" name="user_id" value={u.id} />
                                <button
                                  type="button"
                                  onclick={`spConfirm('Restablecer contraseña','¿Generar contraseña temporal para ${u.name} y cerrar su sesión?',()=>document.getElementById('form-reset-${u.id}').submit(),'warning')`}
                                  class="p-1 text-muted/50 hover:text-amber-500 transition-colors"
                                  title="Reset contraseña"
                                >
                                  <svg
                                    class="w-3.5 h-3.5"
                                    fill="none"
                                    viewBox="0 0 24 24"
                                    stroke="currentColor"
                                    stroke-width="2"
                                  >
                                    <path
                                      stroke-linecap="round"
                                      stroke-linejoin="round"
                                      d="M15.75 5.25a3 3 0 013 3m3 0a6 6 0 01-7.029 5.912c-.563-.097-1.159.026-1.563.43L10.5 17.25H8.25v2.25H6v2.25H2.25v-2.818c0-.597.237-1.17.659-1.591l6.499-6.499c.404-.404.527-1 .43-1.563A6 6 0 1121.75 8.25z"
                                    />
                                  </svg>
                                </button>
                              </form>
                              <form
                                method="POST"
                                class="inline"
                                id={`form-delete-${u.id}`}
                              >
                                <input type="hidden" name="action" value="delete-user" />
                                <input type="hidden" name="user_id" value={u.id} />
                                <button
                                  type="button"
                                  onclick={`spConfirm('Eliminar usuario permanentemente','¿Eliminar a ${u.name}? Se borrarán todos sus datos, partidos e historial. Esta acción no se puede deshacer.',()=>document.getElementById('form-delete-${u.id}').submit(),'danger')`}
                                  class="p-1 text-muted/50 hover:text-red-600 transition-colors"
                                  title="Eliminar usuario"
                                >
                                  <svg
                                    class="w-3.5 h-3.5"
                                    fill="none"
                                    viewBox="0 0 24 24"
                                    stroke="currentColor"
                                    stroke-width="2"
                                  >
                                    <path
                                      stroke-linecap="round"
                                      stroke-linejoin="round"
                                      d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0"
                                    />
                                  </svg>
                                </button>
                              </form>
                            </>
                          ) : (
                            <form method="POST" class="inline">
                              <input type="hidden" name="action" value="unsuspend" />
                              <input type="hidden" name="user_id" value={u.id} />
                              <button
                                type="submit"
                                class="px-2 py-1 text-[10px] font-semibold bg-teal/10 text-teal rounded-full hover:bg-teal/20 transition-colors"
                              >
                                Reactivar
                              </button>
                            </form>
                          )}
                        </div>
                      )}
                    </td>
                  </tr>
                )
              })
            }
          </tbody>
        </table>
      </div>
    </div>
  </div>
</AppLayout>
