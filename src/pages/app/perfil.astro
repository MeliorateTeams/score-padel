---
import AppLayout from '../../layouts/AppLayout.astro'
import { getProfile, updateProfile } from '../../lib/db'
import { calculateInitialRating } from '../../lib/rating'

const user = (Astro.locals as any).user
if (!user) return Astro.redirect('/login')
if (user.role === 'guest') return Astro.redirect('/app?error=guest')

const db = (Astro.locals as any).db
let message = ''

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData()
  const experienceYears = parseInt(form.get('experience_years')?.toString() ?? '0') || 0
  const racquetSports = form.get('racquet_sports')?.toString() ?? ''
  const birthDate = form.get('birth_date')?.toString() ?? ''
  const gender = form.get('gender')?.toString() ?? ''

  await updateProfile(db, user.id, {
    bio: form.get('bio')?.toString() ?? '',
    location: form.get('location')?.toString() ?? '',
    experience_years: experienceYears,
    racquet_sports: racquetSports,
    birth_date: birthDate,
    gender: gender,
  })

  // Si el jugador no tiene partidos, ajustar rating inicial según perfil
  const currentProfile = await getProfile(db, user.id)
  if (currentProfile && currentProfile.matches_played === 0) {
    const initialRating = calculateInitialRating(experienceYears, racquetSports)
    await db
      .prepare("UPDATE profiles SET rating = ?, updated_at = datetime('now') WHERE user_id = ?")
      .bind(initialRating, user.id)
      .run()
  }

  message = 'Perfil actualizado correctamente.'
}

const profile = await getProfile(db, user.id)
---

<AppLayout title="Mi perfil" user={user}>
  <div class="max-w-2xl">
    <h1 class="font-display text-2xl font-bold mb-1">Mi perfil</h1>
    <p class="text-sm text-muted mb-8">
      Completa tu perfil para obtener una valoración más precisa.
    </p>

    {
      message && (
        <div class="bg-teal/10 border border-teal/20 text-teal text-xs p-3 rounded-xl mb-6">
          {message}
        </div>
      )
    }

    <form method="POST" class="space-y-5">
      <div class="grid sm:grid-cols-2 gap-4">
        <div>
          <label class="text-xs font-medium text-muted block mb-1.5">Nombre</label>
          <input
            type="text"
            disabled
            value={user.name}
            class="w-full px-3.5 py-2.5 bg-white border border-gray-200 rounded-xl text-sm text-muted"
          />
        </div>
        <div>
          <label class="text-xs font-medium text-muted block mb-1.5">Email</label>
          <input
            type="email"
            disabled
            value={user.email}
            class="w-full px-3.5 py-2.5 bg-white border border-gray-200 rounded-xl text-sm text-muted"
          />
        </div>
      </div>

      <div>
        <label for="location" class="text-xs font-medium text-muted block mb-1.5"
          >Ubicación (ciudad, país)</label
        >
        <input
          type="text"
          id="location"
          name="location"
          value={profile?.location ?? ''}
          placeholder="Madrid, España"
          class="w-full px-3.5 py-2.5 bg-white border border-gray-200 rounded-xl text-sm text-navy placeholder:text-muted/50 focus:outline-none focus:border-coral/50 transition-colors"
        />
      </div>

      <div class="grid sm:grid-cols-2 gap-4">
        <div>
          <label for="birth_date" class="text-xs font-medium text-muted block mb-1.5"
            >Fecha de nacimiento</label
          >
          <input
            type="date"
            id="birth_date"
            name="birth_date"
            value={profile?.birth_date ?? ''}
            class="w-full px-3.5 py-2.5 bg-white border border-gray-200 rounded-xl text-sm text-navy focus:outline-none focus:border-coral/50 transition-colors"
          />
        </div>
        <div>
          <label for="gender" class="text-xs font-medium text-muted block mb-1.5">Género</label>
          <select
            id="gender"
            name="gender"
            class="w-full px-3.5 py-2.5 bg-white border border-gray-200 rounded-xl text-sm text-navy focus:outline-none focus:border-coral/50 transition-colors"
          >
            <option value="" selected={!profile?.gender}>Seleccionar</option>
            <option value="masculino" selected={profile?.gender === 'masculino'}>Masculino</option>
            <option value="femenino" selected={profile?.gender === 'femenino'}>Femenino</option>
            <option value="otro" selected={profile?.gender === 'otro'}>Otro</option>
          </select>
        </div>
      </div>

      <div class="grid sm:grid-cols-2 gap-4">
        <div>
          <label for="experience_years" class="text-xs font-medium text-muted block mb-1.5"
            >Años jugando pádel</label
          >
          <input
            type="number"
            id="experience_years"
            name="experience_years"
            min="0"
            max="50"
            value={profile?.experience_years ?? 0}
            class="w-full px-3.5 py-2.5 bg-white border border-gray-200 rounded-xl text-sm text-navy focus:outline-none focus:border-coral/50 transition-colors"
          />
        </div>
        <div>
          <label for="racquet_sports" class="text-xs font-medium text-muted block mb-1.5"
            >Otros deportes de raqueta</label
          >
          <input
            type="text"
            id="racquet_sports"
            name="racquet_sports"
            value={profile?.racquet_sports ?? ''}
            placeholder="Tenis, Squash..."
            class="w-full px-3.5 py-2.5 bg-white border border-gray-200 rounded-xl text-sm text-navy placeholder:text-muted/50 focus:outline-none focus:border-coral/50 transition-colors"
          />
        </div>
      </div>

      <div>
        <label for="bio" class="text-xs font-medium text-muted block mb-1.5">Sobre ti</label>
        <textarea
          id="bio"
          name="bio"
          rows="3"
          placeholder="Cuéntanos sobre tu juego..."
          class="w-full px-3.5 py-2.5 bg-white border border-gray-200 rounded-xl text-sm text-navy placeholder:text-muted/50 focus:outline-none focus:border-coral/50 transition-colors resize-none"
          >{profile?.bio ?? ''}</textarea
        >
      </div>

      <button
        type="submit"
        class="px-6 py-2.5 bg-coral text-white text-sm font-semibold rounded-full hover:bg-coral-dark transition-colors"
      >
        Guardar cambios
      </button>
    </form>

    <div class="mt-10 card p-5">
      <div class="text-xs text-muted mb-2">Tu valoración actual</div>
      <div class="font-display text-4xl font-bold text-coral">
        {profile?.rating?.toFixed(1) ?? '1.0'}
      </div>
    </div>
  </div>
</AppLayout>
