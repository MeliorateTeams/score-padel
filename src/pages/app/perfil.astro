---
import AppLayout from '../../layouts/AppLayout.astro'
import { getProfile, updateProfile } from '../../lib/db'
import { calculateInitialRating } from '../../lib/rating'

const user = (Astro.locals as any).user
if (!user) return Astro.redirect('/login')
if (user.role === 'guest') return Astro.redirect('/app?error=guest')

const db = (Astro.locals as any).db
let message = ''

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData()
  const experienceYears = parseInt(form.get('experience_years')?.toString() ?? '0') || 0
  const racquetSports = form.get('racquet_sports')?.toString() ?? ''
  const birthDate = form.get('birth_date')?.toString() ?? ''
  const gender = form.get('gender')?.toString() ?? ''

  await updateProfile(db, user.id, {
    bio: form.get('bio')?.toString() ?? '',
    location: form.get('location')?.toString() ?? '',
    experience_years: experienceYears,
    racquet_sports: racquetSports,
    birth_date: birthDate,
    gender: gender,
  })

  // Si el jugador no tiene partidos, ajustar rating inicial según perfil
  const currentProfile = await getProfile(db, user.id)
  if (currentProfile && currentProfile.matches_played === 0) {
    const initialRating = calculateInitialRating(experienceYears, racquetSports)
    await db
      .prepare("UPDATE profiles SET rating = ?, updated_at = datetime('now') WHERE user_id = ?")
      .bind(initialRating, user.id)
      .run()
  }

  message = 'Perfil actualizado correctamente.'
}

const profile = await getProfile(db, user.id)

const ratingLevel = (r: number) => {
  if (r < 2.0) return { nombre: 'Iniciación Pádel', div: 'C' }
  if (r < 2.5) return { nombre: 'Consistencia Inicial', div: 'C' }
  if (r < 3.0) return { nombre: 'Precisión en Desarrollo', div: 'C' }
  if (r < 3.5) return { nombre: 'Confianza Intermedia', div: 'C' }
  if (r < 4.0) return { nombre: 'Control y Ritmo', div: 'B' }
  if (r < 4.5) return { nombre: 'Estrategas del Pádel', div: 'B' }
  if (r < 5.0) return { nombre: 'Jugadores Ingeniosos', div: 'B' }
  if (r < 5.5) return { nombre: 'Competidores de Torneo', div: 'B' }
  if (r < 6.0) return { nombre: 'Estrellas Nacionales', div: 'B' }
  if (r < 6.5) return { nombre: 'Semiprofesionales en Ascenso', div: 'A' }
  if (r < 7.0) return { nombre: 'Profesionales de Élite', div: 'A' }
  return { nombre: 'Élite Mundial del Pádel', div: 'A' }
}
---

<AppLayout title="Mi perfil" user={user}>
  <div class="max-w-3xl mx-auto space-y-8">

    {
      message && (
        <div class="bg-teal/10 border border-teal/20 text-teal text-xs p-3 rounded-xl">
          {message}
        </div>
      )
    }

    <!-- Hero card: identity + rating -->
    <div class="card p-0 overflow-hidden">
      <div class="bg-gradient-to-r from-coral to-coral-dark h-24 relative">
        <div class="absolute -bottom-10 left-8">
          <div class="w-20 h-20 rounded-2xl bg-white shadow-lg flex items-center justify-center border-4 border-white">
            <span class="font-display text-3xl font-bold text-coral">{user.name?.charAt(0)?.toUpperCase()}</span>
          </div>
        </div>
      </div>
      <div class="pt-14 pb-6 px-8 flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4">
        <div>
          <h1 class="font-display text-xl font-bold text-navy">{user.name}</h1>
          <p class="text-sm text-muted mt-0.5">{user.email}</p>
          {profile?.location && (
            <p class="text-xs text-muted/70 mt-1 flex items-center gap-1">
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/></svg>
              {profile.location}
            </p>
          )}
        </div>
        <div class="flex items-center gap-6">
          <div class="text-center">
            <div class="font-display text-3xl font-bold text-coral">{profile?.rating?.toFixed(1) ?? '1.0'}</div>
            <div class="text-[10px] font-semibold text-muted uppercase tracking-wider mt-0.5">{ratingLevel(profile?.rating ?? 1).nombre}</div>
          </div>
          <div class="hidden sm:block w-px h-12 bg-gray-200"></div>
          <div class="hidden sm:flex gap-5">
            <div class="text-center">
              <div class="font-display text-lg font-bold text-navy">{profile?.matches_played ?? 0}</div>
              <div class="text-[10px] text-muted uppercase tracking-wider">Partidos</div>
            </div>
            <div class="text-center">
              <div class="font-display text-lg font-bold text-navy">{profile?.matches_won ?? 0}</div>
              <div class="text-[10px] text-muted uppercase tracking-wider">Victorias</div>
            </div>
            <div class="text-center">
              <div class="font-display text-lg font-bold text-navy">{profile?.matches_played ? Math.round((profile.matches_won / profile.matches_played) * 100) : 0}%</div>
              <div class="text-[10px] text-muted uppercase tracking-wider">Win rate</div>
            </div>
          </div>
        </div>
      </div>
      <!-- Mobile stats -->
      <div class="sm:hidden flex border-t border-gray-100 divide-x divide-gray-100">
        <div class="flex-1 py-3 text-center">
          <div class="font-display text-lg font-bold text-navy">{profile?.matches_played ?? 0}</div>
          <div class="text-[10px] text-muted uppercase tracking-wider">Partidos</div>
        </div>
        <div class="flex-1 py-3 text-center">
          <div class="font-display text-lg font-bold text-navy">{profile?.matches_won ?? 0}</div>
          <div class="text-[10px] text-muted uppercase tracking-wider">Victorias</div>
        </div>
        <div class="flex-1 py-3 text-center">
          <div class="font-display text-lg font-bold text-navy">{profile?.matches_played ? Math.round((profile.matches_won / profile.matches_played) * 100) : 0}%</div>
          <div class="text-[10px] text-muted uppercase tracking-wider">Win rate</div>
        </div>
      </div>
    </div>

    <!-- Form: editable fields -->
    <form method="POST" class="space-y-6">
      <div class="card p-6 space-y-5">
        <h2 class="font-display text-sm font-bold text-navy uppercase tracking-wider flex items-center gap-2">
          <svg class="w-4 h-4 text-coral" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"/></svg>
          Información personal
        </h2>

        <div class="grid sm:grid-cols-2 gap-4">
          <div>
            <label class="text-xs font-medium text-muted block mb-1.5">Nombre</label>
            <input type="text" disabled value={user.name} class="w-full px-3.5 py-2.5 bg-gray-50 border border-gray-200 rounded-xl text-sm text-muted cursor-not-allowed" />
          </div>
          <div>
            <label class="text-xs font-medium text-muted block mb-1.5">Email</label>
            <input type="email" disabled value={user.email} class="w-full px-3.5 py-2.5 bg-gray-50 border border-gray-200 rounded-xl text-sm text-muted cursor-not-allowed" />
          </div>
        </div>

        <div>
          <label for="location" class="text-xs font-medium text-muted block mb-1.5">Ubicación (ciudad, país)</label>
          <input type="text" id="location" name="location" value={profile?.location ?? ''} placeholder="Madrid, España" class="w-full px-3.5 py-2.5 bg-white border border-gray-200 rounded-xl text-sm text-navy placeholder:text-muted/50 focus:outline-none focus:border-coral/50 transition-colors" />
        </div>

        <div class="grid sm:grid-cols-2 gap-4">
          <div>
            <label for="birth_date" class="text-xs font-medium text-muted block mb-1.5">Fecha de nacimiento</label>
            <input type="date" id="birth_date" name="birth_date" value={profile?.birth_date ?? ''} class="w-full px-3.5 py-2.5 bg-white border border-gray-200 rounded-xl text-sm text-navy focus:outline-none focus:border-coral/50 transition-colors" />
          </div>
          <div>
            <label for="gender" class="text-xs font-medium text-muted block mb-1.5">Género</label>
            <select id="gender" name="gender" class="w-full px-3.5 py-2.5 bg-white border border-gray-200 rounded-xl text-sm text-navy focus:outline-none focus:border-coral/50 transition-colors">
              <option value="" selected={!profile?.gender}>Seleccionar</option>
              <option value="masculino" selected={profile?.gender === 'masculino'}>Masculino</option>
              <option value="femenino" selected={profile?.gender === 'femenino'}>Femenino</option>
              <option value="otro" selected={profile?.gender === 'otro'}>Otro</option>
            </select>
          </div>
        </div>
      </div>

      <div class="card p-6 space-y-5">
        <h2 class="font-display text-sm font-bold text-navy uppercase tracking-wider flex items-center gap-2">
          <svg class="w-4 h-4 text-coral" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z"/></svg>
          Experiencia deportiva
        </h2>

        <div class="grid sm:grid-cols-2 gap-4">
          <div>
            <label for="experience_years" class="text-xs font-medium text-muted block mb-1.5">Años jugando pádel</label>
            <input type="number" id="experience_years" name="experience_years" min="0" max="50" value={profile?.experience_years ?? 0} class="w-full px-3.5 py-2.5 bg-white border border-gray-200 rounded-xl text-sm text-navy focus:outline-none focus:border-coral/50 transition-colors" />
          </div>
          <div>
            <label for="racquet_sports" class="text-xs font-medium text-muted block mb-1.5">Otros deportes de raqueta</label>
            <input type="text" id="racquet_sports" name="racquet_sports" value={profile?.racquet_sports ?? ''} placeholder="Tenis, Squash..." class="w-full px-3.5 py-2.5 bg-white border border-gray-200 rounded-xl text-sm text-navy placeholder:text-muted/50 focus:outline-none focus:border-coral/50 transition-colors" />
          </div>
        </div>

        <div>
          <label for="bio" class="text-xs font-medium text-muted block mb-1.5">Sobre ti</label>
          <textarea id="bio" name="bio" rows="3" placeholder="Cuéntanos sobre tu juego..." class="w-full px-3.5 py-2.5 bg-white border border-gray-200 rounded-xl text-sm text-navy placeholder:text-muted/50 focus:outline-none focus:border-coral/50 transition-colors resize-none">{profile?.bio ?? ''}</textarea>
        </div>
      </div>

      <div class="flex justify-end">
        <button type="submit" class="px-8 py-2.5 bg-coral text-white text-sm font-semibold rounded-full hover:bg-coral-dark transition-colors shadow-sm">
          Guardar cambios
        </button>
      </div>
    </form>

  </div>
</AppLayout>
