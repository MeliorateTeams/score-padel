---
import AppLayout from '../../layouts/AppLayout.astro'
import { getProfile, updateProfile } from '../../lib/db'

const user = (Astro.locals as any).user
if (!user) return Astro.redirect('/login')

const db = (Astro.locals as any).db
let message = ''

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData()
  await updateProfile(db, user.id, {
    bio: form.get('bio')?.toString() ?? '',
    location: form.get('location')?.toString() ?? '',
    experience_years: parseInt(form.get('experience_years')?.toString() ?? '0') || 0,
    racquet_sports: form.get('racquet_sports')?.toString() ?? '',
  })
  message = 'Perfil actualizado correctamente.'
}

const profile = await getProfile(db, user.id)
---

<AppLayout title="Mi perfil" user={user}>
  <div class="max-w-2xl">
    <h1 class="font-display text-2xl font-bold mb-1">Mi perfil</h1>
    <p class="text-sm text-muted mb-8">
      Completa tu perfil para obtener una valoración más precisa.
    </p>

    {
      message && (
        <div class="bg-emerald/10 border border-emerald/20 text-emerald text-xs p-3 rounded-lg mb-6">
          {message}
        </div>
      )
    }

    <form method="POST" class="space-y-5">
      <div class="grid sm:grid-cols-2 gap-4">
        <div>
          <label class="text-xs font-medium text-muted block mb-1.5">Nombre</label>
          <input
            type="text"
            disabled
            value={user.name}
            class="w-full px-3.5 py-2.5 bg-surface border border-white/5 rounded-lg text-sm text-muted"
          />
        </div>
        <div>
          <label class="text-xs font-medium text-muted block mb-1.5">Email</label>
          <input
            type="email"
            disabled
            value={user.email}
            class="w-full px-3.5 py-2.5 bg-surface border border-white/5 rounded-lg text-sm text-muted"
          />
        </div>
      </div>

      <div>
        <label for="location" class="text-xs font-medium text-muted block mb-1.5"
          >Ubicación (ciudad, país)</label
        >
        <input
          type="text"
          id="location"
          name="location"
          value={profile?.location ?? ''}
          placeholder="Madrid, España"
          class="w-full px-3.5 py-2.5 bg-surface border border-white/10 rounded-lg text-sm text-text placeholder:text-muted/50 focus:outline-none focus:border-emerald/50 transition-colors"
        />
      </div>

      <div class="grid sm:grid-cols-2 gap-4">
        <div>
          <label for="experience_years" class="text-xs font-medium text-muted block mb-1.5"
            >Años jugando pádel</label
          >
          <input
            type="number"
            id="experience_years"
            name="experience_years"
            min="0"
            max="50"
            value={profile?.experience_years ?? 0}
            class="w-full px-3.5 py-2.5 bg-surface border border-white/10 rounded-lg text-sm text-text focus:outline-none focus:border-emerald/50 transition-colors"
          />
        </div>
        <div>
          <label for="racquet_sports" class="text-xs font-medium text-muted block mb-1.5"
            >Otros deportes de raqueta</label
          >
          <input
            type="text"
            id="racquet_sports"
            name="racquet_sports"
            value={profile?.racquet_sports ?? ''}
            placeholder="Tenis, Squash..."
            class="w-full px-3.5 py-2.5 bg-surface border border-white/10 rounded-lg text-sm text-text placeholder:text-muted/50 focus:outline-none focus:border-emerald/50 transition-colors"
          />
        </div>
      </div>

      <div>
        <label for="bio" class="text-xs font-medium text-muted block mb-1.5">Sobre ti</label>
        <textarea
          id="bio"
          name="bio"
          rows="3"
          placeholder="Cuéntanos sobre tu juego..."
          class="w-full px-3.5 py-2.5 bg-surface border border-white/10 rounded-lg text-sm text-text placeholder:text-muted/50 focus:outline-none focus:border-emerald/50 transition-colors resize-none"
          >{profile?.bio ?? ''}</textarea
        >
      </div>

      <button
        type="submit"
        class="px-6 py-2.5 bg-emerald text-bg text-sm font-semibold rounded-lg hover:bg-emerald-glow transition-colors"
      >
        Guardar cambios
      </button>
    </form>

    <div class="mt-10 p-5 gradient-border rounded-xl bg-surface">
      <div class="text-xs text-muted mb-2">Tu valoración actual</div>
      <div class="font-display text-4xl font-bold text-emerald">
        {profile?.rating?.toFixed(1) ?? '1.0'}
      </div>
    </div>
  </div>
</AppLayout>
