---
import AppLayout from '../../layouts/AppLayout.astro'
import { getProfile, updateProfile } from '../../lib/db'
import { calculateInitialRating } from '../../lib/rating'
import { verifyPassword, hashPassword } from '../../lib/auth'

const user = (Astro.locals as any).user
if (!user) return Astro.redirect('/login')
if (user.role === 'guest') return Astro.redirect('/app?error=guest')

const db = (Astro.locals as any).db
let message = ''
let messageType = 'success'

// Sanitize text input: strip HTML tags, limit length
function sanitize(input: string, maxLen = 200): string {
  return input
    .replace(/<[^>]*>/g, '')
    .trim()
    .slice(0, maxLen)
}

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData()
  const action = form.get('action')?.toString()

  if (action === 'delete-account') {
    // RGPD Art. 17: Derecho de supresión — borrar todos los datos del usuario
    await db.prepare('DELETE FROM sessions WHERE user_id = ?').bind(user.id).run()
    await db.prepare('DELETE FROM notifications WHERE user_id = ?').bind(user.id).run()
    await db.prepare('DELETE FROM rating_history WHERE user_id = ?').bind(user.id).run()
    await db.prepare('DELETE FROM match_confirmations WHERE user_id = ?').bind(user.id).run()
    await db
      .prepare('DELETE FROM challenges WHERE challenger_id = ? OR challenged_id = ?')
      .bind(user.id, user.id)
      .run()
    await db.prepare('DELETE FROM tournament_players WHERE user_id = ?').bind(user.id).run()
    await db.prepare('DELETE FROM profiles WHERE user_id = ?').bind(user.id).run()
    await db.prepare('DELETE FROM users WHERE id = ?').bind(user.id).run()
    Astro.cookies.delete('session', { path: '/' })
    return Astro.redirect('/?deleted=1')
  }

  if (action === 'export-data') {
    // RGPD Art. 20: Derecho a la portabilidad — export personal data as JSON
    const profileData = await db
      .prepare('SELECT * FROM profiles WHERE user_id = ?')
      .bind(user.id)
      .first()
    const userData = await db
      .prepare('SELECT id, name, email, role, created_at FROM users WHERE id = ?')
      .bind(user.id)
      .first()
    const matches = await db
      .prepare(
        `
      SELECT m.* FROM matches m
      WHERE m.team1_player1 = ? OR m.team1_player2 = ? OR m.team2_player1 = ? OR m.team2_player2 = ?
    `,
      )
      .bind(user.id, user.id, user.id, user.id)
      .all()
    const ratings = await db
      .prepare('SELECT * FROM rating_history WHERE user_id = ? ORDER BY created_at DESC')
      .bind(user.id)
      .all()

    const exportData = {
      exportDate: new Date().toISOString(),
      user: userData,
      profile: profileData,
      matches: matches.results ?? [],
      ratingHistory: ratings.results ?? [],
    }

    return new Response(JSON.stringify(exportData, null, 2), {
      headers: {
        'Content-Type': 'application/json; charset=utf-8',
        'Content-Disposition': `attachment; filename="mis_datos_scorepadel.json"`,
      },
    })
  }

  if (action === 'change-password') {
    const currentPass = form.get('current_password')?.toString() ?? ''
    const newPass = form.get('new_password')?.toString() ?? ''
    const confirmPass = form.get('confirm_password')?.toString() ?? ''

    if (!currentPass || !newPass || !confirmPass) {
      message = 'Todos los campos de contraseña son obligatorios.'
      messageType = 'error'
    } else if (newPass.length < 8) {
      message = 'La nueva contraseña debe tener al menos 8 caracteres.'
      messageType = 'error'
    } else if (!/[A-Z]/.test(newPass) || !/[a-z]/.test(newPass) || !/[0-9]/.test(newPass)) {
      message = 'La contraseña debe incluir mayúsculas, minúsculas y números.'
      messageType = 'error'
    } else if (newPass !== confirmPass) {
      message = 'Las contraseñas no coinciden.'
      messageType = 'error'
    } else {
      const row = await db
        .prepare('SELECT password_hash FROM users WHERE id = ?')
        .bind(user.id)
        .first()
      const valid = row ? await verifyPassword(currentPass, (row as any).password_hash) : false
      if (!valid) {
        message = 'La contraseña actual es incorrecta.'
        messageType = 'error'
      } else {
        const newHash = await hashPassword(newPass)
        await db
          .prepare('UPDATE users SET password_hash = ? WHERE id = ?')
          .bind(newHash, user.id)
          .run()
        // Invalidar todas las sesiones excepto la actual
        const currentSession = Astro.cookies.get('session')?.value
        if (currentSession) {
          await db.prepare('DELETE FROM sessions WHERE user_id = ? AND id != ?').bind(user.id, currentSession).run()
        }
        message = 'Contraseña cambiada correctamente. Todas las demás sesiones han sido cerradas.'
      }
    }
  }

  // Profile update - solo se ejecuta si no es otra acción específica
  if (!action || action === 'update-profile') {
    const experienceYears = Math.max(
      0,
      Math.min(50, parseInt(form.get('experience_years')?.toString() ?? '0') || 0),
    )
    const racquetSports = sanitize(form.get('racquet_sports')?.toString() ?? '', 100)
    const birthDate = form.get('birth_date')?.toString() ?? ''
    const gender = form.get('gender')?.toString() ?? ''

    // Validate gender option
    const validGenders = ['', 'masculino', 'femenino', 'otro']
    const safeGender = validGenders.includes(gender) ? gender : ''

    // Validate birth_date format (YYYY-MM-DD)
    const safeBirthDate = /^\d{4}-\d{2}-\d{2}$/.test(birthDate) ? birthDate : ''

    await updateProfile(db, user.id, {
      bio: sanitize(form.get('bio')?.toString() ?? '', 500),
      location: sanitize(form.get('location')?.toString() ?? '', 100),
      experience_years: experienceYears,
      racquet_sports: racquetSports,
      birth_date: safeBirthDate,
      gender: safeGender,
    })

    // Si el jugador no tiene partidos, ajustar rating inicial según perfil
    const currentProfile = await getProfile(db, user.id)
    if (currentProfile && currentProfile.matches_played === 0) {
      const initialRating = calculateInitialRating(experienceYears, racquetSports)
      await db
        .prepare("UPDATE profiles SET rating = ?, updated_at = datetime('now') WHERE user_id = ?")
        .bind(initialRating, user.id)
        .run()
    }

    message = 'Perfil actualizado correctamente.'
  }
}

const profile = await getProfile(db, user.id)

// Stats queries
const recentMatches = await db
  .prepare(
    `
    SELECT m.team1_games, m.team2_games, m.team1_player1, m.set_scores, m.created_at,
           u1.name as team1_name, u2.name as team2_name
    FROM matches m
    LEFT JOIN users u1 ON m.team1_player1 = u1.id
    LEFT JOIN users u2 ON m.team2_player1 = u2.id
    WHERE m.team1_player1 = ? OR m.team1_player2 = ? OR m.team2_player1 = ? OR m.team2_player2 = ?
    ORDER BY m.created_at DESC LIMIT 10
  `,
  )
  .bind(user.id, user.id, user.id, user.id)
  .all()

const ratingHistory = await db
  .prepare(
    `
    SELECT old_rating, new_rating, created_at
    FROM rating_history
    WHERE user_id = ?
    ORDER BY created_at DESC LIMIT 15
  `,
  )
  .bind(user.id)
  .all()

// Calculate streaks and stats
const matchResults = (recentMatches.results || []).map((m: any) => {
  const isTeam1 = m.team1_player1 === user.id
  const won = isTeam1 ? m.team1_games > m.team2_games : m.team2_games > m.team1_games
  return { ...m, isTeam1, won }
})

let currentStreak = 0
let streakType = ''
for (const m of matchResults) {
  if (currentStreak === 0) {
    streakType = m.won ? 'W' : 'L'
    currentStreak = 1
  } else if ((m.won && streakType === 'W') || (!m.won && streakType === 'L')) currentStreak++
  else break
}

const totalGamesWon = matchResults.reduce(
  (s: number, m: any) => s + (m.isTeam1 ? m.team1_games : m.team2_games),
  0,
)
const totalGamesLost = matchResults.reduce(
  (s: number, m: any) => s + (m.isTeam1 ? m.team2_games : m.team1_games),
  0,
)

const ratingChange = ratingHistory.results?.length
  ? Number(ratingHistory.results[0].new_rating) -
    Number(ratingHistory.results[ratingHistory.results.length - 1].old_rating)
  : 0

const ratingLevel = (r: number) => {
  if (r < 2.0) return { nombre: 'Iniciación Pádel', div: 'C' }
  if (r < 2.5) return { nombre: 'Consistencia Inicial', div: 'C' }
  if (r < 3.0) return { nombre: 'Precisión en Desarrollo', div: 'C' }
  if (r < 3.5) return { nombre: 'Confianza Intermedia', div: 'C' }
  if (r < 4.0) return { nombre: 'Control y Ritmo', div: 'B' }
  if (r < 4.5) return { nombre: 'Estrategas del Pádel', div: 'B' }
  if (r < 5.0) return { nombre: 'Jugadores Ingeniosos', div: 'B' }
  if (r < 5.5) return { nombre: 'Competidores de Torneo', div: 'B' }
  if (r < 6.0) return { nombre: 'Estrellas Nacionales', div: 'B' }
  if (r < 6.5) return { nombre: 'Semiprofesionales en Ascenso', div: 'A' }
  if (r < 7.0) return { nombre: 'Profesionales de Élite', div: 'A' }
  return { nombre: 'Élite Mundial del Pádel', div: 'A' }
}
---

<AppLayout title="Mi perfil" user={user}>
  <div class="max-w-3xl mx-auto space-y-8">
    {
      message && (
        <div data-toast={messageType === 'error' ? 'error' : 'success'} class="hidden">
          {message}
        </div>
      )
    }

    <!-- Hero card: identity + rating -->
    <div class="card p-0 overflow-hidden">
      <div class="bg-gradient-to-r from-coral to-coral-dark h-24 relative">
        <div class="absolute -bottom-10 left-8">
          <div
            class="w-20 h-20 rounded-2xl bg-white shadow-lg flex items-center justify-center border-4 border-white"
          >
            <span class="font-display text-3xl font-bold text-coral"
              >{user.name?.charAt(0)?.toUpperCase()}</span
            >
          </div>
        </div>
      </div>
      <div class="pt-14 pb-6 px-8 flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4">
        <div>
          <h1 class="font-display text-xl font-bold text-navy">{user.name}</h1>
          <p class="text-sm text-muted mt-0.5">{user.email}</p>
          {
            profile?.location && (
              <p class="text-xs text-muted/70 mt-1 flex items-center gap-1">
                <svg
                  class="w-3.5 h-3.5"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <>
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"
                    />
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"
                    />
                  </>
                </svg>
                {profile.location}
              </p>
            )
          }
        </div>
        <div class="flex items-center gap-6">
          <div class="text-center">
            <div class="font-display text-3xl font-bold text-coral">
              {profile?.rating?.toFixed(1) ?? '1.0'}
            </div>
            <div class="text-[10px] font-semibold text-muted uppercase tracking-wider mt-0.5">
              {ratingLevel(profile?.rating ?? 1).nombre}
            </div>
          </div>
          <div class="hidden sm:block w-px h-12 bg-gray-200"></div>
          <div class="hidden sm:flex gap-5">
            <div class="text-center">
              <div class="font-display text-lg font-bold text-navy">
                {profile?.matches_played ?? 0}
              </div>
              <div class="text-[10px] text-muted uppercase tracking-wider">Partidos</div>
            </div>
            <div class="text-center">
              <div class="font-display text-lg font-bold text-navy">
                {profile?.matches_won ?? 0}
              </div>
              <div class="text-[10px] text-muted uppercase tracking-wider">Victorias</div>
            </div>
            <div class="text-center">
              <div class="font-display text-lg font-bold text-navy">
                {
                  profile?.matches_played
                    ? Math.round((profile.matches_won / profile.matches_played) * 100)
                    : 0
                }%
              </div>
              <div class="text-[10px] text-muted uppercase tracking-wider">Win rate</div>
            </div>
          </div>
        </div>
      </div>
      <!-- Mobile stats -->
      <div class="sm:hidden flex border-t border-gray-100 divide-x divide-gray-100">
        <div class="flex-1 py-3 text-center">
          <div class="font-display text-lg font-bold text-navy">{profile?.matches_played ?? 0}</div>
          <div class="text-[10px] text-muted uppercase tracking-wider">Partidos</div>
        </div>
        <div class="flex-1 py-3 text-center">
          <div class="font-display text-lg font-bold text-navy">{profile?.matches_won ?? 0}</div>
          <div class="text-[10px] text-muted uppercase tracking-wider">Victorias</div>
        </div>
        <div class="flex-1 py-3 text-center">
          <div class="font-display text-lg font-bold text-navy">
            {
              profile?.matches_played
                ? Math.round((profile.matches_won / profile.matches_played) * 100)
                : 0
            }%
          </div>
          <div class="text-[10px] text-muted uppercase tracking-wider">Win rate</div>
        </div>
      </div>
    </div>

    <!-- Stats section -->
    <div class="grid sm:grid-cols-2 gap-4">
      <div class="card p-5">
        <h2
          class="font-display text-sm font-bold text-navy uppercase tracking-wider flex items-center gap-2 mb-4"
        >
          <svg
            class="w-4 h-4 text-coral"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
            ><path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z"
            ></path></svg
          >
          Estadísticas
        </h2>
        <div class="space-y-3">
          <div class="flex items-center justify-between">
            <span class="text-xs text-muted">Racha actual</span>
            <span
              class:list={[
                'text-sm font-display font-bold',
                streakType === 'W'
                  ? 'text-teal'
                  : currentStreak > 0
                    ? 'text-red-500'
                    : 'text-muted',
              ]}
            >
              {
                currentStreak > 0
                  ? `${currentStreak} ${streakType === 'W' ? 'victorias' : 'derrotas'}`
                  : '—'
              }
            </span>
          </div>
          <div class="flex items-center justify-between">
            <span class="text-xs text-muted">Juegos ganados / perdidos</span>
            <span class="text-sm font-display font-bold text-navy"
              >{totalGamesWon} / {totalGamesLost}</span
            >
          </div>
          <div class="flex items-center justify-between">
            <span class="text-xs text-muted">Ratio de juegos</span>
            <span class="text-sm font-display font-bold text-navy">
              {
                totalGamesLost > 0
                  ? (totalGamesWon / totalGamesLost).toFixed(2)
                  : totalGamesWon > 0
                    ? '∞'
                    : '—'
              }
            </span>
          </div>
          <div class="flex items-center justify-between">
            <span class="text-xs text-muted">Evolución rating</span>
            <span
              class:list={[
                'text-sm font-display font-bold',
                ratingChange > 0 ? 'text-teal' : ratingChange < 0 ? 'text-red-500' : 'text-muted',
              ]}
            >
              {ratingChange > 0 ? '+' : ''}{ratingChange.toFixed(1)}
            </span>
          </div>
        </div>
      </div>

      <div class="card p-5">
        <h2
          class="font-display text-sm font-bold text-navy uppercase tracking-wider flex items-center gap-2 mb-4"
        >
          <svg
            class="w-4 h-4 text-coral"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
            ><path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg
          >
          Últimos partidos
        </h2>
        {
          matchResults.length === 0 ? (
            <p class="text-xs text-muted text-center py-4">Sin partidos registrados.</p>
          ) : (
            <div class="space-y-2">
              {matchResults.slice(0, 5).map((m: any) => {
                const setScores = m.set_scores ? JSON.parse(m.set_scores) : []
                return (
                  <div class="flex items-center justify-between p-2.5 rounded-xl bg-gray-50 border border-gray-100">
                    <div class="flex items-center gap-2">
                      <span
                        class:list={[
                          'text-[10px] font-semibold px-1.5 py-0.5 rounded-full uppercase',
                          m.won ? 'bg-teal/10 text-teal' : 'bg-red-500/10 text-red-500',
                        ]}
                      >
                        {m.won ? 'V' : 'D'}
                      </span>
                      <div>
                        <div class="text-xs text-navy">
                          {m.team1_name} <span class="text-muted">vs</span> {m.team2_name}
                        </div>
                        {setScores.length > 0 && (
                          <div class="text-[10px] text-muted mt-0.5">
                            {setScores.map((s: any) => `${s.team1}-${s.team2}`).join(' · ')}
                          </div>
                        )}
                      </div>
                    </div>
                    <span class="text-[11px] text-muted">
                      {new Date(m.created_at).toLocaleDateString('es-ES', {
                        day: 'numeric',
                        month: 'short',
                      })}
                    </span>
                  </div>
                )
              })}
            </div>
          )
        }
      </div>
    </div>

    <!-- Form: editable fields -->
    <form method="POST" class="space-y-6">
      <div class="card p-6 space-y-5">
        <h2
          class="font-display text-sm font-bold text-navy uppercase tracking-wider flex items-center gap-2"
        >
          <svg
            class="w-4 h-4 text-coral"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
            ><path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"
            ></path></svg
          >
          Información personal
        </h2>

        <div class="grid sm:grid-cols-2 gap-4">
          <div>
            <label class="text-xs font-medium text-muted block mb-1.5">Nombre</label>
            <input
              type="text"
              disabled
              value={user.name}
              class="w-full px-3.5 py-2.5 bg-gray-50 border border-gray-200 rounded-xl text-sm text-muted cursor-not-allowed"
            />
          </div>
          <div>
            <label class="text-xs font-medium text-muted block mb-1.5">Email</label>
            <input
              type="email"
              disabled
              value={user.email}
              class="w-full px-3.5 py-2.5 bg-gray-50 border border-gray-200 rounded-xl text-sm text-muted cursor-not-allowed"
            />
          </div>
        </div>

        <div>
          <label for="location" class="text-xs font-medium text-muted block mb-1.5"
            >Ubicación (ciudad, país)</label
          >
          <input
            type="text"
            id="location"
            name="location"
            value={profile?.location ?? ''}
            placeholder="Madrid, España"
            class="w-full px-3.5 py-2.5 bg-white border border-gray-200 rounded-xl text-sm text-navy placeholder:text-muted/50 focus:outline-none focus:border-coral/50 transition-colors"
          />
        </div>

        <div class="grid sm:grid-cols-2 gap-4">
          <div>
            <label for="birth_date" class="text-xs font-medium text-muted block mb-1.5"
              >Fecha de nacimiento</label
            >
            <input
              type="date"
              id="birth_date"
              name="birth_date"
              value={profile?.birth_date ?? ''}
              class="w-full px-3.5 py-2.5 bg-white border border-gray-200 rounded-xl text-sm text-navy focus:outline-none focus:border-coral/50 transition-colors"
            />
          </div>
          <div>
            <label for="gender" class="text-xs font-medium text-muted block mb-1.5">Género</label>
            <select
              id="gender"
              name="gender"
              class="w-full px-3.5 py-2.5 bg-white border border-gray-200 rounded-xl text-sm text-navy focus:outline-none focus:border-coral/50 transition-colors"
            >
              <option value="" selected={!profile?.gender}>Seleccionar</option>
              <option value="masculino" selected={profile?.gender === 'masculino'}>Masculino</option
              >
              <option value="femenino" selected={profile?.gender === 'femenino'}>Femenino</option>
              <option value="otro" selected={profile?.gender === 'otro'}>Otro</option>
            </select>
          </div>
        </div>
      </div>

      <div class="card p-6 space-y-5">
        <h2
          class="font-display text-sm font-bold text-navy uppercase tracking-wider flex items-center gap-2"
        >
          <svg
            class="w-4 h-4 text-coral"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
            ><path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z"
            ></path></svg
          >
          Experiencia deportiva
        </h2>

        <div class="grid sm:grid-cols-2 gap-4">
          <div>
            <label for="experience_years" class="text-xs font-medium text-muted block mb-1.5"
              >Años jugando pádel</label
            >
            <input
              type="number"
              id="experience_years"
              name="experience_years"
              min="0"
              max="50"
              value={profile?.experience_years ?? 0}
              class="w-full px-3.5 py-2.5 bg-white border border-gray-200 rounded-xl text-sm text-navy focus:outline-none focus:border-coral/50 transition-colors"
            />
          </div>
          <div>
            <label for="racquet_sports" class="text-xs font-medium text-muted block mb-1.5"
              >Otros deportes de raqueta</label
            >
            <input
              type="text"
              id="racquet_sports"
              name="racquet_sports"
              value={profile?.racquet_sports ?? ''}
              placeholder="Tenis, Squash..."
              class="w-full px-3.5 py-2.5 bg-white border border-gray-200 rounded-xl text-sm text-navy placeholder:text-muted/50 focus:outline-none focus:border-coral/50 transition-colors"
            />
          </div>
        </div>

        <div>
          <label for="bio" class="text-xs font-medium text-muted block mb-1.5">Sobre ti</label>
          <textarea
            id="bio"
            name="bio"
            rows="3"
            placeholder="Cuéntanos sobre tu juego..."
            class="w-full px-3.5 py-2.5 bg-white border border-gray-200 rounded-xl text-sm text-navy placeholder:text-muted/50 focus:outline-none focus:border-coral/50 transition-colors resize-none"
            >{profile?.bio ?? ''}</textarea
          >
        </div>
      </div>

      <div class="flex justify-end">
        <button
          type="submit"
          class="px-8 py-2.5 bg-coral text-white text-sm font-semibold rounded-full hover:bg-coral-dark transition-colors shadow-sm"
        >
          Guardar cambios
        </button>
      </div>
    </form>

    <!-- Cambiar contraseña -->
    <div class="card p-6 space-y-5">
      <h2
        class="font-display text-sm font-bold text-navy uppercase tracking-wider flex items-center gap-2"
      >
        <svg
          class="w-4 h-4 text-coral"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z"
          ></path>
        </svg>
        Cambiar contraseña
      </h2>
      <form method="POST" class="space-y-4">
        <input type="hidden" name="action" value="change-password" />
        <div>
          <label for="current_password" class="text-xs font-medium text-muted block mb-1.5"
            >Contraseña actual</label
          >
          <input
            type="password"
            id="current_password"
            name="current_password"
            required
            autocomplete="current-password"
            class="w-full px-3.5 py-2.5 bg-white border border-gray-200 rounded-xl text-sm text-navy focus:outline-none focus:border-coral/50 transition-colors"
          />
        </div>
        <div class="grid sm:grid-cols-2 gap-4">
          <div>
            <label for="new_password" class="text-xs font-medium text-muted block mb-1.5"
              >Nueva contraseña</label
            >
            <input
              type="password"
              id="new_password"
              name="new_password"
              required
              minlength="8"
              autocomplete="new-password"
              class="w-full px-3.5 py-2.5 bg-white border border-gray-200 rounded-xl text-sm text-navy focus:outline-none focus:border-coral/50 transition-colors"
            />
            <p class="text-[10px] text-muted/60 mt-1">
              Mín. 8 caracteres, mayúsculas, minúsculas y números
            </p>
          </div>
          <div>
            <label for="confirm_password" class="text-xs font-medium text-muted block mb-1.5"
              >Confirmar contraseña</label
            >
            <input
              type="password"
              id="confirm_password"
              name="confirm_password"
              required
              minlength="8"
              autocomplete="new-password"
              class="w-full px-3.5 py-2.5 bg-white border border-gray-200 rounded-xl text-sm text-navy focus:outline-none focus:border-coral/50 transition-colors"
            />
          </div>
        </div>
        <div class="flex justify-end">
          <button
            type="submit"
            class="px-6 py-2 bg-navy text-white text-xs font-semibold rounded-full hover:bg-navy/90 transition-colors"
          >
            Cambiar contraseña
          </button>
        </div>
      </form>
    </div>

    <!-- RGPD: Privacidad y datos personales -->
    <div class="card p-6 space-y-5 border-red-200">
      <h2
        class="font-display text-sm font-bold text-navy uppercase tracking-wider flex items-center gap-2"
      >
        <svg
          class="w-4 h-4 text-coral"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"
          ></path>
        </svg>
        Privacidad y datos personales
      </h2>
      <p class="text-xs text-muted">
        Conforme al RGPD, tienes derecho a exportar y eliminar tus datos personales.
      </p>

      <div class="flex flex-wrap gap-3">
        <form method="POST">
          <input type="hidden" name="action" value="export-data" />
          <button
            type="submit"
            class="px-5 py-2 bg-teal/10 text-teal text-xs font-semibold rounded-full hover:bg-teal/20 transition-colors flex items-center gap-2"
          >
            <svg
              class="w-3.5 h-3.5"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3"
              ></path>
            </svg>
            Descargar mis datos (JSON)
          </button>
        </form>
        <form
          method="POST"
          onsubmit="return confirm('⚠️ ¿Estás seguro? Se eliminarán TODOS tus datos permanentemente. Esta acción no se puede deshacer.')"
        >
          <input type="hidden" name="action" value="delete-account" />
          <button
            type="submit"
            class="px-5 py-2 bg-red-50 text-red-600 text-xs font-semibold rounded-full hover:bg-red-100 transition-colors border border-red-200 flex items-center gap-2"
          >
            <svg
              class="w-3.5 h-3.5"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0"
              ></path>
            </svg>
            Eliminar mi cuenta
          </button>
        </form>
      </div>
    </div>
  </div>
</AppLayout>
