---
import AppLayout from '../../layouts/AppLayout.astro'

const user = (Astro.locals as any).user
if (!user) return Astro.redirect('/login')

const db = (Astro.locals as any).db

const genderFilter = Astro.url.searchParams.get('gender') ?? ''
const divisionFilter = Astro.url.searchParams.get('division') ?? ''
const ageFilter = Astro.url.searchParams.get('age') ?? ''

let leaderboardQuery = `
  SELECT u.id, u.name, p.rating, p.location, p.matches_played, p.matches_won, p.birth_date
  FROM users u
  LEFT JOIN profiles p ON u.id = p.user_id
  WHERE 1=1
`
const lbParams: any[] = []

if (genderFilter) {
  leaderboardQuery += ' AND p.gender = ?'
  lbParams.push(genderFilter)
}
if (divisionFilter === 'C') {
  leaderboardQuery += ' AND p.rating < 3.5'
} else if (divisionFilter === 'B') {
  leaderboardQuery += ' AND p.rating >= 3.5 AND p.rating < 6.0'
} else if (divisionFilter === 'A') {
  leaderboardQuery += ' AND p.rating >= 6.0'
}
// Age filtering: calculate based on birth_date
if (ageFilter === 'sub18') {
  leaderboardQuery +=
    " AND p.birth_date != '' AND p.birth_date IS NOT NULL AND (strftime('%Y', 'now') - strftime('%Y', p.birth_date)) < 18"
} else if (ageFilter === '18-35') {
  leaderboardQuery +=
    " AND p.birth_date != '' AND p.birth_date IS NOT NULL AND (strftime('%Y', 'now') - strftime('%Y', p.birth_date)) BETWEEN 18 AND 35"
} else if (ageFilter === '36-50') {
  leaderboardQuery +=
    " AND p.birth_date != '' AND p.birth_date IS NOT NULL AND (strftime('%Y', 'now') - strftime('%Y', p.birth_date)) BETWEEN 36 AND 50"
} else if (ageFilter === '50plus') {
  leaderboardQuery +=
    " AND p.birth_date != '' AND p.birth_date IS NOT NULL AND (strftime('%Y', 'now') - strftime('%Y', p.birth_date)) > 50"
}

leaderboardQuery += ' ORDER BY p.rating DESC LIMIT 100'

const leaderboard =
  lbParams.length > 0
    ? await db
        .prepare(leaderboardQuery)
        .bind(...lbParams)
        .all()
    : await db.prepare(leaderboardQuery).all()

function getLevel(rating: number) {
  if (rating < 2.0) return { name: 'Iniciación Pádel', division: 'C', color: 'text-blue-400' }
  if (rating < 2.5) return { name: 'Consistencia Inicial', division: 'C', color: 'text-blue-400' }
  if (rating < 3.0)
    return { name: 'Precisión en Desarrollo', division: 'C', color: 'text-blue-400' }
  if (rating < 3.5) return { name: 'Confianza Intermedia', division: 'C', color: 'text-blue-400' }
  if (rating < 4.0) return { name: 'Control y Ritmo', division: 'B', color: 'text-teal' }
  if (rating < 4.5) return { name: 'Estrategas del Pádel', division: 'B', color: 'text-teal' }
  if (rating < 5.0) return { name: 'Jugadores Ingeniosos', division: 'B', color: 'text-teal' }
  if (rating < 5.5) return { name: 'Competidores de Torneo', division: 'B', color: 'text-teal' }
  if (rating < 6.0) return { name: 'Estrellas Nacionales', division: 'B', color: 'text-teal' }
  if (rating < 6.5)
    return { name: 'Semiprofesionales en Ascenso', division: 'A', color: 'text-amber' }
  if (rating < 7.0) return { name: 'Profesionales de Élite', division: 'A', color: 'text-amber' }
  return { name: 'Élite Mundial del Pádel', division: 'A', color: 'text-amber' }
}
---

<AppLayout title="Valoraciones" user={user}>
  <div>
    <h1 class="font-display text-2xl font-bold mb-1">Valoraciones globales</h1>
    <p class="text-sm text-muted mb-4">Valoración numérica de jugadores según su nivel de juego.</p>

    <form method="GET" class="flex flex-wrap gap-3 mb-6">
      <select
        name="division"
        class="px-3.5 py-2 bg-white border border-gray-200 rounded-xl text-sm text-navy focus:outline-none focus:border-coral/50 transition-colors"
      >
        <option value="">Todas las divisiones</option>
        <option value="C" selected={divisionFilter === 'C'}>División C (1.0-3.0)</option>
        <option value="B" selected={divisionFilter === 'B'}>División B (3.5-5.5)</option>
        <option value="A" selected={divisionFilter === 'A'}>División A (6.0-7.0)</option>
      </select>
      <select
        name="gender"
        class="px-3.5 py-2 bg-white border border-gray-200 rounded-xl text-sm text-navy focus:outline-none focus:border-coral/50 transition-colors"
      >
        <option value="">Todos los géneros</option>
        <option value="masculino" selected={genderFilter === 'masculino'}>Masculino</option>
        <option value="femenino" selected={genderFilter === 'femenino'}>Femenino</option>
      </select>
      <select
        name="age"
        class="px-3.5 py-2 bg-white border border-gray-200 rounded-xl text-sm text-navy focus:outline-none focus:border-coral/50 transition-colors"
      >
        <option value="">Todas las edades</option>
        <option value="sub18" selected={ageFilter === 'sub18'}>Sub-18</option>
        <option value="18-35" selected={ageFilter === '18-35'}>18-35 años</option>
        <option value="36-50" selected={ageFilter === '36-50'}>36-50 años</option>
        <option value="50plus" selected={ageFilter === '50plus'}>+50 años</option>
      </select>
      <button
        type="submit"
        class="px-5 py-2 bg-coral text-white text-sm font-semibold rounded-full hover:bg-coral-dark transition-colors"
      >
        Filtrar
      </button>
      <a
        href="/api/export?type=clasificacion"
        class="px-4 py-2 border border-gray-200 text-sm text-muted rounded-full hover:text-coral hover:border-coral/30 transition-colors flex items-center gap-1.5"
      >
        <svg
          class="w-3.5 h-3.5"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
          ><path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3"
          ></path></svg
        >
        CSV
      </a>
    </form>

    <div class="card rounded-2xl overflow-hidden">
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-gray-100 text-muted text-left">
              <th class="px-5 py-3 font-medium">Jugador</th>
              <th class="px-5 py-3 font-medium">Nivel</th>
              <th class="px-5 py-3 font-medium text-center">Partidos</th>
              <th class="px-5 py-3 font-medium text-center">Victorias</th>
              <th class="px-5 py-3 font-medium text-right">Valoración</th>
            </tr>
          </thead>
          <tbody>
            {
              leaderboard.results?.map((p: any) => {
                const level = getLevel(Number(p.rating || 1))
                const isMe = p.id === user.id
                return (
                  <tr
                    class={`border-b border-gray-100 hover:bg-gray-50 transition-colors ${isMe ? 'bg-coral/5' : ''}`}
                  >
                    <td class="px-5 py-3.5">
                      <a
                        href={`/app/jugadores/${p.id}`}
                        class={`font-medium hover:underline ${isMe ? 'text-coral' : 'text-navy'}`}
                      >
                        {p.name}
                      </a>
                      {p.location && <span class="ml-2 text-xs text-muted">· {p.location}</span>}
                      {isMe && (
                        <span class="ml-2 text-[10px] bg-coral/10 text-coral px-1.5 py-0.5 rounded-full">
                          Tú
                        </span>
                      )}
                    </td>
                    <td class="px-5 py-3.5">
                      <span class={`text-xs font-semibold ${level.color}`}>{level.name}</span>
                      <span class="block text-[10px] text-muted">{level.division}</span>
                    </td>
                    <td class="px-5 py-3.5 text-center text-muted">{p.matches_played ?? 0}</td>
                    <td class="px-5 py-3.5 text-center text-muted">{p.matches_won ?? 0}</td>
                    <td class="px-5 py-3.5 text-right">
                      <span class="font-display font-bold text-coral">
                        {Number(p.rating || 1).toFixed(1)}
                      </span>
                    </td>
                  </tr>
                )
              })
            }
          </tbody>
        </table>
        {
          (leaderboard.results?.length ?? 0) === 0 && (
            <div class="p-10 text-center text-muted">Aún no hay jugadores registrados.</div>
          )
        }
      </div>
    </div>
  </div>
</AppLayout>
