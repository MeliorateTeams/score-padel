---
import AppLayout from '../../layouts/AppLayout.astro'

const user = (Astro.locals as any).user
if (!user) return Astro.redirect('/login')

const db = (Astro.locals as any).db

const leaderboard = await db
  .prepare(
    `
  SELECT u.id, u.name, p.rating, p.location, p.matches_played, p.matches_won
  FROM users u
  LEFT JOIN profiles p ON u.id = p.user_id
  ORDER BY p.rating DESC
  LIMIT 100
`,
  )
  .all()

function getLevel(rating: number) {
  if (rating < 1.5) return { name: 'Iniciación', division: 'Formativa', color: 'text-blue-400' }
  if (rating < 2.0) return { name: 'Iniciación +', division: 'Formativa', color: 'text-blue-400' }
  if (rating < 2.5) return { name: 'Intermedio', division: 'Formativa', color: 'text-blue-400' }
  if (rating < 3.0)
    return { name: 'Intermedio Avanzado', division: 'Competitiva', color: 'text-teal' }
  if (rating < 3.5) return { name: 'Avanzado', division: 'Competitiva', color: 'text-teal' }
  if (rating < 4.0) return { name: 'Avanzado +', division: 'Competitiva', color: 'text-teal' }
  if (rating < 4.5) return { name: 'Competición', division: 'Competitiva', color: 'text-teal' }
  if (rating < 5.0) return { name: 'Pre-Profesional', division: 'Élite', color: 'text-amber' }
  if (rating < 5.5) return { name: 'Profesional', division: 'Élite', color: 'text-amber' }
  if (rating < 6.0) return { name: 'Profesional +', division: 'Élite', color: 'text-amber' }
  if (rating < 6.5) return { name: 'Élite', division: 'Élite', color: 'text-amber' }
  return { name: 'World Class', division: 'Élite', color: 'text-amber' }
}
---

<AppLayout title="Clasificación" user={user}>
  <div>
    <h1 class="font-display text-2xl font-bold mb-1">Clasificación global</h1>
    <p class="text-sm text-muted mb-8">Ranking de jugadores por valoración.</p>

    <div class="card rounded-2xl overflow-hidden">
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-gray-100 text-muted text-left">
              <th class="px-5 py-3 font-medium w-12">#</th>
              <th class="px-5 py-3 font-medium">Jugador</th>
              <th class="px-5 py-3 font-medium">Nivel</th>
              <th class="px-5 py-3 font-medium text-center">Partidos</th>
              <th class="px-5 py-3 font-medium text-center">Victorias</th>
              <th class="px-5 py-3 font-medium text-right">Valoración</th>
            </tr>
          </thead>
          <tbody>
            {
              leaderboard.results?.map((p: any, i: number) => {
                const level = getLevel(Number(p.rating || 1))
                const isMe = p.id === user.id
                return (
                  <tr
                    class={`border-b border-gray-100 hover:bg-gray-50 transition-colors ${isMe ? 'bg-coral/5' : ''}`}
                  >
                    <td class="px-5 py-3.5 font-display font-bold text-muted">
                      {i < 3 ? ['🥇', '🥈', '🥉'][i] : i + 1}
                    </td>
                    <td class="px-5 py-3.5">
                      <span class={`font-medium ${isMe ? 'text-coral' : 'text-navy'}`}>
                        {p.name}
                      </span>
                      {p.location && <span class="ml-2 text-xs text-muted">· {p.location}</span>}
                      {isMe && (
                        <span class="ml-2 text-[10px] bg-coral/10 text-coral px-1.5 py-0.5 rounded-full">
                          Tú
                        </span>
                      )}
                    </td>
                    <td class="px-5 py-3.5">
                      <span class={`text-xs font-semibold ${level.color}`}>{level.name}</span>
                      <span class="block text-[10px] text-muted">{level.division}</span>
                    </td>
                    <td class="px-5 py-3.5 text-center text-muted">{p.matches_played ?? 0}</td>
                    <td class="px-5 py-3.5 text-center text-muted">{p.matches_won ?? 0}</td>
                    <td class="px-5 py-3.5 text-right">
                      <span class="font-display font-bold text-coral">
                        {Number(p.rating || 1).toFixed(1)}
                      </span>
                    </td>
                  </tr>
                )
              })
            }
          </tbody>
        </table>
        {
          (leaderboard.results?.length ?? 0) === 0 && (
            <div class="p-10 text-center text-muted">Aún no hay jugadores registrados.</div>
          )
        }
      </div>
    </div>
  </div>
</AppLayout>
