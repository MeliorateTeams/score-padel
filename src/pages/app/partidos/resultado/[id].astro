---
import AppLayout from '../../../../layouts/AppLayout.astro'
import { calculateAndUpdateRatings } from '../../../../lib/rating'

const user = (Astro.locals as any).user
if (!user) return Astro.redirect('/login')

const db = (Astro.locals as any).db
const matchId = Astro.params.id as string

const match = (await db
  .prepare(
    `SELECT m.*,
    u1.name as t1p1_name, u1.email as t1p1_email,
    u2.name as t1p2_name, u2.email as t1p2_email,
    u3.name as t2p1_name, u3.email as t2p1_email,
    u4.name as t2p2_name, u4.email as t2p2_email
   FROM matches m
   LEFT JOIN users u1 ON m.team1_player1 = u1.id
   LEFT JOIN users u2 ON m.team1_player2 = u2.id
   LEFT JOIN users u3 ON m.team2_player1 = u3.id
   LEFT JOIN users u4 ON m.team2_player2 = u4.id
   WHERE m.id = ?`,
  )
  .bind(matchId)
  .first()) as any

if (!match) return Astro.redirect('/app/partidos')

// Only players of this match can register result
const playerIds = [
  match.team1_player1,
  match.team1_player2,
  match.team2_player1,
  match.team2_player2,
]
if (!playerIds.includes(user.id) && user.role !== 'admin') return Astro.redirect('/app/partidos')

// Determine if user can edit an already-completed match (admin or recorder within 24h)
const isRecorder = match.recorded_by === user.id
const isRecent =
  match.created_at && Date.now() - new Date(match.created_at as string).getTime() < 86400000
const canEdit = user.role === 'admin' || (isRecorder && isRecent)

// Already completed - only redirect if user has no edit permission
if (match.status === 'completed' && !canEdit) return Astro.redirect('/app/partidos')

// Parse existing set scores for pre-filling the edit form
let existingSetScores: { team1: number; team2: number }[] = []
if (match.status === 'completed' && match.set_scores) {
  try {
    const parsed = JSON.parse(match.set_scores as string)
    if (Array.isArray(parsed)) existingSetScores = parsed
  } catch {
    /* ignore */
  }
}

let message = ''
let error = ''

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData()
  const sets: { team1: number; team2: number }[] = []
  for (let i = 1; i <= 5; i++) {
    const s1 = form.get(`set${i}_team1`)?.toString()
    const s2 = form.get(`set${i}_team2`)?.toString()
    if (s1 !== undefined && s2 !== undefined && s1 !== '' && s2 !== '') {
      sets.push({
        team1: Math.min(7, Math.max(0, parseInt(s1) || 0)),
        team2: Math.min(7, Math.max(0, parseInt(s2) || 0)),
      })
    }
  }

  const team1_games = sets.reduce((s, x) => s + x.team1, 0)
  const team2_games = sets.reduce((s, x) => s + x.team2, 0)

  if (sets.length === 0) {
    error = 'Introduce al menos un set.'
  } else if (team1_games === 0 && team2_games === 0) {
    error = 'Registra al menos un juego.'
  } else {
    const isEditing = match.status === 'completed'

    // If re-editing a completed match: reverse old stats and rating history
    if (isEditing) {
      const allMatchPlayers = [
        match.team1_player1,
        match.team1_player2,
        match.team2_player1,
        match.team2_player2,
      ].filter(Boolean) as string[]
      const oldWasTeam1Win = (match.team1_games as number) > (match.team2_games as number)
      const oldWinners = (
        oldWasTeam1Win
          ? [match.team1_player1, match.team1_player2]
          : [match.team2_player1, match.team2_player2]
      ).filter(Boolean) as string[]
      for (const pid of allMatchPlayers) {
        const wasWinner = oldWinners.includes(pid)
        await db
          .prepare(
            `UPDATE profiles SET matches_played = MAX(0, matches_played - 1), matches_won = MAX(0, matches_won - ?) WHERE user_id = ?`,
          )
          .bind(wasWinner ? 1 : 0, pid)
          .run()
      }
      await db.prepare('DELETE FROM rating_history WHERE match_id = ?').bind(matchId).run()
    }

    await db
      .prepare(
        'UPDATE matches SET status=?, team1_games=?, team2_games=?, set_scores=?, recorded_by=? WHERE id=?',
      )
      .bind('completed', team1_games, team2_games, JSON.stringify(sets), user.id, matchId)
      .run()

    // Create match confirmations (only on first registration)
    if (!isEditing) {
      for (const pid of playerIds.filter(Boolean)) {
        const existing = await db
          .prepare('SELECT 1 FROM match_confirmations WHERE match_id=? AND user_id=?')
          .bind(matchId, pid)
          .first()
        if (!existing) {
          await db
            .prepare(
              'INSERT INTO match_confirmations (match_id, user_id, confirmed) VALUES (?, ?, ?)',
            )
            .bind(matchId, pid, pid === user.id ? 1 : 0)
            .run()
        }
      }
    }

    // Update ratings
    const team1 = [match.team1_player1, match.team1_player2].filter(Boolean)
    const team2 = [match.team2_player1, match.team2_player2].filter(Boolean)
    await calculateAndUpdateRatings(db, matchId, team1, team2, team1_games, team2_games)

    // Notify other players
    const setsStr = sets.map((s) => `${s.team1}-${s.team2}`).join(', ')
    for (const pid of playerIds.filter((p) => p && p !== user.id)) {
      await db
        .prepare(
          'INSERT INTO notifications (id, user_id, type, message, link) VALUES (?, ?, ?, ?, ?)',
        )
        .bind(
          crypto.randomUUID(),
          pid,
          'match',
          isEditing
            ? `${user.name} corrigió el resultado: ${setsStr}`
            : `${user.name} registró el resultado: ${setsStr}`,
          '/app/partidos',
        )
        .run()
    }

    message = isEditing
      ? '¡Resultado actualizado! Las valoraciones se han recalculado.'
      : '¡Resultado registrado! Las valoraciones se han actualizado.'
  }
}
---

<AppLayout
  title={match.status === 'completed' ? 'Editar resultado' : 'Registrar resultado'}
  user={user}
>
  <div class="max-w-xl mx-auto space-y-6">
    <div class="flex items-center gap-3">
      <a
        href="/app/partidos"
        class="w-8 h-8 rounded-lg bg-gray-100 hover:bg-gray-200 flex items-center justify-center transition-colors"
      >
        <svg
          class="w-4 h-4 text-navy"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
          ><path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18"></path></svg
        >
      </a>
      <div class="w-10 h-10 rounded-xl bg-teal/10 flex items-center justify-center">
        <svg
          class="w-5 h-5 text-teal"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
          ><path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M16.5 18.75h-9m9 0a3 3 0 013 3h-15a3 3 0 013-3m9 0v-3.375c0-.621-.503-1.125-1.125-1.125h-.871M7.5 18.75v-3.375c0-.621.504-1.125 1.125-1.125h.872m5.007 0H9.497m5.007 0a7.454 7.454 0 01-.982-3.172M9.497 14.25a7.454 7.454 0 00.981-3.172M5.25 4.236c-.982.143-1.954.317-2.916.52A6.003 6.003 0 007.73 9.728M5.25 4.236V4.5c0 2.108.966 3.99 2.48 5.228M5.25 4.236V2.721C7.456 2.41 9.71 2.25 12 2.25c2.291 0 4.545.16 6.75.47v1.516M18.75 4.236c.982.143 1.954.317 2.916.52A6.003 6.003 0 0016.27 9.728M18.75 4.236V4.5c0 2.108-.966 3.99-2.48 5.228m0 0a6.003 6.003 0 01-5.54 0"
          ></path></svg
        >
      </div>
      <div>
        <h1 class="font-display text-xl font-bold text-navy">
          {match.status === 'completed' ? 'Editar resultado' : 'Registrar resultado'}
        </h1>
        <p class="text-xs text-muted">
          {
            match.status === 'completed'
              ? 'Corrige los sets — las valoraciones se recalcularán automáticamente.'
              : 'Introduce los sets del partido para actualizar valoraciones.'
          }
        </p>
      </div>
    </div>

    <!-- Match summary -->
    <div class="card p-5">
      <div class="flex items-center justify-between">
        <div class="text-center flex-1">
          <div class="text-sm font-bold text-navy">{match.t1p1_name}</div>
          {match.t1p2_name && <div class="text-xs text-muted">&amp; {match.t1p2_name}</div>}
        </div>
        <div class="text-xs font-bold text-muted px-4">VS</div>
        <div class="text-center flex-1">
          <div class="text-sm font-bold text-navy">{match.t2p1_name}</div>
          {match.t2p2_name && <div class="text-xs text-muted">&amp; {match.t2p2_name}</div>}
        </div>
      </div>
      {match.location && <p class="text-xs text-muted text-center mt-2">📍 {match.location}</p>}
      {
        match.event_date && (
          <p class="text-xs text-muted text-center">
            {new Date(match.event_date).toLocaleDateString('es', {
              day: 'numeric',
              month: 'long',
              year: 'numeric',
            })}
          </p>
        )
      }
    </div>

    {
      message && (
        <div class="flex items-center gap-3 bg-teal/10 border border-teal/20 text-teal text-sm p-4 rounded-xl">
          <svg
            class="w-5 h-5 shrink-0"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
            />
          </svg>
          {message}
          <a href="/app/partidos" class="ml-auto text-xs font-semibold underline">
            Ver partidos
          </a>
        </div>
      )
    }
    {
      error && (
        <div class="flex items-center gap-3 bg-red-500/10 border border-red-500/20 text-red-500 text-sm p-4 rounded-xl">
          <svg
            class="w-5 h-5 shrink-0"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z"
            />
          </svg>
          {error}
        </div>
      )
    }

    {
      !message && (
        <form method="POST" class="card p-6 space-y-4">
          <h2 class="font-display text-sm font-bold text-navy uppercase tracking-wider">
            Resultado por sets
          </h2>
          <div class="space-y-3">
            <div class="grid grid-cols-[1fr_80px_24px_80px] items-center gap-2 px-1">
              <div />
              <div class="text-[10px] font-semibold text-teal uppercase tracking-wider text-center">
                Tu equipo
              </div>
              <div />
              <div class="text-[10px] font-semibold text-coral uppercase tracking-wider text-center">
                Rival
              </div>
            </div>
            {[1, 2, 3].map((n) => (
              <div class="grid grid-cols-[1fr_80px_24px_80px] items-center gap-2">
                <div class="text-xs font-medium text-navy">
                  Set {n}
                  {n === 1 ? ' *' : ''}
                </div>
                <input
                  type="number"
                  name={`set${n}_team1`}
                  min="0"
                  max="7"
                  value={existingSetScores[n - 1]?.team1 ?? undefined}
                  required={n === 1}
                  class="text-center px-2 py-2 bg-white border border-gray-200 rounded-xl text-sm font-display font-bold text-navy focus:outline-none focus:border-coral/50 transition-colors"
                />
                <span class="text-center text-muted text-xs">–</span>
                <input
                  type="number"
                  name={`set${n}_team2`}
                  min="0"
                  max="7"
                  value={existingSetScores[n - 1]?.team2 ?? undefined}
                  required={n === 1}
                  class="text-center px-2 py-2 bg-white border border-gray-200 rounded-xl text-sm font-display font-bold text-navy focus:outline-none focus:border-coral/50 transition-colors"
                />
              </div>
            ))}
          </div>
          <p class="text-[11px] text-muted/60">* Set 1 obligatorio. Sets 2 y 3 opcionales.</p>
          <div class="flex justify-end pt-2">
            <button
              type="submit"
              class="px-8 py-2.5 bg-teal text-white text-sm font-semibold rounded-full hover:bg-teal/90 transition-colors shadow-sm flex items-center gap-2"
            >
              <svg
                class="w-4 h-4"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
                />
              </svg>
              Guardar {match.status === 'completed' ? 'cambios' : 'resultado'}
            </button>
          </div>
        </form>
      )
    }
  </div>
</AppLayout>
