---
import AppLayout from '../../../layouts/AppLayout.astro'
import { generateId } from '../../../lib/auth'

const user = (Astro.locals as any).user
if (!user) return Astro.redirect('/login')

const db = (Astro.locals as any).db
let message = ''
let error = ''
let newMatchId = ''

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData()
  const partner_email = form.get('partner_email')?.toString().trim().toLowerCase()
  const opponent_email = form.get('opponent_email')?.toString().trim().toLowerCase()
  const opponent2_email = form.get('opponent2_email')?.toString().trim().toLowerCase()
  const event_date = form.get('event_date')?.toString() || null
  const location = form.get('location')?.toString().trim().slice(0, 200) || ''
  const notes = form.get('notes')?.toString().trim().slice(0, 500) || ''
  const tournament_id = form.get('tournament_id')?.toString() || null

  if (!partner_email || !opponent_email || !opponent2_email) {
    error = 'Indica los emails de los 4 jugadores (tu compañero/a y los dos rivales).'
  } else {
    const partner = (await db
      .prepare('SELECT id FROM users WHERE email = ?')
      .bind(partner_email)
      .first()) as { id: string } | null
    const opp1 = (await db
      .prepare('SELECT id FROM users WHERE email = ?')
      .bind(opponent_email)
      .first()) as { id: string } | null
    const opp2 = (await db
      .prepare('SELECT id FROM users WHERE email = ?')
      .bind(opponent2_email)
      .first()) as { id: string } | null

    if (!partner) error = 'No se encontró a tu compañero/a. Debe estar registrado/a.'
    else if (!opp1) error = 'No se encontró al rival 1. Debe estar registrado/a.'
    else if (!opp2) error = 'No se encontró al rival 2. Debe estar registrado/a.'
    else {
      const allIds = [user.id, partner.id, opp1.id, opp2.id]
      if (new Set(allIds).size !== 4) {
        error = 'Los 4 jugadores deben ser personas distintas.'
      } else {
        const matchId = generateId()
        await db
          .prepare(
            'INSERT INTO matches (id, tournament_id, team1_player1, team1_player2, team2_player1, team2_player2, team1_games, team2_games, set_scores, notes, recorded_by, status, event_date, location) VALUES (?, ?, ?, ?, ?, ?, 0, 0, ?, ?, ?, ?, ?, ?)',
          )
          .bind(
            matchId,
            tournament_id,
            user.id,
            partner.id,
            opp1.id,
            opp2.id,
            '[]',
            notes,
            user.id,
            'pending',
            event_date,
            location,
          )
          .run()

        // Notify other players
        for (const pid of [partner.id, opp1.id, opp2.id]) {
          await db
            .prepare(
              'INSERT INTO notifications (id, user_id, type, message, link) VALUES (?, ?, ?, ?, ?)',
            )
            .bind(
              crypto.randomUUID(),
              pid,
              'match',
              `${user.name} ha creado un partido contigo.`,
              '/app/partidos',
            )
            .run()
        }

        newMatchId = matchId
        message = '¡Partido creado! Registra el resultado cuando lo juguéis.'
      }
    }
  }
}

const tournaments = await db
  .prepare(
    `SELECT t.id, t.name FROM tournament_players tp JOIN tournaments t ON tp.tournament_id = t.id WHERE tp.user_id = ? AND t.status = 'open'`,
  )
  .bind(user.id)
  .all()
---

<AppLayout title="Crear partido" user={user}>
  <div class="max-w-2xl mx-auto space-y-6">
    <div class="flex items-center gap-3">
      <a
        href="/app/partidos"
        class="w-8 h-8 rounded-lg bg-gray-100 hover:bg-gray-200 flex items-center justify-center transition-colors"
      >
        <svg
          class="w-4 h-4 text-navy"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
          ><path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18"></path></svg
        >
      </a>
      <div class="w-10 h-10 rounded-xl bg-coral/10 flex items-center justify-center">
        <svg
          class="w-5 h-5 text-coral"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
          ><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"
          ></path></svg
        >
      </div>
      <div>
        <h1 class="font-display text-xl font-bold text-navy">Crear partido</h1>
        <p class="text-xs text-muted">Organiza un partido con otros jugadores. 2 vs 2.</p>
      </div>
    </div>

    {
      message && (
        <div class="flex flex-col gap-2 bg-teal/10 border border-teal/20 text-teal text-sm p-4 rounded-xl">
          <div class="flex items-center gap-2">
            <svg
              class="w-5 h-5 shrink-0"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
              />
            </svg>
            {message}
          </div>
          {newMatchId && (
            <a
              href={`/app/partidos/resultado/${newMatchId}`}
              class="inline-flex items-center gap-1.5 text-xs font-semibold text-teal underline"
            >
              Registrar resultado ahora →
            </a>
          )}
        </div>
      )
    }
    {
      error && (
        <div class="flex items-center gap-3 bg-red-500/10 border border-red-500/20 text-red-500 text-sm p-4 rounded-xl">
          <svg
            class="w-5 h-5 shrink-0"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z"
            />
          </svg>
          {error}
        </div>
      )
    }

    <form method="POST" class="space-y-6">
      <!-- Tu equipo -->
      <div class="card p-6 space-y-4">
        <h2
          class="font-display text-sm font-bold text-navy uppercase tracking-wider flex items-center gap-2"
        >
          <svg
            class="w-4 h-4 text-teal"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
            ><path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z"
            ></path></svg
          >
          Tu equipo
        </h2>
        <div class="flex items-center gap-3 bg-gray-50 rounded-xl p-3">
          <div class="w-8 h-8 rounded-lg bg-coral/10 flex items-center justify-center">
            <span class="text-sm font-bold text-coral">{user.name?.charAt(0)?.toUpperCase()}</span>
          </div>
          <div>
            <div class="text-sm font-medium text-navy">{user.name}</div>
            <div class="text-[11px] text-muted">{user.email}</div>
          </div>
          <span
            class="ml-auto text-[10px] font-semibold text-teal bg-teal/10 px-2 py-0.5 rounded-full uppercase"
            >Tú</span
          >
        </div>
        <div>
          <label for="partner_search" class="text-xs font-medium text-muted block mb-1.5"
            >Buscar compañero/a</label
          >
          <div class="relative player-search-wrap">
            <input
              type="text"
              id="partner_search"
              autocomplete="off"
              placeholder="Escribe un nombre..."
              data-target="partner_email"
              class="player-search w-full px-3.5 py-2.5 bg-white border border-gray-200 rounded-xl text-sm text-navy placeholder:text-muted/50 focus:outline-none focus:border-coral/50 transition-colors"
            />
            <input type="hidden" id="partner_email" name="partner_email" required />
            <div
              class="player-results hidden absolute left-0 right-0 top-full mt-1 z-20 bg-white border border-gray-200 rounded-xl shadow-lg max-h-48 overflow-y-auto"
            >
            </div>
          </div>
        </div>
      </div>

      <!-- Equipo rival -->
      <div class="card p-6 space-y-4">
        <h2
          class="font-display text-sm font-bold text-navy uppercase tracking-wider flex items-center gap-2"
        >
          <svg
            class="w-4 h-4 text-coral"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
            ><path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z"
            ></path></svg
          >
          Equipo rival
        </h2>
        <div class="grid sm:grid-cols-2 gap-4">
          <div>
            <label for="opponent_search" class="text-xs font-medium text-muted block mb-1.5"
              >Rival 1</label
            >
            <div class="relative player-search-wrap">
              <input
                type="text"
                id="opponent_search"
                autocomplete="off"
                placeholder="Escribe un nombre..."
                data-target="opponent_email"
                class="player-search w-full px-3.5 py-2.5 bg-white border border-gray-200 rounded-xl text-sm text-navy placeholder:text-muted/50 focus:outline-none focus:border-coral/50 transition-colors"
              />
              <input type="hidden" id="opponent_email" name="opponent_email" required />
              <div
                class="player-results hidden absolute left-0 right-0 top-full mt-1 z-20 bg-white border border-gray-200 rounded-xl shadow-lg max-h-48 overflow-y-auto"
              >
              </div>
            </div>
          </div>
          <div>
            <label for="opponent2_search" class="text-xs font-medium text-muted block mb-1.5"
              >Rival 2</label
            >
            <div class="relative player-search-wrap">
              <input
                type="text"
                id="opponent2_search"
                autocomplete="off"
                placeholder="Escribe un nombre..."
                data-target="opponent2_email"
                class="player-search w-full px-3.5 py-2.5 bg-white border border-gray-200 rounded-xl text-sm text-navy placeholder:text-muted/50 focus:outline-none focus:border-coral/50 transition-colors"
              />
              <input type="hidden" id="opponent2_email" name="opponent2_email" required />
              <div
                class="player-results hidden absolute left-0 right-0 top-full mt-1 z-20 bg-white border border-gray-200 rounded-xl shadow-lg max-h-48 overflow-y-auto"
              >
              </div>
            </div>
          </div>
        </div>
        <p class="text-[11px] text-muted/60">
          Todos los jugadores deben tener cuenta en Score Padel.
        </p>
      </div>

      <!-- Fecha y lugar -->
      <div class="card p-6 space-y-4">
        <h2
          class="font-display text-sm font-bold text-navy uppercase tracking-wider flex items-center gap-2"
        >
          <svg
            class="w-4 h-4 text-coral"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
            ><path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5"
            ></path></svg
          >
          Fecha y lugar (opcional)
        </h2>
        <div class="grid sm:grid-cols-2 gap-4">
          <div>
            <label for="event_date" class="text-xs font-medium text-muted block mb-1.5"
              >Fecha del partido</label
            >
            <input
              type="datetime-local"
              id="event_date"
              name="event_date"
              class="w-full px-3.5 py-2.5 bg-white border border-gray-200 rounded-xl text-sm text-navy focus:outline-none focus:border-coral/50 transition-colors"
            />
          </div>
          <div>
            <label for="location" class="text-xs font-medium text-muted block mb-1.5"
              >Cancha / Lugar</label
            >
            <input
              type="text"
              id="location"
              name="location"
              placeholder="Nombre de la pista..."
              class="w-full px-3.5 py-2.5 bg-white border border-gray-200 rounded-xl text-sm text-navy placeholder:text-muted/50 focus:outline-none focus:border-coral/50 transition-colors"
            />
          </div>
        </div>

        <!-- Map toggle -->
        <button
          type="button"
          id="btn-show-map"
          class="inline-flex items-center gap-2 text-xs font-semibold text-teal hover:text-teal/80 transition-colors"
        >
          <svg
            class="w-4 h-4"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
            ><path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"></path><path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"
            ></path></svg
          >
          Buscar cancha en el mapa
        </button>

        <!-- Embedded map (hidden by default) -->
        <div id="map-section" class="hidden space-y-3">
          <div class="flex flex-col sm:flex-row gap-2">
            <button
              type="button"
              id="btn-locate"
              class="inline-flex items-center gap-2 px-4 py-2 bg-coral text-white text-xs font-semibold rounded-full hover:bg-coral-dark transition-colors"
            >
              <svg
                class="w-3.5 h-3.5"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
                ><path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"></path><path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"
                ></path></svg
              >
              Mi ubicación
            </button>
            <input
              type="text"
              id="search-city"
              placeholder="Buscar ciudad..."
              class="flex-1 pl-3 pr-4 py-2 bg-white border border-gray-200 rounded-full text-xs text-navy placeholder:text-muted/50 focus:outline-none focus:border-coral/50 transition-colors"
            />
            <button
              type="button"
              id="btn-search"
              class="px-4 py-2 border-2 border-coral/30 text-coral text-xs font-semibold rounded-full hover:bg-coral/5 transition-colors"
            >
              Buscar
            </button>
          </div>
          <div id="search-status" class="text-xs text-muted hidden"></div>
          <div class="rounded-xl overflow-hidden border border-gray-200" style="height:320px;">
            <div id="map" class="w-full h-full"></div>
          </div>
          <div id="results-panel" class="hidden">
            <p class="text-xs font-semibold text-navy mb-2">
              <span id="results-count">0</span> pistas encontradas
            </p>
            <div id="results-list" class="grid sm:grid-cols-2 gap-2 max-h-48 overflow-y-auto"></div>
          </div>
        </div>
      </div>

      <!-- Torneo -->
      {
        (tournaments.results?.length ?? 0) > 0 && (
          <div class="card p-6 space-y-4">
            <h2 class="font-display text-sm font-bold text-navy uppercase tracking-wider">
              Torneo (opcional)
            </h2>
            <select
              id="tournament_id"
              name="tournament_id"
              class="w-full px-3.5 py-2.5 bg-white border border-gray-200 rounded-xl text-sm text-navy focus:outline-none focus:border-coral/50 transition-colors"
            >
              <option value="">Sin torneo</option>
              {tournaments.results?.map((t: any) => (
                <option value={t.id}>{t.name}</option>
              ))}
            </select>
          </div>
        )
      }

      <!-- Notas -->
      <div class="card p-6 space-y-3">
        <h2 class="font-display text-sm font-bold text-navy uppercase tracking-wider">
          Notas (opcional)
        </h2>
        <textarea
          id="notes"
          name="notes"
          rows="2"
          maxlength="500"
          placeholder="Superficie, comentarios..."
          class="w-full px-3.5 py-2.5 bg-white border border-gray-200 rounded-xl text-sm text-navy placeholder:text-muted/50 focus:outline-none focus:border-coral/50 transition-colors resize-none"
        ></textarea>
      </div>

      <div class="flex justify-end">
        <button
          type="submit"
          class="px-8 py-2.5 bg-coral text-white text-sm font-semibold rounded-full hover:bg-coral-dark transition-colors shadow-sm flex items-center gap-2"
        >
          <svg
            class="w-4 h-4"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
            ><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"
            ></path></svg
          >
          Crear partido
        </button>
      </div>
    </form>
  </div>

  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" crossorigin="" />
  <script is:inline src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" crossorigin=""></script>
  <script is:inline>
    ;(function () {
      var mapInitialized = false
      var map, markersLayer, userMarker

      document.getElementById('btn-show-map').addEventListener('click', function () {
        var section = document.getElementById('map-section')
        section.classList.toggle('hidden')
        if (!mapInitialized && !section.classList.contains('hidden')) {
          mapInitialized = true
          map = L.map('map').setView([40.4168, -3.7038], 6)
          L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            attribution: '&copy; OpenStreetMap',
            maxZoom: 19,
          }).addTo(map)
          markersLayer = L.layerGroup().addTo(map)
        }
      })

      var padelIcon = null
      function getPadelIcon() {
        if (!padelIcon)
          padelIcon = L.divIcon({
            html: '<div style="background:#FF6A00;width:24px;height:24px;border-radius:50%;border:2px solid white;box-shadow:0 2px 6px rgba(0,0,0,0.3)"></div>',
            className: '',
            iconSize: [24, 24],
            iconAnchor: [12, 12],
            popupAnchor: [0, -14],
          })
        return padelIcon
      }

      function setStatus(msg, isError) {
        var el = document.getElementById('search-status')
        el.textContent = msg
        el.classList.remove('hidden', 'text-red-500', 'text-muted')
        el.classList.add(isError ? 'text-red-500' : 'text-muted')
      }

      function escapeHtml(str) {
        var d = document.createElement('div')
        d.textContent = str
        return d.innerHTML
      }

      function dist(lat1, lon1, lat2, lon2) {
        var R = 6371,
          dLat = ((lat2 - lat1) * Math.PI) / 180,
          dLon = ((lon2 - lon1) * Math.PI) / 180
        var a =
          Math.sin(dLat / 2) * Math.sin(dLat / 2) +
          Math.cos((lat1 * Math.PI) / 180) *
            Math.cos((lat2 * Math.PI) / 180) *
            Math.sin(dLon / 2) *
            Math.sin(dLon / 2)
        return R * 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a))
      }

      function renderResults(courts, userLat, userLon) {
        var panel = document.getElementById('results-panel')
        var list = document.getElementById('results-list')
        var count = document.getElementById('results-count')
        count.textContent = courts.length
        list.innerHTML = ''
        if (courts.length === 0) {
          panel.classList.add('hidden')
          return
        }
        panel.classList.remove('hidden')
        courts.forEach(function (c) {
          var d = document.createElement('div')
          d.className = 'card p-3 cursor-pointer hover:border-coral/30 transition-all'
          d.innerHTML =
            '<div class="text-xs font-bold text-navy">' +
            escapeHtml(c.name) +
            '</div>' +
            (c.address
              ? '<div class="text-[11px] text-muted">📍 ' + escapeHtml(c.address) + '</div>'
              : '') +
            '<div class="text-[11px] font-semibold text-teal mt-1">' +
            c.d.toFixed(1) +
            ' km</div>'
          d.addEventListener('click', function () {
            map.setView([c.lat, c.lon], 16)
            document.getElementById('location').value = c.name
          })
          list.appendChild(d)
        })
      }

      async function searchPadel(lat, lon) {
        setStatus('Buscando pistas...', false)
        var q =
          '[out:json][timeout:25];(node["sport"="padel"](around:15000,' +
          lat +
          ',' +
          lon +
          ');way["sport"="padel"](around:15000,' +
          lat +
          ',' +
          lon +
          ');node["leisure"="pitch"]["sport"="padel"](around:15000,' +
          lat +
          ',' +
          lon +
          '););out center body;'
        try {
          var res = await fetch('https://overpass-api.de/api/interpreter', {
            method: 'POST',
            body: 'data=' + encodeURIComponent(q),
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          })
          var data = await res.json()
          markersLayer.clearLayers()
          var courts = []
          data.elements.forEach(function (el) {
            var elLat = el.lat || (el.center && el.center.lat)
            var elLon = el.lon || (el.center && el.center.lon)
            if (!elLat) return
            var name = (el.tags && el.tags.name) || 'Pista de pádel'
            var address = el.tags && (el.tags['addr:street'] || el.tags['addr:city'] || '')
            var d = dist(lat, lon, elLat, elLon)
            courts.push({ name: name, address: address, lat: elLat, lon: elLon, d: d })
            L.marker([elLat, elLon], { icon: getPadelIcon() })
              .addTo(markersLayer)
              .bindPopup('<strong>' + escapeHtml(name) + '</strong>')
              .on('click', function () {
                document.getElementById('location').value = name
              })
          })
          courts.sort(function (a, b) {
            return a.d - b.d
          })
          renderResults(courts, lat, lon)
          setStatus(courts.length + ' pistas encontradas.', false)
        } catch (e) {
          setStatus('Error al buscar: ' + e.message, true)
        }
      }

      document.getElementById('btn-locate').addEventListener('click', function () {
        if (!mapInitialized) return
        navigator.geolocation.getCurrentPosition(
          function (pos) {
            var lat = pos.coords.latitude,
              lon = pos.coords.longitude
            userMarker && map.removeLayer(userMarker)
            userMarker = L.marker([lat, lon]).addTo(map).bindPopup('Tu ubicación').openPopup()
            map.setView([lat, lon], 13)
            searchPadel(lat, lon)
          },
          function (e) {
            setStatus('No se pudo obtener ubicación.', true)
          },
        )
      })

      document.getElementById('btn-search').addEventListener('click', async function () {
        if (!mapInitialized) return
        var city = document.getElementById('search-city').value.trim()
        if (!city) return
        setStatus('Buscando "' + city + '"...', false)
        try {
          var res = await fetch(
            'https://nominatim.openstreetmap.org/search?format=json&q=' +
              encodeURIComponent(city) +
              '&limit=1&accept-language=es',
            { headers: { 'User-Agent': 'ScorePadel/1.0' } },
          )
          var results = await res.json()
          if (!results.length) {
            setStatus('Ciudad no encontrada.', true)
            return
          }
          var lat = parseFloat(results[0].lat),
            lon = parseFloat(results[0].lon)
          map.setView([lat, lon], 13)
          searchPadel(lat, lon)
        } catch (e) {
          setStatus('Error: ' + e.message, true)
        }
      })

      document.getElementById('search-city').addEventListener('keydown', function (e) {
        if (e.key === 'Enter') {
          e.preventDefault()
          document.getElementById('btn-search').click()
        }
      })
    })()
  </script>

  <script>
    document.querySelectorAll<HTMLInputElement>('.player-search').forEach((input) => {
      const wrap = input.closest('.player-search-wrap')!
      const results = wrap.querySelector('.player-results') as HTMLElement
      const targetId = input.dataset.target!
      const hidden = document.getElementById(targetId) as HTMLInputElement
      let timer: ReturnType<typeof setTimeout>

      input.addEventListener('input', () => {
        clearTimeout(timer)
        hidden.value = ''
        const q = input.value.trim()
        if (q.length < 2) {
          results.classList.add('hidden')
          return
        }

        timer = setTimeout(async () => {
          const res = await fetch(`/api/players/search?q=${encodeURIComponent(q)}`)
          const players = (await res.json()) as {
            id: string
            name: string
            email: string
            rating: string
            location: string
          }[]

          if (players.length === 0) {
            results.innerHTML = '<div class="px-3 py-2 text-xs text-muted">Sin resultados</div>'
          } else {
            results.innerHTML = players
              .map(
                (p) => `
              <button type="button" class="w-full text-left px-3 py-2 hover:bg-coral/5 flex items-center gap-2 transition-colors" data-email="${p.email}" data-name="${p.name}">
                <span class="w-6 h-6 rounded-lg bg-coral/10 flex items-center justify-center text-[10px] font-bold text-coral shrink-0">${p.name.charAt(0).toUpperCase()}</span>
                <span class="flex-1 min-w-0">
                  <span class="text-xs font-medium text-navy block truncate">${p.name}</span>
                  <span class="text-[10px] text-muted block truncate">${p.location || p.email}</span>
                </span>
                <span class="text-[10px] font-bold text-coral shrink-0">${p.rating}</span>
              </button>
            `,
              )
              .join('')
          }

          results.classList.remove('hidden')
          results.querySelectorAll('button').forEach((btn) => {
            btn.addEventListener('click', () => {
              hidden.value = btn.dataset.email!
              input.value = btn.dataset.name!
              results.classList.add('hidden')
            })
          })
        }, 250)
      })

      document.addEventListener('click', (e) => {
        if (!wrap.contains(e.target as Node)) results.classList.add('hidden')
      })
    })
  </script>
</AppLayout>
