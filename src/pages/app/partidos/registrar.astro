---
import AppLayout from '../../../layouts/AppLayout.astro'
import { generateId } from '../../../lib/auth'
import { calculateAndUpdateRatings } from '../../../lib/rating'

const user = (Astro.locals as any).user
if (!user) return Astro.redirect('/login')
if (user.role === 'guest') return Astro.redirect('/app?error=guest')

const db = (Astro.locals as any).db
let message = ''
let error = ''

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData()
  const opponent_email = form.get('opponent_email')?.toString().trim().toLowerCase()
  const partner_email = form.get('partner_email')?.toString().trim().toLowerCase()
  const opponent2_email = form.get('opponent2_email')?.toString().trim().toLowerCase()
  const tournament_id_raw = form.get('tournament_id')?.toString() || null
  const notes = form.get('notes')?.toString().trim().slice(0, 500) || ''

  // Parse set scores
  const sets: { team1: number; team2: number }[] = []
  for (let i = 1; i <= 5; i++) {
    const s1 = form.get(`set${i}_team1`)?.toString()
    const s2 = form.get(`set${i}_team2`)?.toString()
    if (s1 !== undefined && s2 !== undefined && s1 !== '' && s2 !== '') {
      sets.push({
        team1: Math.min(7, Math.max(0, parseInt(s1) || 0)),
        team2: Math.min(7, Math.max(0, parseInt(s2) || 0)),
      })
    }
  }

  // Calculate total games from sets
  const team1_games = sets.reduce((sum, s) => sum + s.team1, 0)
  const team2_games = sets.reduce((sum, s) => sum + s.team2, 0)

  if (!opponent_email || !partner_email || !opponent2_email) {
    error = 'Indica los emails de los 4 jugadores (tu compañero y los dos oponentes).'
  } else if (sets.length === 0) {
    error = 'Introduce al menos un set.'
  } else if (team1_games === 0 && team2_games === 0) {
    error = 'Registra al menos un juego.'
  } else {
    const opponent = (await db
      .prepare('SELECT id FROM users WHERE email = ?')
      .bind(opponent_email)
      .first()) as { id: string } | null
    if (!opponent) {
      error = 'No se encontró al oponente. Debe estar registrado.'
    } else if (opponent.id === user.id) {
      error = 'No puedes jugar contra ti mismo.'
    } else {
      const partner = (await db
        .prepare('SELECT id FROM users WHERE email = ?')
        .bind(partner_email)
        .first()) as { id: string } | null
      const opp2 = (await db
        .prepare('SELECT id FROM users WHERE email = ?')
        .bind(opponent2_email)
        .first()) as { id: string } | null

      let partnerId: string | null = null
      let opponent2Id: string | null = null

      if (!partner) {
        error = 'No se encontró a tu compañero/a. Debe estar registrado/a.'
      } else if (!opp2) {
        error = 'No se encontró al segundo oponente. Debe estar registrado/a.'
      } else {
        const allIds = [user.id, partner.id, opponent.id, opp2.id]
        if (new Set(allIds).size !== 4) {
          error = 'Los 4 jugadores deben ser personas distintas.'
        } else {
          partnerId = partner.id
          opponent2Id = opp2.id
        }
      }

      // Validate tournament_id: user must be a participant
      let tournament_id: string | null = null
      if (tournament_id_raw && !error) {
        const inTournament = await db
          .prepare('SELECT 1 FROM tournament_players WHERE tournament_id = ? AND user_id = ?')
          .bind(tournament_id_raw, user.id)
          .first()
        if (!inTournament) {
          error = 'No eres participante de este torneo.'
        } else {
          tournament_id = tournament_id_raw
        }
      }

      if (!error) {
        const matchId = generateId()
        await db
          .prepare(
            'INSERT INTO matches (id, tournament_id, team1_player1, team1_player2, team2_player1, team2_player2, team1_games, team2_games, set_scores, notes, recorded_by) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)',
          )
          .bind(
            matchId,
            tournament_id,
            user.id,
            partnerId,
            opponent.id,
            opponent2Id,
            team1_games,
            team2_games,
            JSON.stringify(sets),
            notes,
            user.id,
          )
          .run()

        const team1 = [user.id, partnerId!]
        const team2 = [opponent.id, opponent2Id!]

        await calculateAndUpdateRatings(db, matchId, team1, team2, team1_games, team2_games)

        // Create match confirmations (recorder auto-confirmed)
        const allPlayerIds = [user.id, partnerId!, opponent.id, opponent2Id!]
        for (const pid of allPlayerIds) {
          await db
            .prepare(
              'INSERT INTO match_confirmations (match_id, user_id, confirmed) VALUES (?, ?, ?)',
            )
            .bind(matchId, pid, pid === user.id ? 1 : 0)
            .run()
        }

        // Create notifications for all players except the recorder
        const setsStr = sets.map((s) => `${s.team1}-${s.team2}`).join(', ')
        const otherPlayers = [partnerId!, opponent.id, opponent2Id!].filter(
          (pid) => pid !== user.id,
        )
        for (const pid of otherPlayers) {
          const nId = crypto.randomUUID()
          await db
            .prepare(
              'INSERT INTO notifications (id, user_id, type, message, link) VALUES (?, ?, ?, ?, ?)',
            )
            .bind(
              nId,
              pid,
              'match',
              `${user.name} ha registrado un partido: ${setsStr}`,
              '/app/partidos',
            )
            .run()
        }

        message = '¡Partido registrado! Las valoraciones se han actualizado.'
      }
    }
  }
}

// Get user's tournaments for optional linking
const tournaments = await db
  .prepare(
    `
  SELECT t.id, t.name FROM tournament_players tp
  JOIN tournaments t ON tp.tournament_id = t.id
  WHERE tp.user_id = ? AND t.status = 'open'
`,
  )
  .bind(user.id)
  .all()
---

<AppLayout title="Registrar partido" user={user}>
  <div class="max-w-2xl mx-auto space-y-6">
    <!-- Header -->
    <div class="flex items-center gap-3">
      <div class="w-10 h-10 rounded-xl bg-coral/10 flex items-center justify-center">
        <svg
          class="w-5 h-5 text-coral"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
          ><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"
          ></path></svg
        >
      </div>
      <div>
        <h1 class="font-display text-xl font-bold text-navy">Registrar partido</h1>
        <p class="text-xs text-muted">
          Introduce los datos del partido para actualizar las valoraciones.
        </p>
      </div>
    </div>

    {
      message && (
        <div class="flex items-center gap-3 bg-teal/10 border border-teal/20 text-teal text-sm p-4 rounded-xl">
          <svg
            class="w-5 h-5 shrink-0"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
            />
          </svg>
          {message}
        </div>
      )
    }
    {
      error && (
        <div class="flex items-center gap-3 bg-red-500/10 border border-red-500/20 text-red-500 text-sm p-4 rounded-xl">
          <svg
            class="w-5 h-5 shrink-0"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z"
            />
          </svg>
          {error}
        </div>
      )
    }

    <form method="POST" class="space-y-6">
      <!-- Tu pareja -->
      <div class="card p-6 space-y-4">
        <h2
          class="font-display text-sm font-bold text-navy uppercase tracking-wider flex items-center gap-2"
        >
          <svg
            class="w-4 h-4 text-teal"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
            ><path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z"
            ></path></svg
          >
          Tu equipo
        </h2>
        <div class="flex items-center gap-3 bg-gray-50 rounded-xl p-3">
          <div class="w-8 h-8 rounded-lg bg-coral/10 flex items-center justify-center">
            <span class="text-sm font-bold text-coral">{user.name?.charAt(0)?.toUpperCase()}</span>
          </div>
          <div>
            <div class="text-sm font-medium text-navy">{user.name}</div>
            <div class="text-[11px] text-muted">{user.email}</div>
          </div>
          <span
            class="ml-auto text-[10px] font-semibold text-teal bg-teal/10 px-2 py-0.5 rounded-full uppercase"
            >Tú</span
          >
        </div>
        <div>
          <label for="partner_search" class="text-xs font-medium text-muted block mb-1.5"
            >Buscar compañero/a</label
          >
          <div class="relative player-search-wrap">
            <input
              type="text"
              id="partner_search"
              autocomplete="off"
              placeholder="Escribe un nombre..."
              data-target="partner_email"
              class="player-search w-full px-3.5 py-2.5 bg-white border border-gray-200 rounded-xl text-sm text-navy placeholder:text-muted/50 focus:outline-none focus:border-coral/50 transition-colors"
            />
            <input type="hidden" id="partner_email" name="partner_email" required />
            <div
              class="player-results hidden absolute left-0 right-0 top-full mt-1 z-20 bg-white border border-gray-200 rounded-xl shadow-lg max-h-48 overflow-y-auto"
            >
            </div>
          </div>
        </div>
      </div>

      <!-- Equipo rival -->
      <div class="card p-6 space-y-4">
        <h2
          class="font-display text-sm font-bold text-navy uppercase tracking-wider flex items-center gap-2"
        >
          <svg
            class="w-4 h-4 text-coral"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
            ><path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z"
            ></path></svg
          >
          Equipo rival
        </h2>
        <div class="grid sm:grid-cols-2 gap-4">
          <div>
            <label for="opponent_search" class="text-xs font-medium text-muted block mb-1.5"
              >Oponente 1</label
            >
            <div class="relative player-search-wrap">
              <input
                type="text"
                id="opponent_search"
                autocomplete="off"
                placeholder="Escribe un nombre..."
                data-target="opponent_email"
                class="player-search w-full px-3.5 py-2.5 bg-white border border-gray-200 rounded-xl text-sm text-navy placeholder:text-muted/50 focus:outline-none focus:border-coral/50 transition-colors"
              />
              <input type="hidden" id="opponent_email" name="opponent_email" required />
              <div
                class="player-results hidden absolute left-0 right-0 top-full mt-1 z-20 bg-white border border-gray-200 rounded-xl shadow-lg max-h-48 overflow-y-auto"
              >
              </div>
            </div>
          </div>
          <div>
            <label for="opponent2_search" class="text-xs font-medium text-muted block mb-1.5"
              >Oponente 2</label
            >
            <div class="relative player-search-wrap">
              <input
                type="text"
                id="opponent2_search"
                autocomplete="off"
                placeholder="Escribe un nombre..."
                data-target="opponent2_email"
                class="player-search w-full px-3.5 py-2.5 bg-white border border-gray-200 rounded-xl text-sm text-navy placeholder:text-muted/50 focus:outline-none focus:border-coral/50 transition-colors"
              />
              <input type="hidden" id="opponent2_email" name="opponent2_email" required />
              <div
                class="player-results hidden absolute left-0 right-0 top-full mt-1 z-20 bg-white border border-gray-200 rounded-xl shadow-lg max-h-48 overflow-y-auto"
              >
              </div>
            </div>
          </div>
        </div>
        <p class="text-[11px] text-muted/60 flex items-center gap-1">
          <svg
            class="w-3 h-3"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
            ><path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M11.25 11.25l.041-.02a.75.75 0 011.063.852l-.708 2.836a.75.75 0 001.063.853l.041-.021M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9-3.75h.008v.008H12V8.25z"
            ></path></svg
          >
          Todos los jugadores deben tener cuenta en Score Padel.
        </p>
      </div>

      <!-- Resultado por sets -->
      <div class="card p-6 space-y-4">
        <h2
          class="font-display text-sm font-bold text-navy uppercase tracking-wider flex items-center gap-2"
        >
          <svg
            class="w-4 h-4 text-coral"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
            ><path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M16.5 18.75h-9m9 0a3 3 0 013 3h-15a3 3 0 013-3m9 0v-3.375c0-.621-.503-1.125-1.125-1.125h-.871M7.5 18.75v-3.375c0-.621.504-1.125 1.125-1.125h.872m5.007 0H9.497m5.007 0a7.454 7.454 0 01-.982-3.172M9.497 14.25a7.454 7.454 0 00.981-3.172M5.25 4.236c-.982.143-1.954.317-2.916.52A6.003 6.003 0 007.73 9.728M5.25 4.236V4.5c0 2.108.966 3.99 2.48 5.228M5.25 4.236V2.721C7.456 2.41 9.71 2.25 12 2.25c2.291 0 4.545.16 6.75.47v1.516M18.75 4.236c.982.143 1.954.317 2.916.52A6.003 6.003 0 0016.27 9.728M18.75 4.236V4.5c0 2.108-.966 3.99-2.48 5.228m0 0a6.003 6.003 0 01-5.54 0"
            ></path></svg
          >
          Resultado
        </h2>

        <div class="space-y-3" id="sets-container">
          <!-- Header row -->
          <div class="grid grid-cols-[1fr_80px_24px_80px] items-center gap-2 px-1">
            <div></div>
            <div class="text-[10px] font-semibold text-teal uppercase tracking-wider text-center">
              Tu equipo
            </div>
            <div></div>
            <div class="text-[10px] font-semibold text-coral uppercase tracking-wider text-center">
              Rival
            </div>
          </div>
          <!-- Set 1 (required) -->
          <div class="grid grid-cols-[1fr_80px_24px_80px] items-center gap-2 set-row">
            <div class="text-xs font-medium text-navy">Set 1</div>
            <input
              type="number"
              name="set1_team1"
              min="0"
              max="7"
              required
              class="text-center px-2 py-2 bg-white border border-gray-200 rounded-xl text-sm font-display font-bold text-navy focus:outline-none focus:border-coral/50 transition-colors"
            />
            <span class="text-center text-muted text-xs">–</span>
            <input
              type="number"
              name="set1_team2"
              min="0"
              max="7"
              required
              class="text-center px-2 py-2 bg-white border border-gray-200 rounded-xl text-sm font-display font-bold text-navy focus:outline-none focus:border-coral/50 transition-colors"
            />
          </div>
          <!-- Set 2 -->
          <div class="grid grid-cols-[1fr_80px_24px_80px] items-center gap-2 set-row">
            <div class="text-xs font-medium text-navy">Set 2</div>
            <input
              type="number"
              name="set2_team1"
              min="0"
              max="7"
              class="text-center px-2 py-2 bg-white border border-gray-200 rounded-xl text-sm font-display font-bold text-navy focus:outline-none focus:border-coral/50 transition-colors"
            />
            <span class="text-center text-muted text-xs">–</span>
            <input
              type="number"
              name="set2_team2"
              min="0"
              max="7"
              class="text-center px-2 py-2 bg-white border border-gray-200 rounded-xl text-sm font-display font-bold text-navy focus:outline-none focus:border-coral/50 transition-colors"
            />
          </div>
          <!-- Set 3 -->
          <div class="grid grid-cols-[1fr_80px_24px_80px] items-center gap-2 set-row">
            <div class="text-xs font-medium text-navy">Set 3</div>
            <input
              type="number"
              name="set3_team1"
              min="0"
              max="7"
              class="text-center px-2 py-2 bg-white border border-gray-200 rounded-xl text-sm font-display font-bold text-navy focus:outline-none focus:border-coral/50 transition-colors"
            />
            <span class="text-center text-muted text-xs">–</span>
            <input
              type="number"
              name="set3_team2"
              min="0"
              max="7"
              class="text-center px-2 py-2 bg-white border border-gray-200 rounded-xl text-sm font-display font-bold text-navy focus:outline-none focus:border-coral/50 transition-colors"
            />
          </div>
        </div>

        <p class="text-[11px] text-muted/60 flex items-center gap-1">
          <svg
            class="w-3 h-3"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
            ><path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M11.25 11.25l.041-.02a.75.75 0 011.063.852l-.708 2.836a.75.75 0 001.063.853l.041-.021M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9-3.75h.008v.008H12V8.25z"
            ></path></svg
          >
          Set 1 obligatorio. Sets 2 y 3 opcionales. Los juegos totales se calculan automáticamente.
        </p>
      </div>

      {
        (tournaments.results?.length ?? 0) > 0 && (
          <div class="card p-6 space-y-4">
            <h2 class="font-display text-sm font-bold text-navy uppercase tracking-wider flex items-center gap-2">
              <svg
                class="w-4 h-4 text-coral"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5"
                />
              </svg>
              Torneo (opcional)
            </h2>
            <select
              id="tournament_id"
              name="tournament_id"
              class="w-full px-3.5 py-2.5 bg-white border border-gray-200 rounded-xl text-sm text-navy focus:outline-none focus:border-coral/50 transition-colors"
            >
              <option value="">Sin torneo</option>
              {tournaments.results?.map((t: any) => (
                <option value={t.id}>{t.name}</option>
              ))}
            </select>
          </div>
        )
      }

      <!-- Notas -->
      <div class="card p-6 space-y-4">
        <h2
          class="font-display text-sm font-bold text-navy uppercase tracking-wider flex items-center gap-2"
        >
          <svg
            class="w-4 h-4 text-coral"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
            ><path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M7.5 8.25h9m-9 3H12m-9.75 1.51c0 1.6 1.123 2.994 2.707 3.227 1.087.16 2.185.283 3.293.369V21l4.076-4.076a1.526 1.526 0 011.037-.443 48.282 48.282 0 005.68-.494c1.584-.233 2.707-1.626 2.707-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0012 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018z"
            ></path></svg
          >
          Notas (opcional)
        </h2>
        <textarea
          id="notes"
          name="notes"
          rows="2"
          maxlength="500"
          placeholder="Superficie, comentarios, condiciones del partido..."
          class="w-full px-3.5 py-2.5 bg-white border border-gray-200 rounded-xl text-sm text-navy placeholder:text-muted/50 focus:outline-none focus:border-coral/50 transition-colors resize-none"
        ></textarea>
      </div>

      <!-- Buscar cancha -->
      <a
        href="/app/canchas"
        target="_blank"
        class="card p-5 flex items-center gap-3 hover:border-coral/30 transition-colors group"
      >
        <div class="w-9 h-9 rounded-xl bg-teal/10 flex items-center justify-center shrink-0">
          <svg
            class="w-4.5 h-4.5 text-teal"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"></path>
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"
            ></path>
          </svg>
        </div>
        <div class="flex-1">
          <div class="text-sm font-bold text-navy">¿Dónde jugar?</div>
          <div class="text-xs text-muted">Busca pistas de pádel cerca de ti con el mapa.</div>
        </div>
        <svg
          class="w-4 h-4 text-muted group-hover:text-coral transition-colors"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"
          ></path>
        </svg>
      </a>

      <div class="flex justify-end">
        <button
          type="submit"
          class="px-8 py-2.5 bg-coral text-white text-sm font-semibold rounded-full hover:bg-coral-dark transition-colors shadow-sm flex items-center gap-2"
        >
          <svg
            class="w-4 h-4"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
            ><path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg
          >
          Registrar resultado
        </button>
      </div>
    </form>
  </div>
</AppLayout>

<script>
  document.querySelectorAll<HTMLInputElement>('.player-search').forEach((input) => {
    const wrap = input.closest('.player-search-wrap')!
    const results = wrap.querySelector('.player-results') as HTMLElement
    const targetId = input.dataset.target!
    const hidden = document.getElementById(targetId) as HTMLInputElement
    let timer: ReturnType<typeof setTimeout>

    input.addEventListener('input', () => {
      clearTimeout(timer)
      hidden.value = ''
      const q = input.value.trim()
      if (q.length < 2) {
        results.classList.add('hidden')
        return
      }
      timer = setTimeout(async () => {
        const res = await fetch(`/api/players/search?q=${encodeURIComponent(q)}`)
        const players = (await res.json()) as {
          id: string
          name: string
          email: string
          rating: string
          location: string
        }[]
        if (players.length === 0) {
          results.innerHTML = '<div class="px-3 py-2 text-xs text-muted">Sin resultados</div>'
        } else {
          results.innerHTML = players
            .map(
              (p) => `
            <button type="button" class="w-full text-left px-3 py-2 hover:bg-coral/5 flex items-center gap-2 transition-colors" data-email="${p.email}" data-name="${p.name}">
              <span class="w-6 h-6 rounded-lg bg-coral/10 flex items-center justify-center text-[10px] font-bold text-coral shrink-0">${p.name.charAt(0).toUpperCase()}</span>
              <span class="flex-1 min-w-0">
                <span class="text-xs font-medium text-navy block truncate">${p.name}</span>
                <span class="text-[10px] text-muted block truncate">${p.location || p.email}</span>
              </span>
              <span class="text-[10px] font-bold text-coral shrink-0">${p.rating}</span>
            </button>
          `,
            )
            .join('')
        }
        results.classList.remove('hidden')
        results.querySelectorAll('button').forEach((btn) => {
          btn.addEventListener('click', () => {
            hidden.value = btn.dataset.email!
            input.value = btn.dataset.name!
            results.classList.add('hidden')
          })
        })
      }, 250)
    })

    document.addEventListener('click', (e) => {
      if (!wrap.contains(e.target as Node)) results.classList.add('hidden')
    })
  })
</script>
