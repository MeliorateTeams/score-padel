---
import AppLayout from '../../layouts/AppLayout.astro'
import { getProfile } from '../../lib/db'

const user = (Astro.locals as any).user
if (!user) return Astro.redirect('/login')

const db = (Astro.locals as any).db
const profile = await getProfile(db, user.id)

const ratingLevel = (r: number) => {
  if (r < 2.0) return { nombre: 'Iniciación Pádel', div: 'C' }
  if (r < 2.5) return { nombre: 'Consistencia Inicial', div: 'C' }
  if (r < 3.0) return { nombre: 'Precisión en Desarrollo', div: 'C' }
  if (r < 3.5) return { nombre: 'Confianza Intermedia', div: 'C' }
  if (r < 4.0) return { nombre: 'Control y Ritmo', div: 'B' }
  if (r < 4.5) return { nombre: 'Estrategas del Pádel', div: 'B' }
  if (r < 5.0) return { nombre: 'Jugadores Ingeniosos', div: 'B' }
  if (r < 5.5) return { nombre: 'Competidores de Torneo', div: 'B' }
  if (r < 6.0) return { nombre: 'Estrellas Nacionales', div: 'B' }
  if (r < 6.5) return { nombre: 'Semiprofesionales en Ascenso', div: 'A' }
  if (r < 7.0) return { nombre: 'Profesionales de Élite', div: 'A' }
  return { nombre: 'Élite Mundial del Pádel', div: 'A' }
}

const level = ratingLevel(profile?.rating ?? 1.0)
const rating = profile?.rating?.toFixed(1) ?? '1.0'

// Progress toward next level
const levelThresholds = [2.0, 2.5, 3.0, 3.5, 4.0, 4.5, 5.0, 5.5, 6.0, 6.5, 7.0]
const currentRating = profile?.rating ?? 1.0
const nextThreshold = levelThresholds.find((t) => t > currentRating) ?? 7.0
const prevThreshold = [...levelThresholds].reverse().find((t) => t <= currentRating) ?? 1.0
const progressPct =
  nextThreshold === prevThreshold
    ? 100
    : Math.round(((currentRating - prevThreshold) / (nextThreshold - prevThreshold)) * 100)
const nextLevel = ratingLevel(nextThreshold)

const recentMatches = await db
  .prepare(
    `
  SELECT m.*, m.created_at as match_date,
    u1.name as t1p1_name, u2.name as t2p1_name,
    u3.name as t1p2_name, u4.name as t2p2_name
  FROM matches m
  LEFT JOIN users u1 ON m.team1_player1 = u1.id
  LEFT JOIN users u2 ON m.team2_player1 = u2.id
  LEFT JOIN users u3 ON m.team1_player2 = u3.id
  LEFT JOIN users u4 ON m.team2_player2 = u4.id
  WHERE m.team1_player1 = ? OR m.team1_player2 = ? OR m.team2_player1 = ? OR m.team2_player2 = ?
  ORDER BY m.created_at DESC LIMIT 5
`,
  )
  .bind(user.id, user.id, user.id, user.id)
  .all()

const ratingHist = await db
  .prepare(
    `
  SELECT old_rating, new_rating, created_at FROM rating_history
  WHERE user_id = ? ORDER BY created_at DESC LIMIT 20
`,
  )
  .bind(user.id)
  .all()

// Streak calculation
let streak = 0
let streakType = ''
for (const m of (recentMatches.results ?? []) as any[]) {
  const isTeam1 = m.team1_player1 === user.id || m.team1_player2 === user.id
  const won = isTeam1 ? m.team1_games > m.team2_games : m.team2_games > m.team1_games
  const currentT = won ? 'W' : 'L'
  if (!streakType) streakType = currentT
  if (currentT === streakType) streak++
  else break
}

// Win rate
const matchesPlayed = profile?.matches_played ?? 0
const matchesWon = profile?.matches_won ?? 0
const winRate = matchesPlayed > 0 ? Math.round((matchesWon / matchesPlayed) * 100) : 0

// Pending challenges
const pendingChallenges = await db
  .prepare(
    `SELECT c.*, u.name as challenger_name FROM challenges c
     JOIN users u ON c.challenger_id = u.id
     WHERE c.challenged_id = ? AND c.status = 'pending'
     ORDER BY c.created_at DESC LIMIT 5`,
  )
  .bind(user.id)
  .all()

// Upcoming tournaments
const upcomingTournaments = await db
  .prepare(
    `SELECT t.id, t.name, t.location, t.event_date, t.status,
       (SELECT COUNT(*) FROM tournament_players tp WHERE tp.tournament_id = t.id) as player_count
     FROM tournament_players tp2
     JOIN tournaments t ON tp2.tournament_id = t.id
     WHERE tp2.user_id = ? AND t.status = 'open'
     ORDER BY t.event_date ASC LIMIT 3`,
  )
  .bind(user.id)
  .all()

// Badges
const wr = matchesPlayed > 0 ? (matchesWon / matchesPlayed) * 100 : 0
const ratingGain =
  (ratingHist.results?.length ?? 0) > 0
    ? Number((ratingHist.results as any[])[0].new_rating) -
      Number((ratingHist.results as any[])[(ratingHist.results as any[]).length - 1].old_rating)
    : 0
const bestStreak = (() => {
  let best = 0,
    cur = 0
  for (const m of (recentMatches.results ?? []) as any[]) {
    const isT1 = m.team1_player1 === user.id || m.team1_player2 === user.id
    const won = isT1 ? m.team1_games > m.team2_games : m.team2_games > m.team1_games
    if (won) {
      cur++
      if (cur > best) best = cur
    } else cur = 0
  }
  return best
})()
const tournamentsCount = upcomingTournaments.results?.length ?? 0
const badges = [
  { icon: '⚡', name: 'Primer partido', earned: matchesPlayed >= 1 },
  { icon: '🏆', name: 'Primera victoria', earned: matchesWon >= 1 },
  { icon: '🔥', name: '10 Victorias', earned: matchesWon >= 10 },
  { icon: '💎', name: '25 Victorias', earned: matchesWon >= 25 },
  { icon: '🎯', name: 'Precisión 60%+', earned: matchesPlayed >= 10 && wr >= 60 },
  { icon: '🔥', name: 'Racha de 5', earned: bestStreak >= 5 },
  { icon: '🏅', name: 'Torneísta', earned: tournamentsCount >= 1 },
  { icon: '📈', name: 'En ascenso +1.0', earned: ratingGain >= 1.0 },
]
const earnedBadges = badges.filter((b) => b.earned)

const isAdmin = user.role === 'admin'
const errorParam = Astro.url.searchParams.get('error')
---

<AppLayout title="Dashboard" user={user}>
  <div class="mb-8">
    <h1 class="font-display text-2xl font-extrabold mb-1 text-navy">Hola, {user.name}</h1>
    <p class="text-sm text-muted">Tu centro de control en Score Padel.</p>
    {
      isAdmin && (
        <span class="inline-flex items-center gap-1.5 mt-2 px-3 py-1 bg-coral/10 text-coral text-xs font-bold rounded-full">
          Administrador
        </span>
      )
    }
  </div>

  <!-- Hero actions: Registrar partido & Buscar jugadores -->
  <div class="grid sm:grid-cols-2 gap-4 mb-8">
    <a
      href="/app/partidos/crear"
      class="relative overflow-hidden rounded-2xl p-6 bg-linear-to-br from-coral to-coral-dark text-white shadow-lg shadow-coral/20 hover:shadow-xl hover:shadow-coral/30 hover:-translate-y-0.5 transition-all group block"
    >
      <div
        class="absolute top-0 right-0 w-32 h-32 bg-white/5 rounded-full -translate-y-8 translate-x-8"
      >
      </div>
      <div class="relative">
        <div class="w-12 h-12 rounded-xl bg-white/15 flex items-center justify-center mb-4">
          <svg
            class="w-6 h-6"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"></path>
          </svg>
        </div>
        <h2 class="font-display text-lg font-extrabold mb-1">Crear partido</h2>
        <p class="text-sm text-white/70">
          Organiza un partido 2 vs 2 y registra el resultado al terminar.
        </p>
      </div>
    </a>
    <a
      href="/app/jugadores"
      class="relative overflow-hidden rounded-2xl p-6 border-2 border-coral/30 bg-coral/5 text-navy hover:border-coral hover:bg-coral/10 hover:-translate-y-0.5 transition-all group block"
    >
      <div
        class="absolute top-0 right-0 w-32 h-32 bg-coral/5 rounded-full -translate-y-8 translate-x-8"
      >
      </div>
      <div class="relative">
        <div class="w-12 h-12 rounded-xl bg-coral/10 flex items-center justify-center mb-4">
          <svg
            class="w-6 h-6 text-coral"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z"
            ></path>
          </svg>
        </div>
        <h2 class="font-display text-lg font-extrabold mb-1">Buscar jugadores</h2>
        <p class="text-sm text-muted">
          Encuentra rivales de tu nivel cerca de ti en cualquier lugar.
        </p>
      </div>
    </a>
  </div>

  <!-- Stats grid -->
  <div class="grid sm:grid-cols-2 lg:grid-cols-5 gap-4 mb-8 stagger">
    <div class="card p-6">
      <div class="text-xs text-muted font-medium mb-2">Tu valoración</div>
      <div class="font-display text-3xl font-extrabold text-coral">{rating}</div>
      <div class="text-xs text-muted mt-1">{level.nombre}</div>
    </div>
    <div class="card p-6">
      <div class="text-xs text-muted font-medium mb-2">División</div>
      <div class="font-display text-3xl font-extrabold text-navy">{level.div}</div>
      <div class="text-xs text-muted mt-1">
        {level.div === 'A' ? 'Élite' : level.div === 'B' ? 'Competitiva' : 'Iniciación'}
      </div>
    </div>
    <div class="card p-6">
      <div class="text-xs text-muted font-medium mb-2">Partidos</div>
      <div class="font-display text-3xl font-extrabold text-navy">
        {profile?.matches_played ?? 0}
      </div>
    </div>
    <div class="card p-6">
      <div class="text-xs text-muted font-medium mb-2">Victorias</div>
      <div class="font-display text-3xl font-extrabold text-teal">{profile?.matches_won ?? 0}</div>
      <div class="text-xs text-muted mt-1">
        {matchesPlayed > 0 ? `${winRate}% win rate` : 'Sin partidos'}
      </div>
    </div>
    <div class="card p-6">
      <div class="text-xs text-muted font-medium mb-2">Racha actual</div>
      <div
        class="font-display text-3xl font-extrabold"
        class:list={[streakType === 'W' ? 'text-teal' : streak > 0 ? 'text-red-500' : 'text-navy']}
      >
        {streak > 0 ? `${streak}${streakType}` : '—'}
      </div>
      <div class="text-xs text-muted mt-1">
        {
          streakType === 'W'
            ? 'Victorias seguidas'
            : streakType === 'L'
              ? 'Derrotas seguidas'
              : 'Juega tu primer partido'
        }
      </div>
    </div>
  </div>

  <!-- Progress to next level -->
  {
    currentRating < 7.0 && (
      <div class="card p-5 mb-8">
        <div class="flex items-center justify-between mb-2">
          <div class="text-xs font-medium text-navy">
            Progreso hacia <span class="text-coral">{nextLevel.nombre}</span>
          </div>
          <div class="text-xs text-muted">
            {currentRating.toFixed(1)} / {nextThreshold.toFixed(1)}
          </div>
        </div>
        <div class="w-full h-2.5 bg-gray-100 rounded-full overflow-hidden">
          <div
            class="h-full bg-coral rounded-full transition-all"
            style={`width: ${progressPct}%`}
          />
        </div>
        <div class="text-xs text-muted mt-1.5">
          Te faltan{' '}
          <span class="font-semibold text-navy">{(nextThreshold - currentRating).toFixed(1)}</span>{' '}
          puntos para subir a División {nextLevel.div}
        </div>
      </div>
    )
  }

  <!-- Secondary actions -->
  <div class="grid sm:grid-cols-3 gap-4 mb-8">
    <a href="/app/canchas" class="card-hover p-5 block">
      <div class="flex items-center gap-3">
        <div class="w-9 h-9 rounded-xl bg-amber/10 flex items-center justify-center shrink-0">
          <svg
            class="w-4.5 h-4.5 text-amber"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"></path>
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"
            ></path>
          </svg>
        </div>
        <div>
          <div class="text-sm font-bold text-navy">Buscar canchas</div>
          <div class="text-xs text-muted">Pistas de pádel cerca de ti.</div>
        </div>
      </div>
    </a>
    <a href="/app/clasificacion" class="card-hover p-5 block">
      <div class="flex items-center gap-3">
        <div class="w-9 h-9 rounded-xl bg-teal/10 flex items-center justify-center shrink-0">
          <svg
            class="w-4.5 h-4.5 text-teal"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M3 7.5L7.5 3m0 0L12 7.5M7.5 3v13.5m13.5-7.5L16.5 13.5m0 0L12 9m4.5 4.5V3"></path>
          </svg>
        </div>
        <div>
          <div class="text-sm font-bold text-navy">Clasificación</div>
          <div class="text-xs text-muted">Ver clasificaciones actuales.</div>
        </div>
      </div>
    </a>
    <a href="/app/comparador" class="card-hover p-5 block">
      <div class="flex items-center gap-3">
        <div class="w-9 h-9 rounded-xl bg-violet/10 flex items-center justify-center shrink-0">
          <svg
            class="w-4.5 h-4.5 text-violet"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M7.5 21L3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5"></path>
          </svg>
        </div>
        <div>
          <div class="text-sm font-bold text-navy">Comparador</div>
          <div class="text-xs text-muted">Compara jugadores.</div>
        </div>
      </div>
    </a>
  </div>

  <!-- Badges earned -->
  {
    earnedBadges.length > 0 && (
      <div class="flex flex-wrap gap-2 mb-8">
        {earnedBadges.map((b) => (
          <span class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-amber-50 border border-amber-200 rounded-full text-xs font-medium text-amber-700">
            <span>{b.icon}</span>
            {b.name}
          </span>
        ))}
      </div>
    )
  }

  <!-- Pending challenges -->
  {
    (pendingChallenges.results?.length ?? 0) > 0 && (
      <div class="card p-5 mb-6 border-l-4 border-l-amber-400">
        <h2 class="font-display text-sm font-bold text-navy uppercase tracking-wider mb-3 flex items-center gap-2">
          <span>⚔️</span> Retos pendientes
        </h2>
        <div class="space-y-2">
          {(pendingChallenges.results as any[]).map((c: any) => (
            <a
              href={`/app/jugadores/${c.challenger_id}`}
              class="flex items-center justify-between p-3 rounded-xl bg-amber-50 hover:bg-amber-100 transition-colors"
            >
              <div class="text-sm text-navy font-medium">{c.challenger_name} te ha retado</div>
              <div class="flex items-center gap-2">
                {c.proposed_date && (
                  <span class="text-[11px] text-muted">
                    {new Date(c.proposed_date).toLocaleDateString('es', {
                      day: 'numeric',
                      month: 'short',
                    })}
                  </span>
                )}
                <span class="text-coral text-xs font-semibold">Ver →</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    )
  }

  <!-- Upcoming tournaments -->
  {
    (upcomingTournaments.results?.length ?? 0) > 0 && (
      <div class="card p-5 mb-6">
        <h2 class="font-display text-sm font-bold text-navy uppercase tracking-wider mb-3 flex items-center gap-2">
          <span>🏆</span> Tus próximos torneos
        </h2>
        <div class="space-y-2">
          {(upcomingTournaments.results as any[]).map((t: any) => (
            <a
              href={`/app/torneos/${t.id}`}
              class="flex items-center justify-between p-3 rounded-xl bg-surface-2 border border-gray-100 hover:border-coral/30 transition-colors"
            >
              <div>
                <div class="text-sm font-medium text-navy">{t.name}</div>
                <div class="text-[11px] text-muted">
                  {t.location} · {t.player_count} jugadores
                </div>
              </div>
              {t.event_date && (
                <span class="text-xs text-muted">
                  {new Date(t.event_date).toLocaleDateString('es', {
                    day: 'numeric',
                    month: 'short',
                  })}
                </span>
              )}
            </a>
          ))}
        </div>
      </div>
    )
  }

  <!-- Recent matches with names -->
  <div class="card p-6">
    <h2 class="font-display text-base font-bold text-navy mb-4">Partidos recientes</h2>
    {
      (recentMatches.results?.length ?? 0) === 0 ? (
        <p class="text-sm text-muted">
          Aún no has registrado ningún partido.{' '}
          <a href="/app/partidos/registrar" class="text-coral hover:underline">
            Registra tu primero
          </a>
          .
        </p>
      ) : (
        <div class="space-y-2">
          {recentMatches.results?.map((m: any) => {
            const isTeam1 = m.team1_player1 === user.id || m.team1_player2 === user.id
            const won = isTeam1 ? m.team1_games > m.team2_games : m.team2_games > m.team1_games
            const draw = m.team1_games === m.team2_games
            return (
              <div class="flex items-center justify-between p-3 rounded-xl bg-surface-2 border border-gray-100">
                <div class="flex items-center gap-3">
                  <div
                    class:list={[
                      'w-2 h-2 rounded-full shrink-0',
                      won ? 'bg-teal' : draw ? 'bg-amber-400' : 'bg-red-400',
                    ]}
                  />
                  <div>
                    <div class="text-sm text-navy">
                      <span class:list={[isTeam1 ? 'font-semibold' : '']}>
                        {m.t1p1_name}
                        {m.t1p2_name ? ` & ${m.t1p2_name}` : ''}
                      </span>
                      <span class="text-muted mx-1.5">vs</span>
                      <span class:list={[!isTeam1 ? 'font-semibold' : '']}>
                        {m.t2p1_name}
                        {m.t2p2_name ? ` & ${m.t2p2_name}` : ''}
                      </span>
                    </div>
                    {m.notes && (
                      <div class="text-[11px] text-muted/70 mt-0.5 italic">"{m.notes}"</div>
                    )}
                  </div>
                </div>
                <div class="flex items-center gap-3 shrink-0">
                  <span class="font-display text-sm font-bold">
                    <span
                      class:list={[m.team1_games > m.team2_games ? 'text-coral' : 'text-navy/50']}
                    >
                      {m.team1_games}
                    </span>
                    <span class="text-muted/40 mx-1">–</span>
                    <span
                      class:list={[m.team2_games > m.team1_games ? 'text-coral' : 'text-navy/50']}
                    >
                      {m.team2_games}
                    </span>
                  </span>
                  <span class="text-[10px] text-muted">
                    {new Date(m.match_date).toLocaleDateString('es', {
                      day: 'numeric',
                      month: 'short',
                    })}
                  </span>
                </div>
              </div>
            )
          })}
        </div>
      )
    }
  </div>

  <!-- Rating history -->
  {
    (ratingHist.results?.length ?? 0) > 0 && (
      <div class="card p-6 mt-6">
        <h2 class="font-display text-base font-bold text-navy mb-4">Evolución de valoración</h2>
        {(() => {
          const points = (ratingHist.results ?? []).map((h: any) => Number(h.new_rating)).reverse()
          if (points.length < 2) return null
          const min = Math.min(...points) - 0.1
          const max = Math.max(...points) + 0.1
          const range = max - min || 1
          const w = 400
          const h = 120
          const coords = points.map((v: number, i: number) => {
            const x = (i / (points.length - 1)) * w
            const y = h - ((v - min) / range) * h
            return `${x},${y}`
          })
          const polyline = coords.join(' ')
          const areaPath = `M0,${h} ${coords.map((c: string, i: number) => `L${c}`).join(' ')} L${w},${h} Z`
          return (
            <div class="overflow-hidden">
              <svg viewBox={`-10 -10 ${w + 20} ${h + 30}`} class="w-full h-32">
                <defs>
                  <linearGradient id="chartGrad" x1="0" y1="0" x2="0" y2="1">
                    <stop offset="0%" stop-color="#FF6A00" stop-opacity="0.2" />
                    <stop offset="100%" stop-color="#FF6A00" stop-opacity="0" />
                  </linearGradient>
                </defs>
                <path d={areaPath} fill="url(#chartGrad)" />
                <polyline
                  points={polyline}
                  fill="none"
                  stroke="#FF6A00"
                  stroke-width="2.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
                {points.map((v: number, i: number) => {
                  const x = (i / (points.length - 1)) * w
                  const y = h - ((v - min) / range) * h
                  return (
                    <circle cx={x} cy={y} r="3.5" fill="white" stroke="#FF6A00" stroke-width="2" />
                  )
                })}
                {/* Y-axis labels */}
                <text x="-8" y="8" text-anchor="end" class="text-[10px]" fill="#6B7280">
                  {max.toFixed(1)}
                </text>
                <text x="-8" y={h + 4} text-anchor="end" class="text-[10px]" fill="#6B7280">
                  {min.toFixed(1)}
                </text>
              </svg>
            </div>
          )
        })()}
        <div class="space-y-2 mt-2">
          {ratingHist.results?.map((h: any) => (
            <div class="flex items-center justify-between p-3 rounded-xl bg-surface-2 border border-gray-100">
              <div class="text-sm">
                <span class="text-muted">{Number(h.old_rating).toFixed(1)}</span>
                <span class="text-muted mx-2">→</span>
                <span
                  class:list={[
                    Number(h.new_rating) > Number(h.old_rating) ? 'text-teal' : 'text-red-500',
                    'font-semibold',
                  ]}
                >
                  {Number(h.new_rating).toFixed(1)}
                </span>
              </div>
              <div class="text-xs text-muted">
                {new Date(h.created_at).toLocaleDateString('es')}
              </div>
            </div>
          ))}
        </div>
      </div>
    )
  }

