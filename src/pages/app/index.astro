---
import AppLayout from '../../layouts/AppLayout.astro'
import { getProfile } from '../../lib/db'

const user = (Astro.locals as any).user
if (!user) return Astro.redirect('/login')

const db = (Astro.locals as any).db
const profile = await getProfile(db, user.id)

const ratingLevel = (r: number) => {
  if (r < 2.0) return { nombre: 'Iniciación Pádel', div: 'C' }
  if (r < 2.5) return { nombre: 'Consistencia Inicial', div: 'C' }
  if (r < 3.0) return { nombre: 'Precisión en Desarrollo', div: 'C' }
  if (r < 3.5) return { nombre: 'Confianza Intermedia', div: 'C' }
  if (r < 4.0) return { nombre: 'Control y Ritmo', div: 'B' }
  if (r < 4.5) return { nombre: 'Estrategas del Pádel', div: 'B' }
  if (r < 5.0) return { nombre: 'Jugadores Ingeniosos', div: 'B' }
  if (r < 5.5) return { nombre: 'Competidores de Torneo', div: 'B' }
  if (r < 6.0) return { nombre: 'Estrellas Nacionales', div: 'B' }
  if (r < 6.5) return { nombre: 'Semiprofesionales en Ascenso', div: 'A' }
  if (r < 7.0) return { nombre: 'Profesionales de Élite', div: 'A' }
  return { nombre: 'Élite Mundial del Pádel', div: 'A' }
}

const level = ratingLevel(profile?.rating ?? 1.0)
const rating = profile?.rating?.toFixed(1) ?? '1.0'

// Progress toward next level
const levelThresholds = [2.0, 2.5, 3.0, 3.5, 4.0, 4.5, 5.0, 5.5, 6.0, 6.5, 7.0]
const currentRating = profile?.rating ?? 1.0
const nextThreshold = levelThresholds.find((t) => t > currentRating) ?? 7.0
const prevThreshold = [...levelThresholds].reverse().find((t) => t <= currentRating) ?? 1.0
const progressPct =
  nextThreshold === prevThreshold
    ? 100
    : Math.round(((currentRating - prevThreshold) / (nextThreshold - prevThreshold)) * 100)
const nextLevel = ratingLevel(nextThreshold)

const recentMatches = await db
  .prepare(
    `
  SELECT m.*, m.created_at as match_date FROM matches m
  WHERE m.team1_player1 = ? OR m.team1_player2 = ? OR m.team2_player1 = ? OR m.team2_player2 = ?
  ORDER BY m.created_at DESC LIMIT 5
`,
  )
  .bind(user.id, user.id, user.id, user.id)
  .all()

const ratingHist = await db
  .prepare(
    `
  SELECT old_rating, new_rating, created_at FROM rating_history
  WHERE user_id = ? ORDER BY created_at DESC LIMIT 10
`,
  )
  .bind(user.id)
  .all()

const isGuest = user.role === 'guest'
const isAdmin = user.role === 'admin'
const errorParam = Astro.url.searchParams.get('error')
---

<AppLayout title="Dashboard" user={user}>
  <div class="mb-8">
    <h1 class="font-display text-2xl font-extrabold mb-1 text-navy">Hola, {user.name}</h1>
    <p class="text-sm text-muted">Tu centro de control en Score Padel.</p>
    {
      isAdmin && (
        <span class="inline-flex items-center gap-1.5 mt-2 px-3 py-1 bg-coral/10 text-coral text-xs font-bold rounded-full">
          Administrador
        </span>
      )
    }
  </div>

  {
    errorParam === 'guest' && (
      <div class="mb-6 p-4 rounded-xl bg-amber/10 border border-amber/20 text-sm text-amber-700">
        Tu cuenta de invitado no tiene acceso a esta función.{' '}
        <a href="/registro" class="underline font-semibold">
          Crea una cuenta completa
        </a>{' '}
        para desbloquear todas las funciones.
      </div>
    )
  }

  {
    isGuest && (
      <div class="mb-6 p-4 rounded-xl bg-teal/10 border border-teal/20 text-sm text-teal">
        Estás usando una <strong>cuenta de invitado</strong>. Puedes explorar la plataforma, ver
        clasificaciones y jugadores, pero no podrás registrar partidos, crear torneos ni editar tu
        perfil.{' '}
        <a href="/registro" class="underline font-semibold">
          Regístrate
        </a>{' '}
        para acceder a todo.
      </div>
    )
  }

  <!-- Stats grid -->
  <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
    <div class="card p-6">
      <div class="text-xs text-muted font-medium mb-2">Tu valoración</div>
      <div class="font-display text-3xl font-extrabold text-coral">{rating}</div>
      <div class="text-xs text-muted mt-1">{level.nombre}</div>
    </div>
    <div class="card p-6">
      <div class="text-xs text-muted font-medium mb-2">División</div>
      <div class="font-display text-3xl font-extrabold text-navy">{level.div}</div>
      <div class="text-xs text-muted mt-1">
        {level.div === 'A' ? 'Élite' : level.div === 'B' ? 'Competitiva' : 'Iniciación'}
      </div>
    </div>
    <div class="card p-6">
      <div class="text-xs text-muted font-medium mb-2">Partidos jugados</div>
      <div class="font-display text-3xl font-extrabold text-navy">
        {profile?.matches_played ?? 0}
      </div>
    </div>
    <div class="card p-6">
      <div class="text-xs text-muted font-medium mb-2">Victorias</div>
      <div class="font-display text-3xl font-extrabold text-teal">{profile?.matches_won ?? 0}</div>
      <div class="text-xs text-muted mt-1">
        {
          (profile?.matches_played ?? 0) > 0
            ? `${Math.round(((profile?.matches_won ?? 0) / (profile?.matches_played ?? 1)) * 100)}% win rate`
            : 'Sin partidos aún'
        }
      </div>
    </div>
  </div>

  <!-- Progress to next level -->
  {
    currentRating < 7.0 && (
      <div class="card p-5 mb-8">
        <div class="flex items-center justify-between mb-2">
          <div class="text-xs font-medium text-navy">
            Progreso hacia <span class="text-coral">{nextLevel.nombre}</span>
          </div>
          <div class="text-xs text-muted">
            {currentRating.toFixed(1)} / {nextThreshold.toFixed(1)}
          </div>
        </div>
        <div class="w-full h-2.5 bg-gray-100 rounded-full overflow-hidden">
          <div
            class="h-full bg-coral rounded-full transition-all"
            style={`width: ${progressPct}%`}
          />
        </div>
        <div class="text-xs text-muted mt-1.5">
          Te faltan{' '}
          <span class="font-semibold text-navy">{(nextThreshold - currentRating).toFixed(1)}</span>{' '}
          puntos para subir a División {nextLevel.div}
        </div>
      </div>
    )
  }

  <!-- Quick actions -->
  <div class="grid sm:grid-cols-3 gap-4 mb-8">
    {
      !isGuest && (
        <a href="/app/partidos/registrar" class="card-hover p-5 block">
          <div class="text-sm font-bold text-navy mb-1">Registrar partido</div>
          <div class="text-xs text-muted">Añade un resultado para actualizar tu valoración.</div>
        </a>
      )
    }
    {
      !isGuest && (
        <a href="/app/torneos/crear" class="card-hover p-5 block">
          <div class="text-sm font-bold text-navy mb-1">Crear torneo</div>
          <div class="text-xs text-muted">Organiza una competición en tu zona.</div>
        </a>
      )
    }
    <a href="/app/jugadores" class="card-hover p-5 block">
      <div class="text-sm font-bold text-navy mb-1">Buscar jugadores</div>
      <div class="text-xs text-muted">Encuentra rivales de tu nivel cerca de ti.</div>
    </a>
  </div>

  <!-- Recent matches -->
  <div class="card p-6">
    <h2 class="font-display text-base font-bold text-navy mb-4">Partidos recientes</h2>
    {
      (recentMatches.results?.length ?? 0) === 0 ? (
        <p class="text-sm text-muted">
          Aún no has registrado ningún partido.{' '}
          <a href="/app/partidos/registrar" class="text-coral hover:underline">
            Registra tu primero
          </a>
          .
        </p>
      ) : (
        <div class="space-y-2">
          {recentMatches.results?.map((m: any) => (
            <div class="flex items-center justify-between p-3 rounded-xl bg-surface-2 border border-gray-100">
              <div class="text-sm text-navy">
                Equipo 1 ({m.team1_games}g) vs Equipo 2 ({m.team2_games}g)
              </div>
              <div class="text-xs text-muted">
                {new Date(m.match_date).toLocaleDateString('es')}
              </div>
            </div>
          ))}
        </div>
      )
    }
  </div>

  <!-- Rating history -->
  {
    (ratingHist.results?.length ?? 0) > 0 && (
      <div class="card p-6 mt-6">
        <h2 class="font-display text-base font-bold text-navy mb-4">Evolución de valoración</h2>
        <div class="space-y-2">
          {ratingHist.results?.map((h: any) => (
            <div class="flex items-center justify-between p-3 rounded-xl bg-surface-2 border border-gray-100">
              <div class="text-sm">
                <span class="text-muted">{Number(h.old_rating).toFixed(1)}</span>
                <span class="text-muted mx-2">→</span>
                <span
                  class:list={[
                    Number(h.new_rating) > Number(h.old_rating) ? 'text-teal' : 'text-red-500',
                    'font-semibold',
                  ]}
                >
                  {Number(h.new_rating).toFixed(1)}
                </span>
              </div>
              <div class="text-xs text-muted">
                {new Date(h.created_at).toLocaleDateString('es')}
              </div>
            </div>
          ))}
        </div>
      </div>
    )
  }
</AppLayout>
