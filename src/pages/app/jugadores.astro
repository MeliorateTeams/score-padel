---
import AppLayout from '../../layouts/AppLayout.astro'
import { createUser } from '../../lib/db'

const user = (Astro.locals as any).user
if (!user) return Astro.redirect('/login')

const db = (Astro.locals as any).db
let createMsg = ''
let createErr = ''

// Handle create player (admin only)
if (Astro.request.method === 'POST' && user.role === 'admin') {
  const form = await Astro.request.formData()
  const name = form.get('name')?.toString().trim()
  const email = form.get('email')?.toString().trim().toLowerCase()
  const password = form.get('password')?.toString()

  if (!name || !email || !password) {
    createErr = 'Rellena nombre, email y contraseña.'
  } else if (password.length < 8) {
    createErr = 'La contraseña debe tener mínimo 8 caracteres.'
  } else if (!/[A-Z]/.test(password) || !/[a-z]/.test(password) || !/[0-9]/.test(password)) {
    createErr = 'La contraseña debe incluir mayúsculas, minúsculas y números.'
  } else {
    const safeName = (name ?? '').replace(/<[^>]*>/g, '').trim()
    try {
      await createUser(db, email, password, safeName)
      createMsg = `Jugador "${name}" creado correctamente.`
    } catch (e: any) {
      if (e.message?.includes('UNIQUE')) {
        createErr = 'Ya existe un usuario con ese email.'
      } else {
        createErr = 'Error al crear el jugador.'
      }
    }
  }
}

const search = Astro.url.searchParams.get('q') ?? ''
const locationFilter = Astro.url.searchParams.get('location') ?? ''
const divisionFilter = Astro.url.searchParams.get('division') ?? ''
const page = Math.max(1, parseInt(Astro.url.searchParams.get('page') ?? '1'))
const perPage = 18

let query = `
  SELECT u.id, u.name, u.email, p.rating, p.location, p.matches_played, p.experience_years
  FROM users u
  LEFT JOIN profiles p ON u.id = p.user_id
  WHERE u.id != ?
    AND u.role != 'guest' AND u.role != 'suspended'
`
let countQuery = `
  SELECT COUNT(*) as total
  FROM users u
  LEFT JOIN profiles p ON u.id = p.user_id
  WHERE u.id != ?
    AND u.role != 'guest' AND u.role != 'suspended'
`
const params: any[] = [user.id]
const countParams: any[] = [user.id]

if (search && search.length <= 50) {
  const safeSearch = search.replace(/%/g, '\\%').replace(/_/g, '\\_')
  query += " AND (u.name LIKE ? ESCAPE '\\' OR u.email LIKE ? ESCAPE '\\')"
  countQuery += " AND (u.name LIKE ? ESCAPE '\\' OR u.email LIKE ? ESCAPE '\\')"
  params.push(`%${safeSearch}%`, `%${safeSearch}%`)
  countParams.push(`%${safeSearch}%`, `%${safeSearch}%`)
}
if (locationFilter && locationFilter.length <= 50) {
  const safeLoc = locationFilter.replace(/%/g, '\\%').replace(/_/g, '\\_')
  query += " AND p.location LIKE ? ESCAPE '\\'"
  countQuery += " AND p.location LIKE ? ESCAPE '\\'"
  params.push(`%${safeLoc}%`)
  countParams.push(`%${safeLoc}%`)
}
if (divisionFilter === 'C') {
  query += ' AND p.rating < 3.5'
  countQuery += ' AND p.rating < 3.5'
} else if (divisionFilter === 'B') {
  query += ' AND p.rating >= 3.5 AND p.rating < 6.0'
  countQuery += ' AND p.rating >= 3.5 AND p.rating < 6.0'
} else if (divisionFilter === 'A') {
  query += ' AND p.rating >= 6.0'
  countQuery += ' AND p.rating >= 6.0'
}

const totalResult = await db
  .prepare(countQuery)
  .bind(...countParams)
  .first()
const total = (totalResult as any)?.total ?? 0
const totalPages = Math.max(1, Math.ceil(total / perPage))
const offset = (page - 1) * perPage

query += ` ORDER BY p.rating DESC LIMIT ${perPage} OFFSET ${offset}`

const players = await db
  .prepare(query)
  .bind(...params)
  .all()

function buildPageUrl(p: number) {
  const u = new URL(Astro.url)
  u.searchParams.set('page', String(p))
  return u.pathname + u.search
}

// Pre-compute pagination numbers with ellipsis
const pageNumbers: (number | null)[] = []
const allPages = Array.from({ length: totalPages }, (_, i) => i + 1).filter(
  (p) => p === 1 || p === totalPages || Math.abs(p - page) <= 2,
)
for (let i = 0; i < allPages.length; i++) {
  if (i > 0 && allPages[i] - allPages[i - 1] > 1) pageNumbers.push(null)
  pageNumbers.push(allPages[i])
}
---

<AppLayout title="Jugadores" user={user}>
  <div>
    <div class="flex items-center justify-between mb-8">
      <div>
        <h1 class="font-display text-2xl font-bold mb-1">Jugadores</h1>
        <p class="text-sm text-muted">Encuentra jugadores o crea nuevos perfiles.</p>
      </div>
      {
        user.role === 'admin' && (
          <button
            type="button"
            onclick="document.getElementById('create-panel').classList.toggle('hidden')"
            class="px-5 py-2.5 bg-coral text-white text-sm font-semibold rounded-full hover:bg-coral-dark transition-colors flex items-center gap-2"
          >
            <svg
              class="w-4 h-4"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
            </svg>
            Crear jugador
          </button>
        )
      }
    </div>

    {
      createMsg && (
        <div data-toast="success" class="hidden">
          {createMsg}
        </div>
      )
    }
    {
      createErr && (
        <div data-toast="error" class="hidden">
          {createErr}
        </div>
      )
    }

    {
      user.role === 'admin' && (
        <div id="create-panel" class:list={['card p-6 mb-6', !createErr ? 'hidden' : '']}>
          <h2 class="font-display text-sm font-bold text-navy uppercase tracking-wider flex items-center gap-2 mb-4">
            <svg
              class="w-4 h-4 text-coral"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M19 7.5v3m0 0v3m0-3h3m-3 0h-3m-2.25-4.125a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zM4 19.235v-.11a6.375 6.375 0 0112.75 0v.109A12.318 12.318 0 0110.374 21c-2.331 0-4.512-.645-6.374-1.766z"
              />
            </svg>
            Crear nuevo jugador
          </h2>
          <form method="POST" class="grid sm:grid-cols-3 gap-4">
            <div>
              <label class="text-xs font-medium text-muted block mb-1.5">Nombre</label>
              <input
                type="text"
                name="name"
                required
                placeholder="Nombre completo"
                class="w-full px-3.5 py-2.5 bg-white border border-gray-200 rounded-xl text-sm text-navy placeholder:text-muted/50 focus:outline-none focus:border-coral/50 transition-colors"
              />
            </div>
            <div>
              <label class="text-xs font-medium text-muted block mb-1.5">Email</label>
              <input
                type="email"
                name="email"
                required
                placeholder="email@ejemplo.com"
                class="w-full px-3.5 py-2.5 bg-white border border-gray-200 rounded-xl text-sm text-navy placeholder:text-muted/50 focus:outline-none focus:border-coral/50 transition-colors"
              />
            </div>
            <div>
              <label class="text-xs font-medium text-muted block mb-1.5">Contraseña</label>
              <div class="flex gap-2">
                <input
                  type="text"
                  name="password"
                  required
                  placeholder="Mínimo 8 caracteres"
                  class="flex-1 px-3.5 py-2.5 bg-white border border-gray-200 rounded-xl text-sm text-navy placeholder:text-muted/50 focus:outline-none focus:border-coral/50 transition-colors"
                />
                <button
                  type="submit"
                  class="px-4 py-2.5 bg-coral text-white text-sm font-semibold rounded-xl hover:bg-coral-dark transition-colors whitespace-nowrap"
                >
                  Crear
                </button>
              </div>
            </div>
          </form>
        </div>
      )
    }

    <form method="GET" class="flex flex-wrap gap-3 mb-8" id="players-filter-form">
      <div class="relative flex-1 min-w-50">
        <input
          type="text"
          id="players-filter-search"
          name="q"
          value={search}
          autocomplete="off"
          placeholder="Nombre o email del jugador..."
          class="w-full px-3.5 py-2.5 bg-white border border-gray-200 rounded-xl text-sm text-navy placeholder:text-muted/50 focus:outline-none focus:border-coral/50 transition-colors"
        />
        <div
          id="players-filter-results"
          class="hidden absolute left-0 right-0 top-full mt-1 z-20 bg-white border border-gray-200 rounded-xl shadow-lg max-h-56 overflow-y-auto"
        >
        </div>
      </div>
      <input
        type="text"
        name="location"
        value={locationFilter}
        placeholder="Ciudad o país..."
        class="flex-1 min-w-50 px-3.5 py-2.5 bg-white border border-gray-200 rounded-xl text-sm text-navy placeholder:text-muted/50 focus:outline-none focus:border-coral/50 transition-colors"
      />
      <select
        name="division"
        class="px-3.5 py-2.5 bg-white border border-gray-200 rounded-xl text-sm text-navy focus:outline-none focus:border-coral/50 transition-colors"
      >
        <option value="">Todas las divisiones</option>
        <option value="C" selected={divisionFilter === 'C'}>División C (1.0-3.0)</option>
        <option value="B" selected={divisionFilter === 'B'}>División B (3.5-5.5)</option>
        <option value="A" selected={divisionFilter === 'A'}>División A (6.0-7.0)</option>
      </select>
      <button
        type="submit"
        class="px-5 py-2.5 bg-coral text-white text-sm font-semibold rounded-full hover:bg-coral-dark transition-colors"
      >
        Buscar
      </button>
    </form>

    {
      (players.results?.length ?? 0) === 0 ? (
        <div class="card rounded-xl p-10 text-center">
          <p class="text-muted">No se encontraron jugadores{search ? ` con "${search}"` : ''}.</p>
        </div>
      ) : (
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 stagger">
          {players.results?.map((p: any) => (
            <a href={`/app/jugadores/${p.id}`} class="card-hover hover-lift p-5 block">
              <div class="flex items-center justify-between mb-2">
                <h3 class="text-sm font-semibold text-navy">{p.name}</h3>
                <span class="font-display text-sm font-bold text-coral">
                  {Number(p.rating || 1).toFixed(1)}
                </span>
              </div>
              <div class="text-xs text-muted">{p.location || 'Sin ubicación'}</div>
              <div class="flex items-center gap-3 mt-2 text-xs text-muted">
                <span>{p.matches_played ?? 0} partidos</span>
                <span>{p.experience_years ?? 0} años exp.</span>
              </div>
            </a>
          ))}
        </div>
      )
    }

    {
      totalPages > 1 && (
        <nav class="flex items-center justify-center gap-2 mt-8" aria-label="Paginación">
          {page > 1 && (
            <a
              href={buildPageUrl(page - 1)}
              class="px-3.5 py-2 text-sm font-medium text-navy bg-white border border-gray-200 rounded-xl hover:bg-gray-50 transition-colors"
            >
              ← Anterior
            </a>
          )}
          {pageNumbers.map((p) =>
            p === null ? (
              <span class="px-2 text-muted text-sm">…</span>
            ) : (
              <a
                href={buildPageUrl(p)}
                class:list={[
                  'w-9 h-9 flex items-center justify-center text-sm font-medium rounded-xl transition-colors',
                  p === page
                    ? 'bg-coral text-white'
                    : 'bg-white border border-gray-200 text-navy hover:bg-gray-50',
                ]}
                aria-current={p === page ? 'page' : undefined}
              >
                {p}
              </a>
            ),
          )}
          {page < totalPages && (
            <a
              href={buildPageUrl(page + 1)}
              class="px-3.5 py-2 text-sm font-medium text-navy bg-white border border-gray-200 rounded-xl hover:bg-gray-50 transition-colors"
            >
              Siguiente →
            </a>
          )}
        </nav>
      )
    }

    <p class="text-center text-xs text-muted mt-4">{total} jugadores encontrados</p>
  </div>

  <script>
    const searchInput = document.getElementById('players-filter-search') as HTMLInputElement | null
    const resultsBox = document.getElementById('players-filter-results') as HTMLElement | null
    if (searchInput && resultsBox) {
      let timer: ReturnType<typeof setTimeout>

      searchInput.addEventListener('input', () => {
        clearTimeout(timer)
        const q = searchInput.value.trim()
        if (q.length < 2) {
          resultsBox.classList.add('hidden')
          return
        }

        timer = setTimeout(async () => {
          const res = await fetch(`/api/players/search?q=${encodeURIComponent(q)}`)
          const players = (await res.json()) as {
            id: string
            name: string
            email: string
            rating: string
            location: string
          }[]

          if (players.length === 0) {
            resultsBox.innerHTML = '<div class="px-3 py-2 text-xs text-muted">Sin resultados</div>'
          } else {
            resultsBox.innerHTML = players
              .map(
                (p) => `
              <a href="/app/jugadores/${p.id}" class="w-full text-left px-3 py-2 hover:bg-coral/5 flex items-center gap-2 transition-colors block">
                <span class="w-6 h-6 rounded-lg bg-coral/10 flex items-center justify-center text-[10px] font-bold text-coral shrink-0">${p.name.charAt(0).toUpperCase()}</span>
                <span class="flex-1 min-w-0">
                  <span class="text-xs font-medium text-navy block truncate">${p.name}</span>
                  <span class="text-[10px] text-muted block truncate">${p.location || p.email}</span>
                </span>
                <span class="text-[10px] font-bold text-coral shrink-0">${p.rating}</span>
              </a>
            `,
              )
              .join('')
          }

          resultsBox.classList.remove('hidden')
        }, 250)
      })

      document.addEventListener('click', (e) => {
        if (!searchInput.closest('form')?.contains(e.target as Node)) {
          resultsBox.classList.add('hidden')
        }
      })
    }
  </script>
</AppLayout>
