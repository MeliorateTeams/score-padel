---
import AppLayout from '../../layouts/AppLayout.astro'
import { createUser } from '../../lib/db'

const user = (Astro.locals as any).user
if (!user) return Astro.redirect('/login')

const db = (Astro.locals as any).db
let createMsg = ''
let createErr = ''

// Handle create player (admin only)
if (Astro.request.method === 'POST' && user.role === 'admin') {
  const form = await Astro.request.formData()
  const name = form.get('name')?.toString().trim()
  const email = form.get('email')?.toString().trim().toLowerCase()
  const password = form.get('password')?.toString()

  if (!name || !email || !password) {
    createErr = 'Rellena nombre, email y contraseña.'
  } else if (password.length < 8) {
    createErr = 'La contraseña debe tener mínimo 8 caracteres.'
  } else {
    try {
      await createUser(db, email, password, name)
      createMsg = `Jugador "${name}" creado correctamente.`
    } catch (e: any) {
      if (e.message?.includes('UNIQUE')) {
        createErr = 'Ya existe un usuario con ese email.'
      } else {
        createErr = 'Error al crear el jugador.'
      }
    }
  }
}

const search = Astro.url.searchParams.get('q') ?? ''
const locationFilter = Astro.url.searchParams.get('location') ?? ''
const divisionFilter = Astro.url.searchParams.get('division') ?? ''

let query = `
  SELECT u.id, u.name, p.rating, p.location, p.matches_played, p.experience_years
  FROM users u
  LEFT JOIN profiles p ON u.id = p.user_id
  WHERE u.id != ?
`
const params: any[] = [user.id]

if (search) {
  query += ' AND u.name LIKE ?'
  params.push(`%${search}%`)
}
if (locationFilter) {
  query += ' AND p.location LIKE ?'
  params.push(`%${locationFilter}%`)
}
if (divisionFilter === 'C') {
  query += ' AND p.rating < 3.5'
} else if (divisionFilter === 'B') {
  query += ' AND p.rating >= 3.5 AND p.rating < 6.0'
} else if (divisionFilter === 'A') {
  query += ' AND p.rating >= 6.0'
}

query += ' ORDER BY p.rating DESC LIMIT 50'

const players = await db
  .prepare(query)
  .bind(...params)
  .all()
---

<AppLayout title="Jugadores" user={user}>
  <div>
    <div class="flex items-center justify-between mb-8">
      <div>
        <h1 class="font-display text-2xl font-bold mb-1">Jugadores</h1>
        <p class="text-sm text-muted">Encuentra jugadores o crea nuevos perfiles.</p>
      </div>
      {
        user.role === 'admin' && (
          <button
            type="button"
            onclick="document.getElementById('create-panel').classList.toggle('hidden')"
            class="px-5 py-2.5 bg-coral text-white text-sm font-semibold rounded-full hover:bg-coral-dark transition-colors flex items-center gap-2"
          >
            <svg
              class="w-4 h-4"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
            </svg>
            Crear jugador
          </button>
        )
      }
    </div>

    {
      createMsg && (
        <div class="flex items-center gap-3 bg-teal/10 border border-teal/20 text-teal text-sm p-4 rounded-xl mb-6">
          <svg
            class="w-5 h-5 shrink-0"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
            />
          </svg>
          {createMsg}
        </div>
      )
    }
    {
      createErr && (
        <div class="flex items-center gap-3 bg-red-500/10 border border-red-500/20 text-red-500 text-sm p-4 rounded-xl mb-6">
          <svg
            class="w-5 h-5 shrink-0"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z"
            />
          </svg>
          {createErr}
        </div>
      )
    }

    {
      user.role === 'admin' && (
        <div id="create-panel" class:list={['card p-6 mb-6', !createErr ? 'hidden' : '']}>
          <h2 class="font-display text-sm font-bold text-navy uppercase tracking-wider flex items-center gap-2 mb-4">
            <svg
              class="w-4 h-4 text-coral"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M19 7.5v3m0 0v3m0-3h3m-3 0h-3m-2.25-4.125a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zM4 19.235v-.11a6.375 6.375 0 0112.75 0v.109A12.318 12.318 0 0110.374 21c-2.331 0-4.512-.645-6.374-1.766z"
              />
            </svg>
            Crear nuevo jugador
          </h2>
          <form method="POST" class="grid sm:grid-cols-3 gap-4">
            <div>
              <label class="text-xs font-medium text-muted block mb-1.5">Nombre</label>
              <input
                type="text"
                name="name"
                required
                placeholder="Nombre completo"
                class="w-full px-3.5 py-2.5 bg-white border border-gray-200 rounded-xl text-sm text-navy placeholder:text-muted/50 focus:outline-none focus:border-coral/50 transition-colors"
              />
            </div>
            <div>
              <label class="text-xs font-medium text-muted block mb-1.5">Email</label>
              <input
                type="email"
                name="email"
                required
                placeholder="email@ejemplo.com"
                class="w-full px-3.5 py-2.5 bg-white border border-gray-200 rounded-xl text-sm text-navy placeholder:text-muted/50 focus:outline-none focus:border-coral/50 transition-colors"
              />
            </div>
            <div>
              <label class="text-xs font-medium text-muted block mb-1.5">Contraseña</label>
              <div class="flex gap-2">
                <input
                  type="text"
                  name="password"
                  required
                  placeholder="Mínimo 8 caracteres"
                  class="flex-1 px-3.5 py-2.5 bg-white border border-gray-200 rounded-xl text-sm text-navy placeholder:text-muted/50 focus:outline-none focus:border-coral/50 transition-colors"
                />
                <button
                  type="submit"
                  class="px-4 py-2.5 bg-coral text-white text-sm font-semibold rounded-xl hover:bg-coral-dark transition-colors whitespace-nowrap"
                >
                  Crear
                </button>
              </div>
            </div>
          </form>
        </div>
      )
    }

    <form method="GET" class="flex flex-wrap gap-3 mb-8">
      <input
        type="text"
        name="q"
        value={search}
        placeholder="Nombre del jugador..."
        class="flex-1 min-w-50 px-3.5 py-2.5 bg-white border border-gray-200 rounded-xl text-sm text-navy placeholder:text-muted/50 focus:outline-none focus:border-coral/50 transition-colors"
      />
      <input
        type="text"
        name="location"
        value={locationFilter}
        placeholder="Ciudad o país..."
        class="flex-1 min-w-50 px-3.5 py-2.5 bg-white border border-gray-200 rounded-xl text-sm text-navy placeholder:text-muted/50 focus:outline-none focus:border-coral/50 transition-colors"
      />
      <select
        name="division"
        class="px-3.5 py-2.5 bg-white border border-gray-200 rounded-xl text-sm text-navy focus:outline-none focus:border-coral/50 transition-colors"
      >
        <option value="">Todas las divisiones</option>
        <option value="C" selected={divisionFilter === 'C'}>División C (1.0-3.0)</option>
        <option value="B" selected={divisionFilter === 'B'}>División B (3.5-5.5)</option>
        <option value="A" selected={divisionFilter === 'A'}>División A (6.0-7.0)</option>
      </select>
      <button
        type="submit"
        class="px-5 py-2.5 bg-coral text-white text-sm font-semibold rounded-full hover:bg-coral-dark transition-colors"
      >
        Buscar
      </button>
    </form>

    {
      (players.results?.length ?? 0) === 0 ? (
        <div class="card rounded-xl p-10 text-center">
          <p class="text-muted">No se encontraron jugadores{search ? ` con "${search}"` : ''}.</p>
        </div>
      ) : (
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {players.results?.map((p: any) => (
            <a href={`/app/jugadores/${p.id}`} class="card-hover p-5 block">
              <div class="flex items-center justify-between mb-2">
                <h3 class="text-sm font-semibold text-navy">{p.name}</h3>
                <span class="font-display text-sm font-bold text-coral">
                  {Number(p.rating || 1).toFixed(1)}
                </span>
              </div>
              <div class="text-xs text-muted">{p.location || 'Sin ubicación'}</div>
              <div class="flex items-center gap-3 mt-2 text-xs text-muted">
                <span>{p.matches_played ?? 0} partidos</span>
                <span>{p.experience_years ?? 0} años exp.</span>
              </div>
            </a>
          ))}
        </div>
      )
    }
  </div>
</AppLayout>
