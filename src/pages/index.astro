                  </p>
                </div>
              </div>
              <!-- Globe icon: alcance global -->
              <div class="flex items-start gap-4">
                <div
                  class="w-11 h-11 rounded-xl bg-teal/10 flex items-center justify-center shrink-0"
                >
                  <svg
                    class="w-5 h-5 text-teal"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                    aria-hidden="true"
                  >
                    <circle cx="12" cy="12" r="10" stroke-width="1.75"></circle>
