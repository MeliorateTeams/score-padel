const niveles = [
  { cal: '1.0', nombre: 'Iniciación Pádel', div: 'C' },
  { cal: '2.0', nombre: 'Consistencia Inicial', div: 'C' },
  { cal: '2.5', nombre: 'Precisión en Desarrollo', div: 'C' },
  { cal: '3.0', nombre: 'Confianza Intermedia', div: 'C' },
  { cal: '3.5', nombre: 'Control y Ritmo', div: 'B' },
  { cal: '4.0', nombre: 'Estrategas del Pádel', div: 'B' },
  { cal: '4.5', nombre: 'Jugadores Ingeniosos', div: 'B' },
  { cal: '5.0', nombre: 'Competidores de Torneo', div: 'B' },
  { cal: '5.5', nombre: 'Estrellas Nacionales', div: 'B' },
  { cal: '6.0', nombre: 'Semiprofesionales en Ascenso', div: 'A' },
  { cal: '6.5', nombre: 'Profesionales de Élite', div: 'A' },
