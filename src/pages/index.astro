---

<Layout title="Score Padel — Plataforma Global de Pádel">
  <Navbar />
  <div class="hero-pattern">
    <!-- HERO -->
    <section class="relative min-h-screen flex items-center pt-20 pb-16 overflow-hidden">
      <div class="absolute top-20 right-0 w-125 h-125 bg-coral/8 rounded-full blur-[120px]"></div>
      <div class="absolute bottom-0 left-0 w-100 h-100 bg-teal/6 rounded-full blur-[100px]"></div>
      <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-8 w-full">
        <div class="grid lg:grid-cols-2 gap-10 items-center">
          <!-- Left: Text -->
          <div>
            <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-coral/10 mb-6">
              <span class="w-2 h-2 rounded-full bg-coral pulse-soft"></span>
              <span class="text-xs font-semibold text-coral tracking-wide uppercase"
                >Plataforma activa</span
              >
            </div>
            <h1
              class="font-display text-3xl sm:text-4xl lg:text-5xl font-extrabold tracking-tight leading-[1.1] mb-4 text-navy"
            >
              Eleva tu juego.<br />
              <span class="text-gradient">Forja tu legado.</span>
            </h1>
            <p class="text-base text-muted max-w-xl leading-relaxed mb-3">
              Score Padel organiza, estandariza y jerarquiza las competiciones de pádel a nivel
              mundial. Una valoración numérica basada en datos, no en opiniones.
            </p>
            <p class="text-sm text-muted/80 max-w-xl leading-relaxed mb-8">
              Únete a la comunidad global. Cada partido cuenta tu historia.
            </p>
            <div class="flex flex-wrap gap-3 mb-8">
              <a
                href="/registro"
                class="px-7 py-3.5 bg-coral text-white text-sm font-semibold rounded-full hover:bg-coral-dark transition-colors shadow-lg shadow-coral/25"
              >
                Crear cuenta gratis
              </a>
              <a
                href="#como-funciona"
                class="px-7 py-3.5 border-2 border-navy/10 text-navy text-sm font-semibold rounded-full hover:border-coral hover:text-coral transition-all"
              >
                Descubre cómo funciona
              </a>
            </div>
          </div>

          <!-- Right: Hero Image -->
          <div class="relative">
            <div class="rounded-3xl overflow-hidden shadow-2xl border border-white/20">
              <img
                src="/images/hero-padel.jpg"
                alt="Jugadora de pádel en pista"
                class="w-full h-[28rem] lg:h-[32rem] object-cover"
              />
            </div>
            <div
              class="absolute -bottom-4 -left-4 bg-coral text-white px-5 py-3 rounded-2xl shadow-lg"
            >
              <div class="font-display text-2xl font-extrabold">{totalPlayers}</div>
              <div class="text-xs font-medium opacity-90">Jugadores activos</div>
            </div>
            <div
              class="absolute -top-3 -right-3 bg-navy text-coral px-4 py-2.5 rounded-xl shadow-lg"
            >
              <div class="font-display text-lg font-extrabold">{totalMatches}</div>
              <div class="text-[10px] font-medium text-sky">Partidos jugados</div>
            </div>
          </div>
        </div>

        <!-- Data Cards below hero -->
        <div class="grid sm:grid-cols-2 gap-4 mt-16 text-left max-w-3xl mx-auto lg:max-w-none">
          <!-- Últimos partidos -->
          <div class="card p-5">
            <div class="flex items-center gap-2 mb-4">
              <div class="w-8 h-8 rounded-lg bg-coral/15 flex items-center justify-center">
                <svg
                  class="w-4 h-4 text-coral"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="1.75"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M3.75 3v11.25A2.25 2.25 0 006 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0118 16.5h-2.25m-7.5 0h7.5m-7.5 0l-1 3m8.5-3l1 3m0 0l.5 1.5m-.5-1.5h-9.5m0 0l-.5 1.5"
                  ></path>
                </svg>
              </div>
              <h3 class="font-display text-sm font-bold text-navy">Últimos partidos</h3>
            </div>
            {
              recentPublicMatches.length > 0 ? (
                <div class="space-y-2">
                  {recentPublicMatches.slice(0, 4).map((m: any) => (
                    <div
                      class="flex items-center justify-between py-2 px-3 rounded-xl"
                      style="background: rgba(15,34,64,0.08);"
                    >
                      <div class="min-w-0">
                        <div class="text-xs text-navy font-medium truncate">
                          {m.t1p1_name}
                          {m.t1p2_name ? ` & ${m.t1p2_name}` : ''}
                          <span class="text-muted mx-1">vs</span>
                          {m.t2p1_name}
                          {m.t2p2_name ? ` & ${m.t2p2_name}` : ''}
                        </div>
                      </div>
                      <div class="flex items-center gap-2 shrink-0 ml-2">
                        <span class="font-display text-xs font-bold">
                          <span class={m.team1_games > m.team2_games ? 'text-coral' : 'text-muted'}>
                            {m.team1_games}
                          </span>
                          <span class="text-muted/40 mx-0.5">–</span>
                          <span class={m.team2_games > m.team1_games ? 'text-coral' : 'text-muted'}>
                            {m.team2_games}
                          </span>
                        </span>
                      </div>
                    </div>
                  ))}
                </div>
              ) : (
                <p class="text-xs text-muted text-center py-4">Sin partidos registrados aún</p>
              )
            }
          </div>

          <!-- Próximos torneos -->
          <div class="card p-5">
            <div class="flex items-center gap-2 mb-4">
              <div class="w-8 h-8 rounded-lg bg-amber/15 flex items-center justify-center">
                <svg
                  class="w-4 h-4 text-amber"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="1.75"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M16.5 18.75h-9m9 0a3 3 0 013 3h-15a3 3 0 013-3m9 0v-4.5A3 3 0 0019.5 11.25h.75a.75.75 0 00.75-.75v-.75a.75.75 0 00-.75-.75H19.5A4.5 4.5 0 0015 4.5H9a4.5 4.5 0 00-4.5 4.5H3.75a.75.75 0 00-.75.75v.75c0 .414.336.75.75.75H4.5A3 3 0 017.5 14.25v4.5"
                  ></path>
                </svg>
              </div>
              <h3 class="font-display text-sm font-bold text-navy">Próximos torneos</h3>
            </div>
            {
              upcomingPublicTournaments.length > 0 ? (
                <div class="space-y-2">
                  {upcomingPublicTournaments.slice(0, 4).map((t: any) => (
                    <div
                      class="flex items-center justify-between py-2 px-3 rounded-xl"
                      style="background: rgba(15,34,64,0.08);"
                    >
                      <div class="min-w-0">
                        <div class="text-xs text-navy font-semibold truncate">{t.name}</div>
                        <div class="text-[10px] text-muted mt-0.5">
                          {t.location || 'Sin ubicación'} · {t.player_count} jugadores
                        </div>
                      </div>
                      <div class="shrink-0 ml-2 text-right">
                        {t.event_date && (
                          <div class="text-[10px] text-coral font-semibold">
                            {new Date(t.event_date).toLocaleDateString('es', {
                              day: 'numeric',
                              month: 'short',
                            })}
                          </div>
                        )}
                      </div>
                    </div>
                  ))}
                </div>
              ) : (
                <p class="text-xs text-muted text-center py-4">Sin torneos próximos</p>
              )
            }
          </div>
        </div>
      </div>
    </section>
  </div>

  <!-- LIVE STATS BAR -->
  <section class="py-8 border-y border-sky/20" style="background: rgba(15,34,64,0.08);">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="grid grid-cols-3 gap-8 text-center">
        <div>
          <div class="font-display text-3xl sm:text-4xl font-extrabold text-coral">
            {totalPlayers}
          </div>
          <div class="text-xs sm:text-sm text-muted font-medium mt-1">Jugadores registrados</div>
        </div>
        <div>
          <div class="font-display text-3xl sm:text-4xl font-extrabold text-teal">
            {totalMatches}
          </div>
          <div class="text-xs sm:text-sm text-muted font-medium mt-1">Partidos jugados</div>
        </div>
        <div>
          <div class="font-display text-3xl sm:text-4xl font-extrabold text-amber">
            {totalTournaments}
          </div>
          <div class="text-xs sm:text-sm text-muted font-medium mt-1">Torneos creados</div>
        </div>
      </div>
    </div>
  </section>

  <div class="deep-zone">
    <!-- QUIÉNES SOMOS -->
    <section id="quienes-somos" class="py-24">
      <div class="max-w-7xl mx-auto px-6 lg:px-8">
        <div class="grid lg:grid-cols-2 gap-16 items-center">
          <div>
            <span
              class="inline-block text-xs font-bold text-coral uppercase tracking-[0.2em] mb-4 bg-coral/10 px-3 py-1 rounded-full"
              >Quiénes somos</span
            >
            <h2
              class="font-display text-3xl sm:text-4xl font-extrabold tracking-tight mb-8 text-navy"
            >
              Transformando la escena<br />del pádel mundial
            </h2>
            <div class="space-y-5 text-muted leading-relaxed">
              <p>
                Score Padel es <span class="text-navy font-medium"
                  >la respuesta a la necesidad de transformar la escena del pádel</span
                >. Nacimos con el propósito de organizar y estandarizar las competiciones,
                jerarquizar a los jugadores y proporcionar una plataforma global donde cada
                deportista cuente su propia historia de éxito.
              </p>
              <p>
                Somos el impulso que eleva el pádel, ofreciendo <span class="text-navy font-medium"
                  >orden, sentido y comunidad</span
                > a la escena amateur y profesional apasionada por este deporte.
              </p>
              <p>
                Nuestra misión trasciende el simple juego: <span class="text-navy font-medium"
                  >empoderamos a cada jugador</span
                > brindándole la oportunidad de identificarse en su nivel y trazar sus propios caminos
                de progreso en cada evento, con visibilidad internacional.
              </p>
            </div>
          </div>
          <div>
            <div class="card p-8 space-y-6">
              <!-- Padel racket icon: valoración objetiva -->
              <div class="flex items-start gap-4">
                <div
                  class="w-11 h-11 rounded-xl bg-coral/10 flex items-center justify-center shrink-0"
                >
                  <svg
                    class="w-6 h-6 text-coral"
                    viewBox="0 0 28 40"
                    fill="none"
