const porQueUnirse = [
  {
    titulo: 'Identificación y Progreso Personalizado',
    desc: 'Gracias a nuestro sistema de valoración, cada jugador puede identificarse en su nivel y seguir su progreso de manera única. Aquí, no solo juegas, también evolucionas.',
    icon: 'M13 10V3L4 14h7v7l9-11h-7z',
    color: 'coral',
  },
  {
    titulo: 'Visibilidad Internacional',
    desc: 'Tu participación no se limita al ámbito local; tendrás visibilidad a nivel internacional. Cada golpe, cada victoria, contribuirá a tu reconocimiento global.',
    icon: 'M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
