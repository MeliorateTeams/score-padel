---
import Layout from '../layouts/Layout.astro'
import Navbar from '../components/Navbar.astro'
import Footer from '../components/Footer.astro'
import CookieBanner from '../components/CookieBanner.astro'

// Live stats
const db = (Astro.locals as any).db
let totalPlayers = 0,
  totalMatches = 0,
  totalTournaments = 0
let recentPublicMatches: any[] = []
let upcomingPublicTournaments: any[] = []
let topRanking: any[] = []
let playerLocations: any[] = []
let weeklyNewPlayers = 0
let weeklyMatches = 0
if (db) {
  const oneWeekAgo = new Date(Date.now() - 7 * 24 * 60 * 60 * 1000).toISOString()
  const [p, m, t, matches, tournaments, ranking, locations, newP, weekM] = await Promise.all([
    db.prepare('SELECT COUNT(*) as c FROM users WHERE role != ?').bind('guest').first(),
    db.prepare('SELECT COUNT(*) as c FROM matches').first(),
    db.prepare('SELECT COUNT(*) as c FROM tournaments').first(),
    db
      .prepare(
        `
      SELECT m.created_at as match_date,
        m.team1_games, m.team2_games, m.set_scores,
        u1.name as t1p1_name, u2.name as t2p1_name,
        u3.name as t1p2_name, u4.name as t2p2_name
      FROM matches m
      LEFT JOIN users u1 ON m.team1_player1 = u1.id
      LEFT JOIN users u2 ON m.team2_player1 = u2.id
      LEFT JOIN users u3 ON m.team1_player2 = u3.id
      LEFT JOIN users u4 ON m.team2_player2 = u4.id
      ORDER BY m.created_at DESC LIMIT 6
    `,
      )
      .all(),
    db
      .prepare(
        `
      SELECT t.id, t.name, t.location, t.event_date, t.status, t.max_players,
        (SELECT COUNT(*) FROM tournament_players tp WHERE tp.tournament_id = t.id) as player_count
      FROM tournaments t
      WHERE t.status = 'open'
      ORDER BY t.event_date ASC LIMIT 4
    `,
      )
      .all(),
    db
      .prepare(
        `
      SELECT u.name, p.rating, p.matches_played, p.location
      FROM profiles p
      JOIN users u ON p.user_id = u.id
      WHERE u.role != 'guest' AND p.matches_played > 0
      ORDER BY p.rating DESC LIMIT 10
    `,
      )
      .all(),
    db
      .prepare(
        `
      SELECT p.location, COUNT(*) as count
      FROM profiles p
      JOIN users u ON p.user_id = u.id
      WHERE u.role != 'guest' AND p.location IS NOT NULL AND p.location != ''
      GROUP BY p.location
      ORDER BY count DESC LIMIT 12
    `,
      )
      .all(),
    db.prepare('SELECT COUNT(*) as c FROM users WHERE created_at >= ?').bind(oneWeekAgo).first(),
    db.prepare('SELECT COUNT(*) as c FROM matches WHERE created_at >= ?').bind(oneWeekAgo).first(),
  ])
  totalPlayers = p?.c ?? 0
  totalMatches = m?.c ?? 0
  totalTournaments = t?.c ?? 0
  recentPublicMatches = (matches.results ?? []) as any[]
  upcomingPublicTournaments = (tournaments.results ?? []) as any[]
  topRanking = (ranking.results ?? []) as any[]
  playerLocations = (locations.results ?? []) as any[]
  weeklyNewPlayers = newP?.c ?? 0
  weeklyMatches = weekM?.c ?? 0
}

const faqs = [
