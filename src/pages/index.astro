---
import Layout from '../layouts/Layout.astro'
import Navbar from '../components/Navbar.astro'
import Footer from '../components/Footer.astro'
import CookieBanner from '../components/CookieBanner.astro'

const puntos = [
  {
    num: '01',
    titulo: 'Organización y estandarización',
    desc: 'Score Padel organiza, estandariza y jerarquiza las competiciones de pádel a nivel mundial, proporcionando orden y sentido a la escena amateur y profesional.',
  },
  {
    num: '02',
    titulo: 'Valoración, no ranking',
    desc: 'No entregamos un ranking por acumulación de puntos, sino una valoración numérica (1.0–7.0) basada en tu destreza, experiencia deportiva, años de práctica y estado competitivo actual.',
  },
  {
    num: '03',
    titulo: '12 niveles, 3 divisiones',
    desc: 'Cada jugador se ubica en un nivel que refleja su capacidad real, agrupado en tres divisiones: Formativa, Competitiva y Élite.',
  },
  {
    num: '04',
    titulo: 'Encontrar jugadores',
    desc: 'Busca jugadores de tu vecindario, lugar de vacaciones o la ciudad donde vives. Score Padel conecta jugadores en cualquier parte del mundo.',
  },
  {
    num: '05',
    titulo: 'Torneos con puntos globales',
    desc: 'Todos los torneos organizados con Score Padel entregan puntos para tu status mundial en todos los niveles de juego, edad y género.',
  },
  {
    num: '06',
    titulo: 'Seguimiento de partidos',
    desc: 'Cada partido registrado alimenta tu valoración automáticamente. Sets, juegos y resultados se reflejan al instante en tu clasificación.',
  },
  {
    num: '07',
    titulo: 'Algoritmo de jerarquía',
    desc: 'Tres factores determinan tu valoración: diferencia de niveles entre rivales, rendimiento vs. expectativa, y resultados recientes.',
  },
  {
    num: '08',
    titulo: 'Empoderar al jugador',
    desc: 'Nuestra misión es empoderar a cada jugador a disfrutar del juego y motivarlos a mejorar, brindándole la oportunidad de identificarse en su nivel.',
  },
  {
    num: '09',
    titulo: 'Alcance global',
    desc: 'Tu valoración te acompaña donde quiera que juegues. Sin importar el país o continente, cada punto cuenta para tu clasificación mundial.',
  },
]

const niveles = [
  { cal: '1.0', nombre: 'Iniciación Pádel', div: 'C' },
  { cal: '2.0', nombre: 'Consistencia Inicial', div: 'C' },
  { cal: '2.5', nombre: 'Precisión en Desarrollo', div: 'C' },
  { cal: '3.0', nombre: 'Confianza Intermedia', div: 'C' },
  { cal: '3.5', nombre: 'Control y Ritmo', div: 'B' },
  { cal: '4.0', nombre: 'Estrategas del Pádel', div: 'B' },
  { cal: '4.5', nombre: 'Jugadores Ingeniosos', div: 'B' },
  { cal: '5.0', nombre: 'Competidores de Torneo', div: 'B' },
  { cal: '5.5', nombre: 'Estrellas Nacionales', div: 'B' },
  { cal: '6.0', nombre: 'Semiprofesionales en Ascenso', div: 'A' },
  { cal: '6.5', nombre: 'Profesionales de Élite', div: 'A' },
  { cal: '7.0', nombre: 'Élite Mundial del Pádel', div: 'A' },
]

const porQueUnirse = [
  {
    titulo: 'Identificación y Progreso Personalizado',
    desc: 'Identifica tu nivel real y traza tu propio camino de progreso con una valoración que refleja quién eres como jugador. Cada partido cuenta tu historia.',
  },
  {
    titulo: 'Visibilidad Internacional',
    desc: 'Tu clasificación tiene alcance global. Juegues donde juegues, tu valoración te representa y te conecta con la comunidad mundial del pádel.',
  },
  {
    titulo: 'Eventos a la Medida',
    desc: 'Torneos organizados para todos los niveles, edades y géneros, con puntos que cuentan para tu status mundial. Compite en igualdad de condiciones.',
  },
  {
    titulo: 'Comunidad Apasionada',
    desc: 'Conecta con jugadores que comparten tu pasión, amplía tu red y genera nuevas posibilidades. El pádel es mejor cuando se comparte.',
  },
  {
    titulo: 'Seguimiento Personalizado',
    desc: 'Análisis detallado de tu evolución, estadísticas de cada partido, comparativas con rivales y un historial completo de tu trayectoria.',
  },
]
---

<Layout title="Score Padel — Plataforma Global de Pádel">
  <Navbar />
  <div class="hero-pattern">
    <!-- HERO -->
    <section class="relative min-h-screen flex items-center pt-20 pb-16 overflow-hidden">
      <div class="absolute top-20 right-0 w-[500px] h-[500px] bg-coral/8 rounded-full blur-[120px]">
      </div>
      <div class="absolute bottom-0 left-0 w-[400px] h-[400px] bg-teal/6 rounded-full blur-[100px]">
      </div>
      <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-8 w-full">
        <div class="grid lg:grid-cols-2 gap-16 items-center">
          <div>
            <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-coral/10 mb-8">
              <span class="w-2 h-2 rounded-full bg-coral pulse-soft"></span>
              <span class="text-xs font-semibold text-coral tracking-wide uppercase"
                >Plataforma activa</span
              >
            </div>
            <h1
              class="font-display text-5xl sm:text-6xl lg:text-7xl font-extrabold tracking-tight leading-[1.05] mb-6 text-navy"
            >
              Tu nivel real.<br />
              <span class="text-gradient">Sin subjetividad.</span>
            </h1>
            <p class="text-lg text-muted max-w-xl leading-relaxed mb-10">
              Score Padel organiza, estandariza y jerarquiza las competiciones de pádel a nivel
              mundial. Una valoración numérica basada en datos, no en opiniones.
            </p>
            <div class="flex flex-wrap gap-3">
              <a
                href="/registro"
                class="px-7 py-3.5 bg-coral text-white text-sm font-semibold rounded-full hover:bg-coral-dark transition-colors shadow-lg shadow-coral/25"
              >
                Crear cuenta gratis
              </a>
              <a
                href="#como-funciona"
                class="px-7 py-3.5 border-2 border-navy/10 text-navy text-sm font-semibold rounded-full hover:border-coral hover:text-coral transition-all"
              >
                Descubre cómo funciona
              </a>
            </div>
          </div>
          <div class="hidden lg:block">
            <div class="grid grid-cols-2 gap-4">
              <div class="card p-6 text-center space-y-1">
                <div class="font-display text-4xl font-extrabold text-coral">12</div>
                <div class="text-sm font-medium text-muted">Niveles</div>
              </div>
              <div class="card p-6 text-center space-y-1 mt-8">
                <div class="font-display text-4xl font-extrabold text-teal">3</div>
                <div class="text-sm font-medium text-muted">Divisiones</div>
              </div>
              <div class="card p-6 text-center space-y-1">
                <div class="font-display text-4xl font-extrabold text-amber">∞</div>
                <div class="text-sm font-medium text-muted">Torneos</div>
              </div>
              <div class="card p-6 text-center space-y-1 mt-8">
                <div class="font-display text-4xl font-extrabold text-navy">1-7</div>
                <div class="text-sm font-medium text-muted">Valoración</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- QUIÉNES SOMOS -->
    <section id="quienes-somos" class="py-24">
      <div class="max-w-7xl mx-auto px-6 lg:px-8">
        <div class="grid lg:grid-cols-2 gap-16 items-center">
          <div>
            <span
              class="inline-block text-xs font-bold text-coral uppercase tracking-[0.2em] mb-4 bg-coral/10 px-3 py-1 rounded-full"
              >Quiénes somos</span
            >
            <h2
              class="font-display text-3xl sm:text-4xl font-extrabold tracking-tight mb-8 text-navy"
            >
              Transformando la escena<br />del pádel mundial
            </h2>
            <div class="space-y-5 text-muted leading-relaxed">
              <p>
                Score Padel nació con el propósito de <span class="text-navy font-medium"
                  >organizar y estandarizar las competiciones</span
                >, jerarquizar a los jugadores y proporcionar una plataforma global donde cada
                deportista cuente su propia historia de éxito.
              </p>
              <p>
                Cada jugador podrá tener una clasificación de acuerdo con su <span
                  class="text-navy font-medium"
                  >nivel de destreza, experiencia deportiva, años de práctica, estado actual de
                  competencia</span
                > e historia competitiva en pádel y otros deportes de raqueta.
              </p>
              <p>
                Somos el impulso que eleva el pádel, ofreciendo orden, sentido y comunidad a la
                escena amateur y profesional apasionada por este deporte.
              </p>
            </div>
          </div>
          <div>
            <div class="card p-8 space-y-6">
              <div class="flex items-start gap-4">
                <div
                  class="w-11 h-11 rounded-xl bg-coral/10 flex items-center justify-center shrink-0"
                >
                  <svg
                    class="w-5 h-5 text-coral"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                    ><path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"
                    ></path></svg
                  >
                </div>
                <div>
                  <h4 class="text-sm font-bold text-navy mb-1">Valoración objetiva</h4>
                  <p class="text-xs text-muted leading-relaxed">
                    Algoritmo basado en datos reales de partidos, no en opiniones subjetivas.
                  </p>
                </div>
              </div>
              <div class="flex items-start gap-4">
                <div
                  class="w-11 h-11 rounded-xl bg-teal/10 flex items-center justify-center shrink-0"
                >
                  <svg
                    class="w-5 h-5 text-teal"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                    ><path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
                    ></path></svg
                  >
                </div>
                <div>
                  <h4 class="text-sm font-bold text-navy mb-1">Alcance global</h4>
                  <p class="text-xs text-muted leading-relaxed">
                    Juegues donde juegues, tu valoración te acompaña a nivel mundial.
                  </p>
                </div>
              </div>
              <div class="flex items-start gap-4">
                <div
                  class="w-11 h-11 rounded-xl bg-amber/10 flex items-center justify-center shrink-0"
                >
                  <svg
                    class="w-5 h-5 text-amber"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                    ><path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path></svg
                  >
                </div>
                <div>
                  <h4 class="text-sm font-bold text-navy mb-1">Evolución continua</h4>
                  <p class="text-xs text-muted leading-relaxed">
                    Tu clasificación se actualiza tras cada partido, reflejando tu estado real.
                  </p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- 9 PASOS: CÓMO FUNCIONA -->
    <section id="como-funciona" class="py-24 bg-white">
      <div class="max-w-7xl mx-auto px-6 lg:px-8">
        <div class="max-w-2xl mb-16">
          <span
            class="inline-block text-xs font-bold text-coral uppercase tracking-[0.2em] mb-4 bg-coral/10 px-3 py-1 rounded-full"
            >Cómo funciona</span
          >
          <h2
            class="font-display text-3xl sm:text-4xl font-extrabold tracking-tight mb-4 text-navy"
          >
            La plataforma, punto por punto
          </h2>
          <p class="text-muted leading-relaxed">
            9 características que definen Score Padel como la plataforma global de referencia para
            el pádel amateur y profesional.
          </p>
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {
            puntos.map((p) => (
              <div class="card-hover p-7 group">
                <span class="font-display text-3xl font-extrabold text-coral/10 group-hover:text-coral/25 transition-colors block mb-4">
                  {p.num}
                </span>
                <h3 class="font-display text-base font-bold text-navy mb-2">{p.titulo}</h3>
                <p class="text-sm text-muted leading-relaxed">{p.desc}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- VALORACIÓN / ALGORITMO -->
    <section class="py-24">
      <div class="max-w-7xl mx-auto px-6 lg:px-8">
        <div class="grid lg:grid-cols-5 gap-12">
          <div class="lg:col-span-2">
            <span
              class="inline-block text-xs font-bold text-teal uppercase tracking-[0.2em] mb-4 bg-teal/10 px-3 py-1 rounded-full"
              >Sistema de valoración</span
            >
            <h2 class="font-display text-3xl font-extrabold tracking-tight mb-6 text-navy">
              Valoración,<br />no ranking
            </h2>
            <p class="text-muted leading-relaxed mb-6">
              Score Padel no entrega un ranking tradicional, sino una <span
                class="text-coral font-semibold">valoración numérica</span
              > única que refleja tu nivel real basada en tu destreza, experiencia deportiva, años de
              práctica y estado competitivo actual.
            </p>
            <p class="text-muted leading-relaxed">
              Nuestra misión: <span class="text-navy font-medium"
                >empoderar a cada jugador a disfrutar del juego y motivarlos a mejorar</span
              >, brindándole la oportunidad de identificarse en su nivel y trazar sus propios
              caminos de progreso.
            </p>
          </div>
          <div class="lg:col-span-3">
            <div class="card p-8">
              <h3 class="font-display text-lg font-bold text-navy mb-2">Cálculo de valoración</h3>
              <p class="text-sm text-muted mb-6">
                El algoritmo se basa en el resultado de cada equipo según juegos ganados. Tres
                factores:
              </p>
              <div class="space-y-4">
                <div
                  class="flex gap-4 items-start p-4 rounded-xl bg-coral/5 border border-coral/10"
                >
                  <div
                    class="w-9 h-9 rounded-xl bg-coral/10 flex items-center justify-center shrink-0"
                  >
                    <span class="text-xs font-bold text-coral">1</span>
                  </div>
                  <div>
                    <h4 class="text-sm font-bold text-navy mb-1">Diferencia de valoraciones</h4>
                    <p class="text-xs text-muted leading-relaxed">
                      La diferencia entre las clasificaciones de los jugadores que se enfrentan
                      entre sí.
                    </p>
                  </div>
                </div>
                <div class="flex gap-4 items-start p-4 rounded-xl bg-teal/5 border border-teal/10">
                  <div
                    class="w-9 h-9 rounded-xl bg-teal/10 flex items-center justify-center shrink-0"
                  >
                    <span class="text-xs font-bold text-teal">2</span>
                  </div>
                  <div>
                    <h4 class="text-sm font-bold text-navy mb-1">Rendimiento vs. expectativa</h4>
                    <p class="text-xs text-muted leading-relaxed">
                      El porcentaje de juegos ganados comparado con el resultado esperado según tu
                      nivel.
                    </p>
                  </div>
                </div>
                <div
                  class="flex gap-4 items-start p-4 rounded-xl bg-amber/5 border border-amber/10"
                >
                  <div
                    class="w-9 h-9 rounded-xl bg-amber/10 flex items-center justify-center shrink-0"
                  >
                    <span class="text-xs font-bold text-amber">3</span>
                  </div>
                  <div>
                    <h4 class="text-sm font-bold text-navy mb-1">Resultados recientes</h4>
                    <p class="text-xs text-muted leading-relaxed">
                      Tus resultados de partidos recientes comparados con tu mejor rendimiento
                      reciente.
                    </p>
                  </div>
                </div>
              </div>
              <p class="text-xs text-muted/70 mt-6 italic">
                Score Padel contabiliza todos los formatos de juego, la competitividad y la
                fiabilidad de la clasificación de los rivales.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- NIVELES -->
    <section id="niveles" class="py-24 bg-white">
      <div class="max-w-7xl mx-auto px-6 lg:px-8">
        <div class="max-w-2xl mb-16">
          <span
            class="inline-block text-xs font-bold text-coral uppercase tracking-[0.2em] mb-4 bg-coral/10 px-3 py-1 rounded-full"
            >Sistema de niveles</span
          >
          <h2
            class="font-display text-3xl sm:text-4xl font-extrabold tracking-tight mb-4 text-navy"
          >
            12 niveles, 3 divisiones
          </h2>
          <p class="text-muted leading-relaxed">
            Tu valoración te ubica en un nivel que refleja tu destreza real.
          </p>
        </div>

        <div class="space-y-10">
          {/* División C */}
          <div>
            <div class="flex items-center gap-3 mb-4">
              <span class="w-3 h-3 rounded-full bg-gray-400"></span>
              <span class="text-sm font-bold text-navy tracking-wide">División C</span>
              <span class="text-xs text-muted font-medium">· Iniciación</span>
            </div>
            <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-3">
              {
                niveles
                  .filter((n) => n.div === 'C')
                  .map((n) => (
                    <div class="card-hover p-5">
                      <span class="font-display text-xl font-extrabold text-gray-300">{n.cal}</span>
                      <div class="text-sm text-navy font-medium mt-1">{n.nombre}</div>
                    </div>
                  ))
              }
            </div>
          </div>

          {/* División B */}
          <div>
            <div class="flex items-center gap-3 mb-4">
              <span class="w-3 h-3 rounded-full bg-teal"></span>
              <span class="text-sm font-bold text-navy tracking-wide">División B</span>
              <span class="text-xs text-muted font-medium">· Competitiva</span>
            </div>
            <div class="grid sm:grid-cols-2 lg:grid-cols-5 gap-3">
              {
                niveles
                  .filter((n) => n.div === 'B')
                  .map((n) => (
                    <div class="card-hover p-5">
                      <span class="font-display text-xl font-extrabold text-teal/40">{n.cal}</span>
                      <div class="text-sm text-navy font-medium mt-1">{n.nombre}</div>
                    </div>
                  ))
              }
            </div>
          </div>

          {/* División A */}
          <div>
            <div class="flex items-center gap-3 mb-4">
              <span class="w-3 h-3 rounded-full bg-coral"></span>
              <span class="text-sm font-bold text-navy tracking-wide">División A</span>
              <span class="text-xs text-muted font-medium">· Élite</span>
            </div>
            <div class="grid sm:grid-cols-3 gap-3">
              {
                niveles
                  .filter((n) => n.div === 'A')
                  .map((n) => (
                    <div class="card-hover p-5">
                      <span class="font-display text-xl font-extrabold text-coral/40">{n.cal}</span>
                      <div class="text-sm text-navy font-medium mt-1">{n.nombre}</div>
                    </div>
                  ))
              }
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- VENTAJAS -->
    <section id="ventajas" class="py-24">
      <div class="max-w-7xl mx-auto px-6 lg:px-8">
        <div class="max-w-2xl mb-16">
          <span
            class="inline-block text-xs font-bold text-coral uppercase tracking-[0.2em] mb-4 bg-coral/10 px-3 py-1 rounded-full"
            >Por qué unirse</span
          >
          <h2
            class="font-display text-3xl sm:text-4xl font-extrabold tracking-tight mb-4 text-navy"
          >
            ¿Por qué unirse a Score Padel?
          </h2>
          <p class="text-muted leading-relaxed">
            Cinco razones para formar parte de la comunidad global del pádel.
          </p>
        </div>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">
          {
            porQueUnirse.map((v) => (
              <div class="card-hover p-8">
                <h3 class="font-display text-base font-bold text-navy mb-3">{v.titulo}</h3>
                <p class="text-sm text-muted leading-relaxed">{v.desc}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- CONTACTO -->
    <section id="contacto" class="py-24 bg-navy">
      <div class="max-w-3xl mx-auto px-6 lg:px-8 text-center">
        <span
          class="inline-block text-xs font-bold text-coral uppercase tracking-[0.2em] mb-4 bg-coral/20 px-3 py-1 rounded-full"
          >Contacto</span
        >
        <h2 class="font-display text-3xl sm:text-4xl font-extrabold tracking-tight mb-6 text-white">
          ¿Listo para empezar?
        </h2>
        <p class="text-white/60 leading-relaxed mb-10">
          Crea tu cuenta gratuita, obtén tu valoración y empieza a competir a nivel mundial.
        </p>
        <div class="flex flex-wrap justify-center gap-3">
          <a
            href="/registro"
            class="inline-flex px-8 py-3.5 bg-coral text-white text-sm font-semibold rounded-full hover:bg-coral-dark transition-colors shadow-lg shadow-coral/30"
          >
            Crear cuenta gratis
          </a>
          <a
            href="/login"
            class="inline-flex px-8 py-3.5 border-2 border-white/20 text-white text-sm font-semibold rounded-full hover:border-coral hover:text-coral transition-all"
          >
            Ya tengo cuenta
          </a>
        </div>
      </div>
    </section>
  </div>
  <Footer />
  <CookieBanner />
</Layout>
