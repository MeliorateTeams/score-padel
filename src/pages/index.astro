                    <line
                      x1="11.5"
                      y1="34"
                      x2="16.5"
                      y2="34"
                      stroke="white"
                      stroke-width="0.9"
                      opacity="0.4"></line>
                    <line
                      x1="11.5"
                      y1="36.5"
                      x2="16.5"
                      y2="36.5"
                      stroke="white"
                      stroke-width="0.9"
                      opacity="0.4"></line>
                    <path
                      d="M11.5 29 C11.5 26 10 22 9 17 C7 10 9 3.5 14 2.5 C19 3.5 21 10 19 17 C18 22 16.5 26 16.5 29 Z"
                      fill="currentColor"></path>
                    <circle cx="12" cy="9" r="1.4" fill="white" opacity="0.3"></circle>
                    <circle cx="16" cy="8" r="1.4" fill="white" opacity="0.3"></circle>
