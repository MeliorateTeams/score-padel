---
import AppLayout from '../layouts/AppLayout.astro'

const user = (Astro.locals as any).user
if (user) return Astro.redirect('/app')

const email = Astro.url.searchParams.get('email')?.trim().toLowerCase() ?? ''
const error = Astro.url.searchParams.get('error')
const sent = Astro.url.searchParams.get('sent') === '1'
const resent = Astro.url.searchParams.get('resent') === '1'

const errorMsg: Record<string, string> = {
  campos: 'Introduce tu correo y un código de 6 cifras.',
  invalid: 'El código no es válido.',
  expired: 'El código ha caducado o ha quedado invalidado. Solicita uno nuevo.',
  email_send:
    'La cuenta está creada, pero no pudimos enviar el correo. Revisa la configuración y pulsa reenviar.',
  unverified: 'Tu cuenta existe, pero todavía no está verificada.',
  missing_email: 'Indica el correo con el que te registraste.',
  throttled: 'Espera un minuto antes de solicitar otro código.',
  server: 'No se pudo completar la verificación. Inténtalo de nuevo.',
}

const successMessage = sent
  ? 'Te hemos enviado un código de verificación a tu correo.'
  : resent
    ? 'Si la cuenta existe y sigue pendiente, hemos reenviado un nuevo código.'
    : ''
---

<AppLayout title="Verificar email">
  <div class="relative min-h-screen overflow-hidden bg-[#1f1712]">
    <div class="absolute inset-0">
      <img
        src="/images/hero-padel-2.png"
        alt=""
        role="presentation"
        class="h-full w-full object-cover object-center"
        loading="eager"
        decoding="async"
      />
    </div>
    <div
      class="absolute inset-0"
      style="background: linear-gradient(115deg, rgba(24,18,14,0.95) 0%, rgba(24,18,14,0.84) 28%, rgba(208,79,0,0.74) 62%, rgba(255,186,8,0.42) 100%);"
    >
    </div>
    <div
      class="absolute inset-0"
      style="background: radial-gradient(circle at top left, rgba(255,248,242,0.18), transparent 34%), radial-gradient(circle at 84% 18%, rgba(255,186,8,0.18), transparent 28%);"
    >
    </div>

    <div class="relative min-h-screen px-6 py-8 lg:px-8">
      <a
        href="/login"
        class="absolute left-6 top-6 z-10 inline-flex h-11 w-11 items-center justify-center rounded-full bg-white/12 text-white/80 ring-1 ring-white/15 backdrop-blur-sm transition-all hover:bg-white/20 hover:text-white lg:left-8 lg:top-8"
        aria-label="Volver a login"
      >
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18"></path>
        </svg>
      </a>

      <div
        class="mx-auto grid min-h-[calc(100vh-4rem)] max-w-7xl items-center gap-10 lg:grid-cols-[1.02fr_0.98fr]"
      >
        <section class="hidden lg:flex flex-col justify-center pr-10 text-white">
          <span
            class="mb-4 inline-flex w-fit items-center gap-2 rounded-full bg-white/10 px-4 py-2 text-[11px] font-semibold uppercase tracking-[0.22em] text-white/78"
          >
            Activación de cuenta
          </span>

          <h1
            class="font-display max-w-2xl text-5xl font-extrabold leading-[1.02] tracking-tight text-white"
          >
            Un paso más y tu cuenta quedará lista para entrar en pista.
          </h1>
          <p class="mt-5 max-w-xl text-base leading-relaxed text-white/72">
            Te enviamos un código de 6 cifras al correo que usaste en el registro. Introdúcelo aquí
            para activar el acceso.
          </p>

          <div class="mt-10 grid gap-4 sm:grid-cols-3">
            <div
              class="rounded-[1.6rem] border border-white/12 bg-white/7 px-5 py-5 backdrop-blur-sm"
            >
              <div class="font-display text-lg font-bold text-[#FFE3B8]">6 cifras</div>
              <p class="mt-2 text-sm leading-relaxed text-white/70">
                Código corto y rápido de introducir.
              </p>
            </div>
            <div
              class="rounded-[1.6rem] border border-white/12 bg-white/7 px-5 py-5 backdrop-blur-sm"
            >
              <div class="font-display text-lg font-bold text-[#FFE3B8]">15 minutos</div>
              <p class="mt-2 text-sm leading-relaxed text-white/70">
                Ventana breve para reducir abuso y reenvíos masivos.
              </p>
            </div>
            <div
              class="rounded-[1.6rem] border border-white/12 bg-white/7 px-5 py-5 backdrop-blur-sm"
            >
              <div class="font-display text-lg font-bold text-[#FFE3B8]">Cloudflare</div>
              <p class="mt-2 text-sm leading-relaxed text-white/70">
                El envío se hace desde Email Service dentro del propio stack.
              </p>
            </div>
          </div>
        </section>

        <section class="w-full max-w-md lg:ml-auto">
          <div
            class="rounded-4xl border border-white/30 bg-white/12 p-2 shadow-[0_36px_90px_-32px_rgba(0,0,0,0.7)] backdrop-blur-xl"
          >
            <div
              class="rounded-[1.6rem] bg-[#fff8f2]/96 p-7 shadow-[inset_0_1px_0_rgba(255,255,255,0.75)] sm:p-9"
            >
              <a
                href="/"
                class="mb-8 flex items-center justify-center gap-3 font-display font-bold text-xl tracking-tight text-navy lg:hidden"
              >
                <img src="/favicon.svg" alt="Score Padel" class="h-11 w-11" />
                Score<span class="text-coral">Padel</span>
              </a>

              <div class="mb-7 text-center lg:text-left">
                <p
                  class="mb-3 inline-flex rounded-full bg-coral/10 px-4 py-2 text-[11px] font-semibold uppercase tracking-[0.2em] text-coral"
                >
                  Verificación de acceso
                </p>
                <h1 class="font-display text-3xl font-extrabold tracking-tight text-navy">
                  Activa tu cuenta
                </h1>
                <p class="mt-2 text-sm leading-relaxed text-muted">
                  Introduce el código que te acabamos de enviar.
                </p>
              </div>

              {
                error && (
                  <div class="mb-6 rounded-2xl border border-red-200 bg-red-50/95 px-4 py-3 text-sm text-red-700 shadow-sm">
                    {errorMsg[error] || 'Error desconocido.'}
                  </div>
                )
              }

              {
                successMessage && (
                  <div class="mb-6 rounded-2xl border border-emerald-200 bg-emerald-50/95 px-4 py-3 text-sm text-emerald-700 shadow-sm">
                    {successMessage}
                  </div>
                )
              }

              <form method="POST" action="/api/auth/verify-email" class="space-y-3.5">
                <div>
                  <label
                    for="email"
                    class="mb-2 block text-[11px] font-semibold uppercase tracking-[0.18em] text-muted"
                  >
                    Email
                  </label>
                  <input
                    type="email"
                    id="email"
                    name="email"
                    value={email}
                    required
                    autocomplete="email"
                    class="w-full rounded-2xl border border-[#efd2ba] bg-white/90 px-4 py-3.5 text-sm text-navy shadow-[0_10px_30px_-22px_rgba(31,23,18,0.5)] outline-none transition-all placeholder:text-muted/45 focus:border-coral focus:ring-4 focus:ring-coral/10"
                  />
                </div>

                <div>
                  <label
                    for="code"
                    class="mb-2 block text-[11px] font-semibold uppercase tracking-[0.18em] text-muted"
                  >
                    Código de verificación
                  </label>
                  <input
                    type="text"
                    id="code"
                    name="code"
                    required
                    inputmode="numeric"
                    autocomplete="one-time-code"
                    pattern="[0-9]{6}"
                    maxlength="6"
                    placeholder="000000"
                    class="w-full rounded-2xl border border-[#efd2ba] bg-white/90 px-4 py-3.5 text-center font-display text-2xl tracking-[0.35em] text-navy shadow-[0_10px_30px_-22px_rgba(31,23,18,0.5)] outline-none transition-all placeholder:tracking-[0.2em] placeholder:text-muted/35 focus:border-coral focus:ring-4 focus:ring-coral/10"
                  />
                  <p class="mt-1.5 pl-1 text-[11px] text-muted/60">
                    El código caduca en 15 minutos.
                  </p>
                </div>

                <button
                  type="submit"
                  class="w-full rounded-full py-3.5 text-sm font-semibold text-white shadow-[0_20px_40px_-20px_rgba(208,79,0,0.9)] transition-transform duration-200 hover:-translate-y-0.5 hover:shadow-[0_24px_50px_-20px_rgba(208,79,0,0.85)]"
                  style="background: linear-gradient(135deg, #e85d04 0%, #fb923c 50%, #ffba08 100%);"
                >
                  Verificar y entrar
                </button>
              </form>

              <form method="POST" action="/api/auth/resend-verification" class="mt-4">
                <input type="hidden" name="email" value={email} />
                <button
                  type="submit"
                  class="w-full rounded-full border border-[#efd2ba] bg-white/90 py-3 text-sm font-semibold text-navy transition-colors hover:bg-[#fff0e4]"
                >
                  Reenviar código
                </button>
              </form>

              <div
                class="mt-5 flex flex-col gap-3 border-t border-black/6 pt-4 text-center sm:text-left"
              >
                <p class="text-xs text-muted">
                  ¿Ya verificaste tu correo? <a
                    href="/login"
                    class="font-semibold text-coral hover:underline">Vuelve al login</a
                  >
                </p>
                <p class="text-xs text-muted/80">
                  Si no ves el correo, revisa spam o solicita un nuevo código.
                </p>
              </div>
            </div>
          </div>
        </section>
      </div>
    </div>
  </div>
</AppLayout>
