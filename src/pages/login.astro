---
import AppLayout from '../layouts/AppLayout.astro'
const user = (Astro.locals as any).user
if (user) return Astro.redirect('/app')

const error = Astro.url.searchParams.get('error')
const errorMsg: Record<string, string> = {
  campos: 'Email y contraseña son obligatorios.',
  invalid: 'Email o contraseña incorrectos.',
}
---

<AppLayout title="Iniciar sesión">
  <div class="min-h-screen flex items-center justify-center px-6 bg-bg">
    <div class="w-full max-w-sm">
      <a
        href="/"
        class="flex items-center justify-center gap-2 font-display font-bold text-xl tracking-tight mb-10 text-navy"
      >
        <svg class="w-9 h-9" viewBox="0 0 40 40" fill="none">
          <rect width="40" height="40" rx="11" fill="#E5553B"></rect>
          <rect
            x="14"
            y="7"
            width="12"
            height="18"
            rx="6"
            stroke="white"
            stroke-width="2.5"
            fill="none"></rect>
          <line x1="17" y1="12" x2="17" y2="20" stroke="white" stroke-width="1.2" opacity="0.5"
          ></line>
          <line x1="20" y1="12" x2="20" y2="20" stroke="white" stroke-width="1.2" opacity="0.5"
          ></line>
          <line x1="23" y1="12" x2="23" y2="20" stroke="white" stroke-width="1.2" opacity="0.5"
          ></line>
          <line x1="14" y1="14" x2="26" y2="14" stroke="white" stroke-width="1.2" opacity="0.5"
          ></line>
          <line x1="14" y1="18" x2="26" y2="18" stroke="white" stroke-width="1.2" opacity="0.5"
          ></line>
          <rect x="18" y="25" width="4" height="8" rx="2" fill="white"></rect>
          <circle cx="32" cy="9" r="4.5" fill="#0D9488"></circle>
          <path
            d="M30 7c1.5 1 2 3 1 4.5"
            stroke="white"
            stroke-width="1"
            opacity="0.6"
            fill="none"
            stroke-linecap="round"></path>
        </svg>
        Score<span class="text-coral">Padel</span>
      </a>

      <h1 class="font-display text-2xl font-extrabold text-center mb-2 text-navy">
        Iniciar sesión
      </h1>
      <p class="text-sm text-muted text-center mb-8">Accede a tu cuenta de Score Padel.</p>

      {
        error && (
          <div class="bg-red-50 border border-red-200 text-red-600 text-xs p-3 rounded-xl mb-6">
            {errorMsg[error] || 'Error desconocido.'}
          </div>
        )
      }

      <form method="POST" action="/api/auth/login" class="space-y-4">
        <div>
          <label for="email" class="text-xs font-semibold text-navy block mb-1.5">Email</label>
          <input
            type="email"
            id="email"
            name="email"
            required
            autocomplete="email"
            class="w-full px-4 py-3 bg-white border border-gray-200 rounded-xl text-sm text-navy placeholder:text-muted/50 focus:outline-none focus:border-coral focus:ring-2 focus:ring-coral/10 transition-all"
          />
        </div>
        <div>
          <label for="password" class="text-xs font-semibold text-navy block mb-1.5"
            >Contraseña</label
          >
          <input
            type="password"
            id="password"
            name="password"
            required
            autocomplete="current-password"
            class="w-full px-4 py-3 bg-white border border-gray-200 rounded-xl text-sm text-navy placeholder:text-muted/50 focus:outline-none focus:border-coral focus:ring-2 focus:ring-coral/10 transition-all"
          />
        </div>
        <button
          type="submit"
          class="w-full py-3 bg-coral text-white text-sm font-semibold rounded-full hover:bg-coral-dark transition-colors shadow-sm"
        >
          Iniciar sesión
        </button>
      </form>

      <p class="text-xs text-muted text-center mt-6">
        ¿No tienes cuenta? <a href="/registro" class="text-coral font-semibold hover:underline"
          >Regístrate</a
        >
      </p>
    </div>
  </div>
</AppLayout>
