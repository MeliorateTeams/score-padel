---
import '../styles/global.css'

interface Props {
  title: string
  user?: { id: string; name: string; email: string; role?: string } | null
}

const { title, user = null } = Astro.props
const isGuest = user?.role === 'guest'
const isAdmin = user?.role === 'admin'
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" sizes="32x32" />
    <title>{title} — Score Padel</title>
    <meta http-equiv="X-Content-Type-Options" content="nosniff" />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
  </head>
  <body class="min-h-screen bg-bg">
    {
      user ? (
        <nav class="fixed top-0 left-0 right-0 z-50 bg-white shadow-sm border-b border-gray-100">
          <div class="max-w-7xl mx-auto px-6 lg:px-8 flex items-center justify-between h-14">
            <a
              href="/app"
              class="flex items-center gap-1.5 font-display font-bold text-base tracking-tight text-navy"
            >
              <svg class="w-7 h-7" viewBox="0 0 64 64" fill="none">
                <path
                  d="M6 12C6 8.686 8.686 6 12 6h40c3.314 0 6 2.686 6 6v24c0 10-12 18-26 22C18 48 6 40 6 30V12z"
                  fill="#E5553B"
                />
                <path
                  d="M8 13c0-2.761 2.239-5 5-5h38c2.761 0 5 2.239 5 5v21c0 8.5-11 16-24 20C19 50 8 42 8 33.5V13z"
                  fill="#D14430"
                />
                <g transform="translate(32,26) rotate(-30)">
                  <rect
                    x="-9"
                    y="-14"
                    width="18"
                    height="22"
                    rx="9"
                    stroke="white"
                    stroke-width="3"
                    fill="none"
                  />
                  <circle cx="-4" cy="-7" r="1.3" fill="white" opacity="0.7" />
                  <circle cx="0" cy="-7" r="1.3" fill="white" opacity="0.7" />
                  <circle cx="4" cy="-7" r="1.3" fill="white" opacity="0.7" />
                  <circle cx="-4" cy="-3" r="1.3" fill="white" opacity="0.7" />
                  <circle cx="0" cy="-3" r="1.3" fill="white" opacity="0.7" />
                  <circle cx="4" cy="-3" r="1.3" fill="white" opacity="0.7" />
                  <circle cx="-4" cy="1" r="1.3" fill="white" opacity="0.7" />
                  <circle cx="0" cy="1" r="1.3" fill="white" opacity="0.7" />
                  <circle cx="4" cy="1" r="1.3" fill="white" opacity="0.7" />
                  <rect x="-2.5" y="8" width="5" height="10" rx="2.5" fill="white" />
                </g>
                <circle cx="46" cy="14" r="6" fill="#0D9488" />
                <path
                  d="M43.5 11.5c2 1.2 2.5 4 1.2 5.8"
                  stroke="white"
                  stroke-width="1.2"
                  opacity="0.7"
                  fill="none"
                  stroke-linecap="round"
                />
              </svg>
              Score<span class="text-coral">Padel</span>
            </a>
            {/* Desktop nav */}
            <div class="hidden md:flex items-center gap-0.5">
              <a
                href="/app"
                class="px-3 py-1.5 text-xs font-medium text-muted hover:text-coral rounded-full hover:bg-coral/5 transition-all"
              >
                Dashboard
              </a>
              <a
                href="/app/torneos"
                class="px-3 py-1.5 text-xs font-medium text-muted hover:text-coral rounded-full hover:bg-coral/5 transition-all"
              >
                Torneos
              </a>
              {!isGuest && (
                <a
                  href="/app/partidos"
                  class="px-3 py-1.5 text-xs font-medium text-muted hover:text-coral rounded-full hover:bg-coral/5 transition-all"
                >
                  Partidos
                </a>
              )}
              <a
                href="/app/jugadores"
                class="px-3 py-1.5 text-xs font-medium text-muted hover:text-coral rounded-full hover:bg-coral/5 transition-all"
              >
                Jugadores
              </a>
              <a
                href="/app/clasificacion"
                class="px-3 py-1.5 text-xs font-medium text-muted hover:text-coral rounded-full hover:bg-coral/5 transition-all"
              >
                Valoraciones
              </a>
              {!isGuest && (
                <a
                  href="/app/perfil"
                  class="px-3 py-1.5 text-xs font-medium text-muted hover:text-coral rounded-full hover:bg-coral/5 transition-all"
                >
                  Perfil
                </a>
              )}
              {isAdmin && (
                <a
                  href="/app/algoritmo"
                  class="px-3 py-1.5 text-xs font-medium text-muted hover:text-coral rounded-full hover:bg-coral/5 transition-all"
                >
                  Algoritmo
                </a>
              )}
              <form method="POST" action="/api/auth/logout" class="ml-2">
                <button class="px-3 py-1.5 text-xs font-medium text-muted hover:text-red-500 rounded-full hover:bg-red-50 transition-all">
                  Salir
                </button>
              </form>
            </div>
            {/* Mobile hamburger */}
            <button
              id="mobile-menu-btn"
              class="md:hidden p-2 text-navy hover:text-coral transition-colors"
              aria-label="Abrir menú"
            >
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path
                  id="hamburger-icon"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M4 6h16M4 12h16M4 18h16"
                />
              </svg>
            </button>
          </div>
          {/* Mobile menu panel */}
          <div id="mobile-menu" class="md:hidden hidden border-t border-gray-100 bg-white">
            <div class="px-6 py-3 space-y-1">
              <a
                href="/app"
                class="block px-3 py-2 text-sm font-medium text-muted hover:text-coral rounded-lg hover:bg-coral/5 transition-all"
              >
                Dashboard
              </a>
              <a
                href="/app/torneos"
                class="block px-3 py-2 text-sm font-medium text-muted hover:text-coral rounded-lg hover:bg-coral/5 transition-all"
              >
                Torneos
              </a>
              {!isGuest && (
                <a
                  href="/app/partidos"
                  class="block px-3 py-2 text-sm font-medium text-muted hover:text-coral rounded-lg hover:bg-coral/5 transition-all"
                >
                  Partidos
                </a>
              )}
              <a
                href="/app/jugadores"
                class="block px-3 py-2 text-sm font-medium text-muted hover:text-coral rounded-lg hover:bg-coral/5 transition-all"
              >
                Jugadores
              </a>
              <a
                href="/app/clasificacion"
                class="block px-3 py-2 text-sm font-medium text-muted hover:text-coral rounded-lg hover:bg-coral/5 transition-all"
              >
                Valoraciones
              </a>
              {!isGuest && (
                <a
                  href="/app/perfil"
                  class="block px-3 py-2 text-sm font-medium text-muted hover:text-coral rounded-lg hover:bg-coral/5 transition-all"
                >
                  Perfil
                </a>
              )}
              {isAdmin && (
                <a
                  href="/app/algoritmo"
                  class="block px-3 py-2 text-sm font-medium text-muted hover:text-coral rounded-lg hover:bg-coral/5 transition-all"
                >
                  Algoritmo
                </a>
              )}
              <form method="POST" action="/api/auth/logout">
                <button class="w-full text-left px-3 py-2 text-sm font-medium text-muted hover:text-red-500 rounded-lg hover:bg-red-50 transition-all">
                  Salir
                </button>
              </form>
            </div>
          </div>
        </nav>
      ) : null
    }
    <main class={user ? 'pt-20 pb-12 px-6 lg:px-8 max-w-7xl mx-auto' : ''}>
      <slot />
    </main>
    <script>
      const menuBtn = document.getElementById('mobile-menu-btn')
      const mobileMenu = document.getElementById('mobile-menu')
      menuBtn?.addEventListener('click', () => {
        mobileMenu?.classList.toggle('hidden')
      })
    </script>
  </body>
</html>
