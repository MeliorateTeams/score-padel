---
import '../styles/global.css'

interface Props {
  title: string
  user?: { id: string; name: string; email: string; role?: string } | null
}

const { title, user = null } = Astro.props
const isAdmin = user?.role === 'admin'

// Notification count
let unreadCount = 0
if (user) {
  const db = (Astro.locals as any).db
  const countResult = await db
    .prepare('SELECT COUNT(*) as cnt FROM notifications WHERE user_id = ? AND read = 0')
    .bind(user.id)
    .first()
  unreadCount = countResult?.cnt ?? 0
}
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/icon-192.png" />
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#FF6A00" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <title>{title} — Score Padel</title>
    <meta http-equiv="X-Content-Type-Options" content="nosniff" />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
  </head>
  <body
    class="min-h-screen"
    style="background: linear-gradient(180deg, #FFF8F2 0%, #FFF5EB 100%); min-height: 100vh;"
  >
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:z-100 focus:px-4 focus:py-2 focus:bg-coral focus:text-white focus:rounded-lg focus:text-sm focus:font-semibold"
      >Saltar al contenido</a
    >
    {
      user ? (
        <nav
          class="fixed top-0 left-0 right-0 z-50 border-b border-[#f0dcc8]/60 dark-nav"
          style="background: rgba(255,248,242,0.88); backdrop-filter: blur(18px) saturate(160%); -webkit-backdrop-filter: blur(18px) saturate(160%);"
          role="navigation"
          aria-label="Navegación principal"
        >
          <div class="max-w-7xl mx-auto px-6 lg:px-8 flex items-center justify-between h-14">
            <a
              href="/app"
              class="flex items-center gap-1.5 font-display font-bold text-base tracking-tight text-navy"
            >
              <img src="/favicon.svg" alt="Score Padel" class="w-9 h-9" />
              Score<span class="text-coral">Padel</span>
            </a>
            {/* Quick search */}
            <form action="/app/jugadores" method="GET" class="hidden lg:flex items-center ml-4">
              <div class="relative" id="quick-player-search-wrap">
                <svg
                  class="w-3.5 h-3.5 absolute left-3 top-1/2 -translate-y-1/2 text-muted/50"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z"
                  />
                </svg>
                <input
                  type="text"
                  id="quick-player-search"
                  name="q"
                  autocomplete="off"
                  placeholder="Buscar jugador..."
                  class="w-44 pl-8 pr-3 py-1.5 text-xs bg-[#fff5eb] border border-[#efd2ba] rounded-full text-navy placeholder:text-muted/50 focus:outline-none focus:border-coral/50 focus:w-56 transition-all"
                />
                <div
                  id="quick-player-results"
                  class="hidden absolute left-0 right-0 top-full mt-1 z-20 bg-white border border-gray-200 rounded-xl shadow-lg max-h-56 overflow-y-auto"
                />
              </div>
            </form>
            {/* Desktop nav */}
            <div class="hidden md:flex items-center gap-0.5">
              <a
                href="/app"
                class="px-3 py-1.5 text-xs font-medium text-muted hover:text-coral rounded-full hover:bg-coral/5 transition-all"
              >
                Inicio
              </a>
              <a
                href="/app/partidos"
                class="px-3 py-1.5 text-xs font-medium text-muted hover:text-coral rounded-full hover:bg-coral/5 transition-all"
              >
                Partidos
              </a>
              <a
                href="/app/jugadores"
                class="px-3 py-1.5 text-xs font-medium text-muted hover:text-coral rounded-full hover:bg-coral/5 transition-all"
              >
                Jugadores
              </a>
              <a
                href="/app/torneos"
                class="px-3 py-1.5 text-xs font-medium text-muted hover:text-coral rounded-full hover:bg-coral/5 transition-all"
              >
                Torneos
              </a>
              <a
                href="/app/perfil"
                class="px-3 py-1.5 text-xs font-medium text-muted hover:text-coral rounded-full hover:bg-coral/5 transition-all"
              >
                Perfil
              </a>
              {isAdmin && (
                <a
                  href="/app/admin"
                  class="px-3 py-1.5 text-xs font-medium text-muted hover:text-coral rounded-full hover:bg-coral/5 transition-all"
                >
                  Admin
                </a>
              )}
              <a
                href="/app/notificaciones"
                class="relative px-3 py-1.5 text-xs font-medium text-muted hover:text-coral rounded-full hover:bg-coral/5 transition-all"
              >
                <svg
                  class="w-4 h-4"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M14.857 17.082a23.848 23.848 0 005.454-1.31A8.967 8.967 0 0118 9.75V9A6 6 0 006 9v.75a8.967 8.967 0 01-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 01-5.714 0m5.714 0a3 3 0 11-5.714 0"
                  />
                </svg>
                {unreadCount > 0 && (
                  <span class="absolute -top-0.5 -right-0.5 w-4 h-4 bg-coral text-white text-[9px] font-bold rounded-full flex items-center justify-center">
                    {unreadCount > 9 ? '9+' : unreadCount}
                  </span>
                )}
              </a>
              <form method="POST" action="/api/auth/logout" class="ml-2">
                <button class="px-3 py-1.5 text-xs font-medium text-muted hover:text-red-500 rounded-full hover:bg-red-50 transition-all">
                  Salir
                </button>
              </form>
            </div>
            {/* Mobile hamburger */}
            <button
              id="mobile-menu-btn"
              class="md:hidden p-2 text-navy hover:text-coral transition-colors"
              aria-label="Abrir menú"
            >
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path
                  id="hamburger-icon"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M4 6h16M4 12h16M4 18h16"
                />
              </svg>
            </button>
          </div>
          {/* Mobile menu panel */}
          <div
            id="mobile-menu"
            class="md:hidden hidden border-t border-[#f0dcc8]/40"
            style="background: rgba(255,248,242,0.96); backdrop-filter: blur(18px); -webkit-backdrop-filter: blur(18px);"
          >
            <div class="px-6 py-3 space-y-1">
              <a
                href="/app"
                class="block px-3 py-2 text-sm font-medium text-muted hover:text-coral rounded-lg hover:bg-coral/5 transition-all"
              >
                Inicio
              </a>
              <a
                href="/app/partidos"
                class="block px-3 py-2 text-sm font-medium text-muted hover:text-coral rounded-lg hover:bg-coral/5 transition-all"
              >
                Partidos
              </a>
              <a
                href="/app/jugadores"
                class="block px-3 py-2 text-sm font-medium text-muted hover:text-coral rounded-lg hover:bg-coral/5 transition-all"
              >
                Jugadores
              </a>
              <a
                href="/app/torneos"
                class="block px-3 py-2 text-sm font-medium text-muted hover:text-coral rounded-lg hover:bg-coral/5 transition-all"
              >
                Torneos
              </a>
              <a
                href="/app/perfil"
                class="block px-3 py-2 text-sm font-medium text-muted hover:text-coral rounded-lg hover:bg-coral/5 transition-all"
              >
                Perfil
              </a>
              {isAdmin && (
                <a
                  href="/app/admin"
                  class="block px-3 py-2 text-sm font-medium text-muted hover:text-coral rounded-lg hover:bg-coral/5 transition-all"
                >
                  Admin
                </a>
              )}
              <form method="POST" action="/api/auth/logout">
                <button class="w-full text-left px-3 py-2 text-sm font-medium text-muted hover:text-red-500 rounded-lg hover:bg-red-50 transition-all">
                  Salir
                </button>
              </form>
            </div>
          </div>
        </nav>
      ) : null
    }
    <main
      id="main-content"
      class={user ? 'pt-20 pb-12 px-6 lg:px-8 max-w-7xl mx-auto page-enter' : ''}
    >
      <slot />
    </main>
    <!-- Toast container -->
    <div
      id="toast-container"
      class="fixed top-4 right-4 z-9999 flex flex-col gap-2 pointer-events-none"
      aria-live="polite"
    >
    </div>
    <script>
      // Toast system
      ;(function () {
        const container = document.getElementById('toast-container')!
        function showToast(
          message: string,
          type: 'success' | 'error' | 'info' = 'success',
          duration = 4000,
        ) {
          const toast = document.createElement('div')
          const colors = {
            success: 'bg-teal text-white',
            error: 'bg-red-500 text-white',
            info: 'bg-navy text-white',
          }
          toast.className = `pointer-events-auto px-5 py-3 rounded-xl shadow-lg text-sm font-medium flex items-center gap-2 toast-enter ${colors[type]}`
          const icons = {
            success: '✓',
            error: '✗',
            info: 'ℹ',
          }
          toast.innerHTML = `<span class="text-base">${icons[type]}</span><span>${message.replace(/</g, '&lt;')}</span>`
          container.appendChild(toast)
          setTimeout(() => {
            toast.classList.remove('toast-enter')
            toast.classList.add('toast-exit')
            toast.addEventListener('animationend', () => toast.remove())
          }, duration)
        }
        // Expose globally
        ;(window as any).showToast = showToast
        // Auto-convert existing static messages to toasts
        document.querySelectorAll('[data-toast]').forEach((el) => {
          const msg = el.textContent?.trim()
          const type =
            ((el as HTMLElement).dataset.toast as 'success' | 'error' | 'info') || 'success'
          if (msg) showToast(msg, type)
          el.remove()
        })
      })()
    </script>
    <script>
      // Mobile menu
      const menuBtn = document.getElementById('mobile-menu-btn')
      const mobileMenu = document.getElementById('mobile-menu')
      menuBtn?.addEventListener('click', () => {
        mobileMenu?.classList.toggle('hidden')
      })
    </script>
    <script>
      // Navbar quick player autocomplete
      const quickInput = document.getElementById('quick-player-search') as HTMLInputElement | null
      const quickResults = document.getElementById('quick-player-results') as HTMLElement | null
      const quickWrap = document.getElementById('quick-player-search-wrap')

      if (quickInput && quickResults && quickWrap) {
        let timer: ReturnType<typeof setTimeout>

        quickInput.addEventListener('input', () => {
          clearTimeout(timer)
          const q = quickInput.value.trim()
          if (q.length < 2) {
            quickResults.classList.add('hidden')
            return
          }

          timer = setTimeout(async () => {
            const res = await fetch(`/api/players/search?q=${encodeURIComponent(q)}`)
            const players = (await res.json()) as {
              id: string
              name: string
              email: string
              rating: string
              location: string
            }[]

            if (players.length === 0) {
              quickResults.innerHTML =
                '<div class="px-3 py-2 text-xs text-muted">Sin resultados</div>'
            } else {
              quickResults.innerHTML = players
                .map(
                  (p) => `
                <a href="/app/jugadores/${p.id}" class="w-full text-left px-3 py-2 hover:bg-coral/5 flex items-center gap-2 transition-colors block">
                  <span class="w-6 h-6 rounded-lg bg-coral/10 flex items-center justify-center text-[10px] font-bold text-coral shrink-0">${p.name.charAt(0).toUpperCase()}</span>
                  <span class="flex-1 min-w-0">
                    <span class="text-xs font-medium text-navy block truncate">${p.name}</span>
                    <span class="text-[10px] text-muted block truncate">${p.location || p.email}</span>
                  </span>
                  <span class="text-[10px] font-bold text-coral shrink-0">${p.rating}</span>
                </a>
              `,
                )
                .join('')
            }

            quickResults.classList.remove('hidden')
          }, 250)
        })

        document.addEventListener('click', (e) => {
          if (!quickWrap.contains(e.target as Node)) {
            quickResults.classList.add('hidden')
          }
        })
      }
    </script>
    <script define:vars={{ unreadCount }}>
      // Browser notifications for unread items
      if (
        unreadCount > 0 &&
        'Notification' in window &&
        Notification.permission === 'granted' &&
        localStorage.getItem('sp-notif') !== 'off'
      ) {
        const key = 'sp-last-notif'
        const last = parseInt(localStorage.getItem(key) || '0')
        const now = Date.now()
        // Only notify once every 5 minutes max
        if (now - last > 300000) {
          localStorage.setItem(key, String(now))
          new Notification('Score Padel', {
            body: `Tienes ${unreadCount} notificación${unreadCount > 1 ? 'es' : ''} sin leer`,
            icon: '/favicon.svg',
            tag: 'sp-unread',
          })
        }
      }
    </script>

    <!-- Global confirm modal -->
    <div
      id="sp-confirm-modal"
      class="fixed inset-0 z-200 items-center justify-center p-4 hidden"
      style="display:none"
      role="dialog"
      aria-modal="true"
      aria-labelledby="sp-modal-title"
    >
      <div id="sp-modal-backdrop" class="absolute inset-0 bg-navy/40 backdrop-blur-sm"></div>
      <div
        class="relative bg-white rounded-2xl shadow-2xl max-w-sm w-full p-6 space-y-4 animate-[fadeInUp_0.18s_ease-out]"
      >
        <div class="flex items-start gap-3">
          <div
            id="sp-modal-icon"
            class="shrink-0 w-10 h-10 rounded-xl flex items-center justify-center"
          >
          </div>
          <div class="flex-1 min-w-0">
            <h3 id="sp-modal-title" class="font-display font-bold text-navy text-base leading-snug">
            </h3>
            <p id="sp-modal-message" class="text-sm text-muted mt-1 leading-relaxed"></p>
          </div>
        </div>
        <div class="flex items-center justify-end gap-2 pt-1">
          <button
            id="sp-modal-cancel"
            type="button"
            class="px-4 py-2 text-sm font-medium text-muted hover:text-navy border border-gray-200 rounded-xl hover:bg-gray-50 transition-colors"
          >
            Cancelar
          </button>
          <button
            id="sp-modal-confirm"
            type="button"
            class="px-4 py-2 text-sm font-semibold text-white rounded-xl transition-colors"
          >
            Confirmar
          </button>
        </div>
      </div>
    </div>

    <script>
      ;(function () {
        const modal = document.getElementById('sp-confirm-modal')!
        const backdrop = document.getElementById('sp-modal-backdrop')!
        const iconEl = document.getElementById('sp-modal-icon')!
        const titleEl = document.getElementById('sp-modal-title')!
        const msgEl = document.getElementById('sp-modal-message')!
        const cancelBtn = document.getElementById('sp-modal-cancel')!
        const confirmBtn = document.getElementById('sp-modal-confirm')!

        let _resolve: ((v: boolean) => void) | null = null

        function close(result: boolean) {
          modal.style.display = 'none'
          document.body.style.overflow = ''
          if (_resolve) {
            _resolve(result)
            _resolve = null
          }
        }

        backdrop.addEventListener('click', () => close(false))
        cancelBtn.addEventListener('click', () => close(false))
        confirmBtn.addEventListener('click', () => close(true))
        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape' && !modal.classList.contains('hidden')) close(false)
        })

        type ModalVariant = 'danger' | 'warning' | 'info'

        const variants: Record<
          ModalVariant,
          { icon: string; iconBg: string; iconColor: string; btnClass: string }
        > = {
          danger: {
            icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0"/>',
            iconBg: 'bg-red-50',
            iconColor: 'text-red-500',
            btnClass: 'bg-red-500 hover:bg-red-600',
          },
          warning: {
            icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z"/>',
            iconBg: 'bg-amber-50',
            iconColor: 'text-amber-500',
            btnClass: 'bg-amber-500 hover:bg-amber-600',
          },
          info: {
            icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M9.879 7.519c1.171-1.025 3.071-1.025 4.242 0 1.172 1.025 1.172 2.687 0 3.712-.203.179-.43.326-.67.442-.745.361-1.45.999-1.45 1.827v.75M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9 5.25h.008v.008H12v-.008z"/>',
            iconBg: 'bg-teal/10',
            iconColor: 'text-teal',
            btnClass: 'bg-teal hover:bg-teal/90',
          },
        }

        ;(window as any).spConfirm = function (
          title: string,
          message: string,
          onConfirm: () => void,
          variant: ModalVariant = 'danger',
        ) {
          const v = variants[variant] ?? variants.danger
          iconEl.className = `flex-shrink-0 w-10 h-10 rounded-xl flex items-center justify-center ${v.iconBg}`
          iconEl.innerHTML = `<svg class="w-5 h-5 ${v.iconColor}" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">${v.icon}</svg>`
          titleEl.textContent = title
          msgEl.textContent = message
          confirmBtn.className = `px-4 py-2 text-sm font-semibold text-white rounded-xl transition-colors ${v.btnClass}`

        modal.style.display = 'flex'
          document.body.style.overflow = 'hidden'
          cancelBtn.focus()

          _resolve = (confirmed) => {
            if (confirmed) onConfirm()
          }
        }
      })()
    </script>
  </body>
</html>
