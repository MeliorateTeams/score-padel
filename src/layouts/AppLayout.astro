---
import '../styles/global.css'

interface Props {
  title: string
  user?: { id: string; name: string; email: string; role?: string } | null
}

const { title, user = null } = Astro.props
const isGuest = user?.role === 'guest'
const isAdmin = user?.role === 'admin'

// Notification count
let unreadCount = 0
if (user) {
  const db = (Astro.locals as any).db
  const countResult = await db
    .prepare('SELECT COUNT(*) as cnt FROM notifications WHERE user_id = ? AND read = 0')
    .bind(user.id)
    .first()
  unreadCount = countResult?.cnt ?? 0
}
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/icon-192.png" />
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#FF6A00" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <title>{title} — Score Padel</title>
    <meta http-equiv="X-Content-Type-Options" content="nosniff" />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
  </head>
  <body
    class="min-h-screen"
    style="background: linear-gradient(180deg, #FFF8F2 0%, #FFF5EB 100%); min-height: 100vh;"
  >
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:z-[100] focus:px-4 focus:py-2 focus:bg-coral focus:text-white focus:rounded-lg focus:text-sm focus:font-semibold"
      >Saltar al contenido</a
    >
    {
      user ? (
        <nav
          class="fixed top-0 left-0 right-0 z-50 border-b border-[#f0dcc8]/60 dark-nav"
          style="background: rgba(255,248,242,0.88); backdrop-filter: blur(18px) saturate(160%); -webkit-backdrop-filter: blur(18px) saturate(160%);"
          role="navigation"
          aria-label="Navegación principal"
        >
          <div class="max-w-7xl mx-auto px-6 lg:px-8 flex items-center justify-between h-14">
            <a
              href="/app"
              class="flex items-center gap-1.5 font-display font-bold text-base tracking-tight text-navy"
            >
              <img src="/favicon.svg" alt="Score Padel" class="w-9 h-9" />
              Score<span class="text-coral">Padel</span>
            </a>
            {/* Quick search */}
            <form action="/app/jugadores" method="GET" class="hidden lg:flex items-center ml-4">
              <div class="relative">
                <svg
                  class="w-3.5 h-3.5 absolute left-3 top-1/2 -translate-y-1/2 text-muted/50"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z"
                  />
                </svg>
                <input
                  type="text"
                  name="q"
                  placeholder="Buscar jugador..."
                  class="w-44 pl-8 pr-3 py-1.5 text-xs bg-[#fff5eb] border border-[#efd2ba] rounded-full text-navy placeholder:text-muted/50 focus:outline-none focus:border-coral/50 focus:w-56 transition-all"
                />
              </div>
            </form>
            {/* Desktop nav */}
            <div class="hidden md:flex items-center gap-0.5">
              <a
                href="/app"
                class="px-3 py-1.5 text-xs font-medium text-muted hover:text-coral rounded-full hover:bg-coral/5 transition-all"
              >
                Inicio
              </a>
              {!isGuest && (
                <a
                  href="/app/partidos"
                  class="px-3 py-1.5 text-xs font-medium text-muted hover:text-coral rounded-full hover:bg-coral/5 transition-all"
                >
                  Partidos
                </a>
              )}
              <a
                href="/app/jugadores"
                class="px-3 py-1.5 text-xs font-medium text-muted hover:text-coral rounded-full hover:bg-coral/5 transition-all"
              >
                Jugadores
              </a>
              {!isGuest && (
                <a
                  href="/app/torneos"
                  class="px-3 py-1.5 text-xs font-medium text-muted hover:text-coral rounded-full hover:bg-coral/5 transition-all"
                >
                  Torneos
                </a>
              )}
              {!isGuest && (
                <a
                  href="/app/perfil"
                  class="px-3 py-1.5 text-xs font-medium text-muted hover:text-coral rounded-full hover:bg-coral/5 transition-all"
                >
                  Perfil
                </a>
              )}
              {isAdmin && (
                <a
                  href="/app/admin"
                  class="px-3 py-1.5 text-xs font-medium text-muted hover:text-coral rounded-full hover:bg-coral/5 transition-all"
                >
                  Admin
                </a>
              )}
              {!isGuest && (
                <a
                  href="/app/notificaciones"
                  class="relative px-3 py-1.5 text-xs font-medium text-muted hover:text-coral rounded-full hover:bg-coral/5 transition-all"
                >
                  <svg
                    class="w-4 h-4"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M14.857 17.082a23.848 23.848 0 005.454-1.31A8.967 8.967 0 0118 9.75V9A6 6 0 006 9v.75a8.967 8.967 0 01-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 01-5.714 0m5.714 0a3 3 0 11-5.714 0"
                    />
                  </svg>
                  {unreadCount > 0 && (
                    <span class="absolute -top-0.5 -right-0.5 w-4 h-4 bg-coral text-white text-[9px] font-bold rounded-full flex items-center justify-center">
                      {unreadCount > 9 ? '9+' : unreadCount}
                    </span>
                  )}
                </a>
              )}
              <form method="POST" action="/api/auth/logout" class="ml-2">
                <button class="px-3 py-1.5 text-xs font-medium text-muted hover:text-red-500 rounded-full hover:bg-red-50 transition-all">
                  Salir
                </button>
              </form>
            </div>
            {/* Mobile hamburger */}
            <button
              id="mobile-menu-btn"
              class="md:hidden p-2 text-navy hover:text-coral transition-colors"
              aria-label="Abrir menú"
            >
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path
                  id="hamburger-icon"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M4 6h16M4 12h16M4 18h16"
                />
              </svg>
            </button>
          </div>
          {/* Mobile menu panel */}
          <div
            id="mobile-menu"
            class="md:hidden hidden border-t border-[#f0dcc8]/40"
            style="background: rgba(255,248,242,0.96); backdrop-filter: blur(18px); -webkit-backdrop-filter: blur(18px);"
          >
            <div class="px-6 py-3 space-y-1">
              <a
                href="/app"
                class="block px-3 py-2 text-sm font-medium text-muted hover:text-coral rounded-lg hover:bg-coral/5 transition-all"
              >
                Inicio
              </a>
              {!isGuest && (
                <a
                  href="/app/partidos"
                  class="block px-3 py-2 text-sm font-medium text-muted hover:text-coral rounded-lg hover:bg-coral/5 transition-all"
                >
                  Partidos
                </a>
              )}
              <a
                href="/app/jugadores"
                class="block px-3 py-2 text-sm font-medium text-muted hover:text-coral rounded-lg hover:bg-coral/5 transition-all"
              >
                Jugadores
              </a>
              {!isGuest && (
                <a
                  href="/app/torneos"
                  class="block px-3 py-2 text-sm font-medium text-muted hover:text-coral rounded-lg hover:bg-coral/5 transition-all"
                >
                  Torneos
                </a>
              )}
              {!isGuest && (
                <a
                  href="/app/perfil"
                  class="block px-3 py-2 text-sm font-medium text-muted hover:text-coral rounded-lg hover:bg-coral/5 transition-all"
                >
                  Perfil
                </a>
              )}
              {isAdmin && (
                <a
                  href="/app/admin"
                  class="block px-3 py-2 text-sm font-medium text-muted hover:text-coral rounded-lg hover:bg-coral/5 transition-all"
                >
                  Admin
                </a>
              )}
              <form method="POST" action="/api/auth/logout">
                <button class="w-full text-left px-3 py-2 text-sm font-medium text-muted hover:text-red-500 rounded-lg hover:bg-red-50 transition-all">
                  Salir
                </button>
              </form>
            </div>
          </div>
        </nav>
      ) : null
    }
    <main
      id="main-content"
      class={user ? 'pt-20 pb-12 px-6 lg:px-8 max-w-7xl mx-auto page-enter' : ''}
    >
      <slot />
    </main>
    <!-- Toast container -->
    <div
      id="toast-container"
      class="fixed top-4 right-4 z-[9999] flex flex-col gap-2 pointer-events-none"
      aria-live="polite"
    >
    </div>
    <script>
      // Toast system
      ;(function () {
        const container = document.getElementById('toast-container')!
        function showToast(
          message: string,
          type: 'success' | 'error' | 'info' = 'success',
          duration = 4000,
        ) {
          const toast = document.createElement('div')
          const colors = {
            success: 'bg-teal text-white',
            error: 'bg-red-500 text-white',
            info: 'bg-navy text-white',
          }
          toast.className = `pointer-events-auto px-5 py-3 rounded-xl shadow-lg text-sm font-medium flex items-center gap-2 toast-enter ${colors[type]}`
          const icons = {
            success: '✓',
            error: '✗',
            info: 'ℹ',
          }
          toast.innerHTML = `<span class="text-base">${icons[type]}</span><span>${message.replace(/</g, '&lt;')}</span>`
          container.appendChild(toast)
          setTimeout(() => {
            toast.classList.remove('toast-enter')
            toast.classList.add('toast-exit')
            toast.addEventListener('animationend', () => toast.remove())
          }, duration)
        }
        // Expose globally
        ;(window as any).showToast = showToast
        // Auto-convert existing static messages to toasts
        document.querySelectorAll('[data-toast]').forEach((el) => {
          const msg = el.textContent?.trim()
          const type =
            ((el as HTMLElement).dataset.toast as 'success' | 'error' | 'info') || 'success'
          if (msg) showToast(msg, type)
          el.remove()
        })
      })()
    </script>
    <script>
      // Mobile menu
      const menuBtn = document.getElementById('mobile-menu-btn')
      const mobileMenu = document.getElementById('mobile-menu')
      menuBtn?.addEventListener('click', () => {
        mobileMenu?.classList.toggle('hidden')
      })
    </script>
    <script define:vars={{ unreadCount }}>
      // Browser notifications for unread items
      if (
        unreadCount > 0 &&
        'Notification' in window &&
        Notification.permission === 'granted' &&
        localStorage.getItem('sp-notif') !== 'off'
      ) {
        const key = 'sp-last-notif'
        const last = parseInt(localStorage.getItem(key) || '0')
        const now = Date.now()
        // Only notify once every 5 minutes max
        if (now - last > 300000) {
          localStorage.setItem(key, String(now))
          new Notification('Score Padel', {
            body: `Tienes ${unreadCount} notificación${unreadCount > 1 ? 'es' : ''} sin leer`,
            icon: '/favicon.svg',
            tag: 'sp-unread',
          })
        }
      }
    </script>
  </body>
</html>
