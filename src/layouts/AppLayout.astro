---
import '../styles/global.css'

interface Props {
  title: string
  user?: { id: string; name: string; email: string; role?: string } | null
}

const { title, user = null } = Astro.props
const isGuest = user?.role === 'guest'
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" sizes="32x32" />
    <title>{title} — Score Padel</title>
    <meta http-equiv="X-Content-Type-Options" content="nosniff" />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
  </head>
  <body class="min-h-screen bg-bg">
    {
      user ? (
        <nav class="fixed top-0 left-0 right-0 z-50 bg-white shadow-sm border-b border-gray-100">
          <div class="max-w-7xl mx-auto px-6 lg:px-8 flex items-center justify-between h-14">
            <a
              href="/app"
              class="flex items-center gap-1.5 font-display font-bold text-base tracking-tight text-navy"
            >
              <svg class="w-7 h-7" viewBox="0 0 40 40" fill="none">
                <rect width="40" height="40" rx="11" fill="#E5553B" />
                <rect
                  x="14"
                  y="7"
                  width="12"
                  height="18"
                  rx="6"
                  stroke="white"
                  stroke-width="2.5"
                  fill="none"
                />
                <line
                  x1="17"
                  y1="12"
                  x2="17"
                  y2="20"
                  stroke="white"
                  stroke-width="1.2"
                  opacity="0.5"
                />
                <line
                  x1="20"
                  y1="12"
                  x2="20"
                  y2="20"
                  stroke="white"
                  stroke-width="1.2"
                  opacity="0.5"
                />
                <line
                  x1="23"
                  y1="12"
                  x2="23"
                  y2="20"
                  stroke="white"
                  stroke-width="1.2"
                  opacity="0.5"
                />
                <line
                  x1="14"
                  y1="14"
                  x2="26"
                  y2="14"
                  stroke="white"
                  stroke-width="1.2"
                  opacity="0.5"
                />
                <line
                  x1="14"
                  y1="18"
                  x2="26"
                  y2="18"
                  stroke="white"
                  stroke-width="1.2"
                  opacity="0.5"
                />
                <rect x="18" y="25" width="4" height="8" rx="2" fill="white" />
                <circle cx="32" cy="9" r="4.5" fill="#0D9488" />
                <path
                  d="M30 7c1.5 1 2 3 1 4.5"
                  stroke="white"
                  stroke-width="1"
                  opacity="0.6"
                  fill="none"
                  stroke-linecap="round"
                />
              </svg>
              Score<span class="text-coral">Padel</span>
            </a>
            {/* Desktop nav */}
            <div class="hidden md:flex items-center gap-0.5">
              <a
                href="/app"
                class="px-3 py-1.5 text-xs font-medium text-muted hover:text-coral rounded-full hover:bg-coral/5 transition-all"
              >
                Dashboard
              </a>
              <a
                href="/app/torneos"
                class="px-3 py-1.5 text-xs font-medium text-muted hover:text-coral rounded-full hover:bg-coral/5 transition-all"
              >
                Torneos
              </a>
              {!isGuest && (
                <a
                  href="/app/partidos"
                  class="px-3 py-1.5 text-xs font-medium text-muted hover:text-coral rounded-full hover:bg-coral/5 transition-all"
                >
                  Partidos
                </a>
              )}
              <a
                href="/app/jugadores"
                class="px-3 py-1.5 text-xs font-medium text-muted hover:text-coral rounded-full hover:bg-coral/5 transition-all"
              >
                Jugadores
              </a>
              <a
                href="/app/clasificacion"
                class="px-3 py-1.5 text-xs font-medium text-muted hover:text-coral rounded-full hover:bg-coral/5 transition-all"
              >
                Valoraciones
              </a>
              {!isGuest && (
                <a
                  href="/app/perfil"
                  class="px-3 py-1.5 text-xs font-medium text-muted hover:text-coral rounded-full hover:bg-coral/5 transition-all"
                >
                  Perfil
                </a>
              )}
              <form method="POST" action="/api/auth/logout" class="ml-2">
                <button class="px-3 py-1.5 text-xs font-medium text-muted hover:text-red-500 rounded-full hover:bg-red-50 transition-all">
                  Salir
                </button>
              </form>
            </div>
            {/* Mobile hamburger */}
            <button
              id="mobile-menu-btn"
              class="md:hidden p-2 text-navy hover:text-coral transition-colors"
              aria-label="Abrir menú"
            >
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path
                  id="hamburger-icon"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M4 6h16M4 12h16M4 18h16"
                />
              </svg>
            </button>
          </div>
          {/* Mobile menu panel */}
          <div id="mobile-menu" class="md:hidden hidden border-t border-gray-100 bg-white">
            <div class="px-6 py-3 space-y-1">
              <a
                href="/app"
                class="block px-3 py-2 text-sm font-medium text-muted hover:text-coral rounded-lg hover:bg-coral/5 transition-all"
              >
                Dashboard
              </a>
              <a
                href="/app/torneos"
                class="block px-3 py-2 text-sm font-medium text-muted hover:text-coral rounded-lg hover:bg-coral/5 transition-all"
              >
                Torneos
              </a>
              {!isGuest && (
                <a
                  href="/app/partidos"
                  class="block px-3 py-2 text-sm font-medium text-muted hover:text-coral rounded-lg hover:bg-coral/5 transition-all"
                >
                  Partidos
                </a>
              )}
              <a
                href="/app/jugadores"
                class="block px-3 py-2 text-sm font-medium text-muted hover:text-coral rounded-lg hover:bg-coral/5 transition-all"
              >
                Jugadores
              </a>
              <a
                href="/app/clasificacion"
                class="block px-3 py-2 text-sm font-medium text-muted hover:text-coral rounded-lg hover:bg-coral/5 transition-all"
              >
                Valoraciones
              </a>
              {!isGuest && (
                <a
                  href="/app/perfil"
                  class="block px-3 py-2 text-sm font-medium text-muted hover:text-coral rounded-lg hover:bg-coral/5 transition-all"
                >
                  Perfil
                </a>
              )}
              <form method="POST" action="/api/auth/logout">
                <button class="w-full text-left px-3 py-2 text-sm font-medium text-muted hover:text-red-500 rounded-lg hover:bg-red-50 transition-all">
                  Salir
                </button>
              </form>
            </div>
          </div>
        </nav>
      ) : null
    }
    <main class={user ? 'pt-20 pb-12 px-6 lg:px-8 max-w-7xl mx-auto' : ''}>
      <slot />
    </main>
    <script>
      const menuBtn = document.getElementById('mobile-menu-btn')
      const mobileMenu = document.getElementById('mobile-menu')
      menuBtn?.addEventListener('click', () => {
        mobileMenu?.classList.toggle('hidden')
      })
    </script>
  </body>
</html>
