<div
  id="cookie-banner"
  class="fixed bottom-4 left-4 right-4 sm:left-auto sm:right-6 sm:max-w-sm z-50 hidden"
>
  <div class="bg-white rounded-2xl p-5 shadow-xl border border-gray-100">
    <p class="text-sm text-navy font-semibold mb-1.5">Aviso de Cookies</p>
    <p class="text-xs text-muted leading-relaxed mb-4">
      Este sitio utiliza únicamente cookies técnicas necesarias para el funcionamiento de la
      aplicación (sesión de usuario). No utilizamos cookies de análisis, publicidad ni de terceros.
      Estas cookies están exentas de consentimiento según el artículo 22.2 de la LSSI-CE.
      <a href="/politica-cookies" class="text-coral hover:underline">Más información</a>.
    </p>
    <button
      id="cookie-dismiss"
      class="w-full px-3 py-2 text-xs font-semibold bg-coral text-white rounded-full hover:bg-coral-dark transition-colors"
    >
      Entendido
    </button>
  </div>
</div>

<script>
  const banner = document.getElementById('cookie-banner')
  const dismissBtn = document.getElementById('cookie-dismiss')

  if (!localStorage.getItem('cookie-notice-seen')) {
    banner?.classList.remove('hidden')
  }

  dismissBtn?.addEventListener('click', () => {
    localStorage.setItem('cookie-notice-seen', '1')
    banner?.classList.add('hidden')
  })
</script>
