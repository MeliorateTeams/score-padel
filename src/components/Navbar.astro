---

<nav id="main-nav" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300">
  <div class="nav-progress" aria-hidden="true">
    <span id="nav-progress-bar" class="nav-progress-bar"></span>
  </div>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div id="main-nav-shell" class="nav-shell">
      <div class="flex items-center justify-between h-16 px-2 sm:px-1">
        <a
          href="/"
          class="nav-brand flex items-center gap-2 font-display font-bold text-xl tracking-tight text-navy"
        >
          <img src="/favicon.svg" alt="Score Padel" class="w-11 h-11" />
          Score<span class="text-coral">Padel</span>
        </a>

        <!-- Desktop -->
        <div class="hidden md:flex items-center gap-3">
          <div
            class="nav-section-links flex items-center gap-1 rounded-full border border-transparent px-1 py-1"
          >
            <a
              href="#quienes-somos"
              data-nav-link
              class="nav-section-link px-3.5 py-2 text-sm font-medium text-muted hover:text-coral rounded-full hover:bg-coral/5 transition-all"
              >Quiénes somos</a
            >
            <a
              href="#como-funciona"
              data-nav-link
              class="nav-section-link px-3.5 py-2 text-sm font-medium text-muted hover:text-coral rounded-full hover:bg-coral/5 transition-all"
              >Cómo funciona</a
            >
            <a
              href="#niveles"
              data-nav-link
              class="nav-section-link px-3.5 py-2 text-sm font-medium text-muted hover:text-coral rounded-full hover:bg-coral/5 transition-all"
              >Niveles</a
            >
            <a
              href="#destacados"
              data-nav-link
              class="nav-section-link px-3.5 py-2 text-sm font-medium text-muted hover:text-coral rounded-full hover:bg-coral/5 transition-all"
              >Destacados</a
            >
            <a
              href="#ventajas"
              data-nav-link
              class="nav-section-link px-3.5 py-2 text-sm font-medium text-muted hover:text-coral rounded-full hover:bg-coral/5 transition-all"
              >Actividad</a
            >
          </div>
          <a
            href="/login"
            class="nav-utility-link px-4 py-2 text-sm font-medium text-navy hover:text-coral transition-colors"
            >Iniciar sesión</a
          >
          <a
            href="/registro"
            class="ml-1 px-5 py-2.5 text-sm font-semibold bg-coral text-white rounded-full hover:bg-coral-dark transition-colors shadow-sm"
            >Crear cuenta</a
          >
        </div>

        <!-- Mobile button -->
        <button
          id="mobile-menu-btn"
          class="nav-mobile-toggle md:hidden p-2 text-muted hover:text-coral transition-colors"
          aria-label="Abrir menú"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="hidden md:hidden border-t border-black/5 bg-white/95 backdrop-blur-md shadow-lg"
  >
    <div class="px-6 py-4 space-y-1">
      <a
        href="#quienes-somos"
        data-nav-link
        class="nav-mobile-link block py-2.5 text-sm font-medium text-muted hover:text-coral transition-colors"
        >Quiénes somos</a
      >
      <a
        href="#como-funciona"
        data-nav-link
        class="nav-mobile-link block py-2.5 text-sm font-medium text-muted hover:text-coral transition-colors"
        >Cómo funciona</a
      >
      <a
        href="#niveles"
        data-nav-link
        class="nav-mobile-link block py-2.5 text-sm font-medium text-muted hover:text-coral transition-colors"
        >Niveles</a
      >
      <a
        href="#destacados"
        data-nav-link
        class="nav-mobile-link block py-2.5 text-sm font-medium text-muted hover:text-coral transition-colors"
        >Destacados</a
      >
      <a
        href="#ventajas"
        data-nav-link
        class="nav-mobile-link block py-2.5 text-sm font-medium text-muted hover:text-coral transition-colors"
        >Actividad</a
      >
      <a
        href="/login"
        class="block py-2.5 text-sm font-medium text-muted hover:text-coral transition-colors"
        >Iniciar sesión</a
      >
      <a
        href="/registro"
        class="block mt-2 text-center py-2.5 text-sm font-semibold bg-coral text-white rounded-full hover:bg-coral-dark transition-colors"
        >Crear cuenta</a
      >
    </div>
  </div>
</nav>

<script>
  const btn = document.getElementById('mobile-menu-btn')
  const menu = document.getElementById('mobile-menu')
  const nav = document.getElementById('main-nav')
  const navShell = document.getElementById('main-nav-shell')
  const progressBar = document.getElementById('nav-progress-bar')
  const sectionLinks = Array.from(document.querySelectorAll('[data-nav-link]'))
  const revealNodes = Array.from(document.querySelectorAll('[data-scroll-reveal]'))

  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden')
  })
  menu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      menu?.classList.add('hidden')
    })
  })

  function updateNav() {
    if (!nav || !navShell) return
    const scrollTop = window.scrollY
    const scrollHeight = document.documentElement.scrollHeight - window.innerHeight
    const progress = scrollHeight > 0 ? Math.min(scrollTop / scrollHeight, 1) : 0
    const isScrolled = scrollTop > 48

    nav.classList.toggle('nav-scrolled', isScrolled)
    navShell.classList.toggle('nav-shell-scrolled', isScrolled)

    if (progressBar) {
      progressBar.style.transform = `scaleX(${progress})`
    }
  }

  function setActiveLink(id: string) {
    sectionLinks.forEach((link) => {
      const isActive = link.getAttribute('href') === `#${id}`
      link.classList.toggle('nav-active', isActive)
      if (isActive) {
        link.setAttribute('aria-current', 'true')
      } else {
        link.removeAttribute('aria-current')
      }
    })
  }

  // Scroll-spy: track which section is in the top third of viewport
  const seen = new Set<string>()
  const sectionEls: { id: string; el: Element }[] = []
  sectionLinks.forEach((link) => {
    const hash = link.getAttribute('href')
    if (!hash?.startsWith('#') || seen.has(hash)) return
    seen.add(hash)
    const section = document.querySelector(hash)
    if (section) sectionEls.push({ id: hash.slice(1), el: section })
  })
  // Sort by DOM position so the loop finds the correct active section
  sectionEls.sort((a, b) => {
    const aTop = a.el.getBoundingClientRect().top
    const bTop = b.el.getBoundingClientRect().top
    return aTop - bTop
  })

  function updateActiveSection() {
    const scrollY = window.scrollY + window.innerHeight * 0.33
    let activeId = ''
    for (const { id, el } of sectionEls) {
      const rect = el.getBoundingClientRect()
      const top = rect.top + window.scrollY
      if (scrollY >= top) activeId = id
    }
    setActiveLink(activeId)
  }

  // Scroll-reveal setup
  if ('IntersectionObserver' in window) {
    revealNodes.forEach((node, index) => {
      if (node instanceof HTMLElement) {
        node.style.setProperty('--reveal-delay', `${Math.min(index * 45, 180)}ms`)
      }
    })

    const revealObserver = new IntersectionObserver(
      (entries, observer) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return
          entry.target.classList.add('is-visible')
          observer.unobserve(entry.target)
          setTimeout(() => {
            if (entry.target instanceof HTMLElement) {
              entry.target.style.willChange = 'auto'
            }
          }, 600)
        })
      },
      {
        rootMargin: '0px 0px -12% 0px',
        threshold: 0.12,
      },
    )

    revealNodes.forEach((node) => revealObserver.observe(node))
  } else {
    revealNodes.forEach((node) => node.classList.add('is-visible'))
  }

  let ticking = false
  window.addEventListener(
    'scroll',
    () => {
      if (!ticking) {
        ticking = true
        requestAnimationFrame(() => {
          updateNav()
          updateActiveSection()
          ticking = false
        })
      }
    },
    { passive: true },
  )
  updateNav()
  updateActiveSection()
</script>
