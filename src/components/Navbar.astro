---

---

<nav
  class="fixed top-0 left-0 right-0 z-50 bg-white/80 backdrop-blur-md shadow-sm border-b border-gray-100"
>
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <a
        href="/"
        class="flex items-center gap-2 font-display font-bold text-xl tracking-tight text-navy"
      >
        <svg class="w-9 h-9" viewBox="0 0 64 64" fill="none">
          <path
            d="M6 12C6 8.686 8.686 6 12 6h40c3.314 0 6 2.686 6 6v24c0 10-12 18-26 22C18 48 6 40 6 30V12z"
            fill="#E5553B"></path>
          <path
            d="M8 13c0-2.761 2.239-5 5-5h38c2.761 0 5 2.239 5 5v21c0 8.5-11 16-24 20C19 50 8 42 8 33.5V13z"
            fill="#D14430"></path>
          <g transform="translate(32,26) rotate(-30)">
            <rect
              x="-9"
              y="-14"
              width="18"
              height="22"
              rx="9"
              stroke="white"
              stroke-width="3"
              fill="none"></rect>
            <circle cx="-4" cy="-7" r="1.3" fill="white" opacity="0.7"></circle>
            <circle cx="0" cy="-7" r="1.3" fill="white" opacity="0.7"></circle>
            <circle cx="4" cy="-7" r="1.3" fill="white" opacity="0.7"></circle>
            <circle cx="-4" cy="-3" r="1.3" fill="white" opacity="0.7"></circle>
            <circle cx="0" cy="-3" r="1.3" fill="white" opacity="0.7"></circle>
            <circle cx="4" cy="-3" r="1.3" fill="white" opacity="0.7"></circle>
            <circle cx="-4" cy="1" r="1.3" fill="white" opacity="0.7"></circle>
            <circle cx="0" cy="1" r="1.3" fill="white" opacity="0.7"></circle>
            <circle cx="4" cy="1" r="1.3" fill="white" opacity="0.7"></circle>
            <rect x="-2.5" y="8" width="5" height="10" rx="2.5" fill="white"></rect>
          </g>
          <circle cx="46" cy="14" r="6" fill="#0D9488"></circle>
          <path
            d="M43.5 11.5c2 1.2 2.5 4 1.2 5.8"
            stroke="white"
            stroke-width="1.2"
            opacity="0.7"
            fill="none"
            stroke-linecap="round"></path>
        </svg>
        Score<span class="text-coral">Padel</span>
      </a>

      <!-- Desktop -->
      <div class="hidden md:flex items-center gap-1">
        <a
          href="#quienes-somos"
          class="px-3.5 py-2 text-sm font-medium text-muted hover:text-coral rounded-full hover:bg-coral/5 transition-all"
          >Quiénes somos</a
        >
        <a
          href="#como-funciona"
          class="px-3.5 py-2 text-sm font-medium text-muted hover:text-coral rounded-full hover:bg-coral/5 transition-all"
          >Cómo funciona</a
        >
        <a
          href="#niveles"
          class="px-3.5 py-2 text-sm font-medium text-muted hover:text-coral rounded-full hover:bg-coral/5 transition-all"
          >Niveles</a
        >
        <a
          href="#ventajas"
          class="px-3.5 py-2 text-sm font-medium text-muted hover:text-coral rounded-full hover:bg-coral/5 transition-all"
          >Por qué unirse</a
        >
        <a
          href="/login"
          class="ml-3 px-4 py-2 text-sm font-medium text-navy hover:text-coral transition-colors"
          >Iniciar sesión</a
        >
        <a
          href="/registro"
          class="ml-1 px-5 py-2.5 text-sm font-semibold bg-coral text-white rounded-full hover:bg-coral-dark transition-colors shadow-sm"
          >Crear cuenta</a
        >
      </div>

      <!-- Mobile button -->
      <button
        id="mobile-menu-btn"
        class="md:hidden p-2 text-muted hover:text-coral transition-colors"
        aria-label="Abrir menú"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-gray-100 bg-white shadow-lg">
    <div class="px-6 py-4 space-y-1">
      <a
        href="#quienes-somos"
        class="block py-2.5 text-sm font-medium text-muted hover:text-coral transition-colors"
        >Quiénes somos</a
      >
      <a
        href="#como-funciona"
        class="block py-2.5 text-sm font-medium text-muted hover:text-coral transition-colors"
        >Cómo funciona</a
      >
      <a
        href="#niveles"
        class="block py-2.5 text-sm font-medium text-muted hover:text-coral transition-colors"
        >Niveles</a
      >
      <a
        href="#ventajas"
        class="block py-2.5 text-sm font-medium text-muted hover:text-coral transition-colors"
        >Por qué unirse</a
      >
      <a
        href="/login"
        class="block py-2.5 text-sm font-medium text-muted hover:text-coral transition-colors"
        >Iniciar sesión</a
      >
      <a
        href="/registro"
        class="block mt-2 text-center py-2.5 text-sm font-semibold bg-coral text-white rounded-full hover:bg-coral-dark transition-colors"
        >Crear cuenta</a
      >
    </div>
  </div>
</nav>

<script>
  const btn = document.getElementById('mobile-menu-btn')
  const menu = document.getElementById('mobile-menu')
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden')
  })
  menu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      menu?.classList.add('hidden')
    })
  })
</script>
