---

---

<nav
  class="fixed top-0 left-0 right-0 z-50 backdrop-blur-md shadow-sm border-b border-white/20 dark-nav"
>
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <a
        href="/"
        class="flex items-center gap-2 font-display font-bold text-xl tracking-tight text-navy"
      >
        <img src="/favicon.svg" alt="Score Padel" class="w-11 h-11" />
        Score<span class="text-coral">Padel</span>
      </a>

      <!-- Desktop -->
      <div class="hidden md:flex items-center gap-1">
        <a
          href="#quienes-somos"
          class="px-3.5 py-2 text-sm font-medium text-muted hover:text-coral rounded-full hover:bg-coral/5 transition-all"
          >Quiénes somos</a
        >
        <a
          href="#como-funciona"
          class="px-3.5 py-2 text-sm font-medium text-muted hover:text-coral rounded-full hover:bg-coral/5 transition-all"
          >Cómo funciona</a
        >
        <a
          href="#niveles"
          class="px-3.5 py-2 text-sm font-medium text-muted hover:text-coral rounded-full hover:bg-coral/5 transition-all"
          >Niveles</a
        >
        <a
          href="#ventajas"
          class="px-3.5 py-2 text-sm font-medium text-muted hover:text-coral rounded-full hover:bg-coral/5 transition-all"
          >Por qué unirse</a
        >
        <a
          href="/login"
          class="ml-3 px-4 py-2 text-sm font-medium text-navy hover:text-coral transition-colors"
          >Iniciar sesión</a
        >
        <a
          href="/registro"
          class="ml-1 px-5 py-2.5 text-sm font-semibold bg-coral text-white rounded-full hover:bg-coral-dark transition-colors shadow-sm"
          >Crear cuenta</a
        >
      </div>

      <!-- Mobile button -->
      <button
        id="mobile-menu-btn"
        class="md:hidden p-2 text-muted hover:text-coral transition-colors"
        aria-label="Abrir menú"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="hidden md:hidden border-t border-black/5 bg-white/95 backdrop-blur-md shadow-lg"
  >
    <div class="px-6 py-4 space-y-1">
      <a
        href="#quienes-somos"
        class="block py-2.5 text-sm font-medium text-muted hover:text-coral transition-colors"
        >Quiénes somos</a
      >
      <a
        href="#como-funciona"
        class="block py-2.5 text-sm font-medium text-muted hover:text-coral transition-colors"
        >Cómo funciona</a
      >
      <a
        href="#niveles"
        class="block py-2.5 text-sm font-medium text-muted hover:text-coral transition-colors"
        >Niveles</a
      >
      <a
        href="#ventajas"
        class="block py-2.5 text-sm font-medium text-muted hover:text-coral transition-colors"
        >Por qué unirse</a
      >
      <a
        href="/login"
        class="block py-2.5 text-sm font-medium text-muted hover:text-coral transition-colors"
        >Iniciar sesión</a
      >
      <a
        href="/registro"
        class="block mt-2 text-center py-2.5 text-sm font-semibold bg-coral text-white rounded-full hover:bg-coral-dark transition-colors"
        >Crear cuenta</a
      >
    </div>
  </div>
</nav>

<script>
  const btn = document.getElementById('mobile-menu-btn')
  const menu = document.getElementById('mobile-menu')
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden')
  })
  menu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      menu?.classList.add('hidden')
    })
  })

  // Nav turns black on scroll
  const nav = document.querySelector('nav')
  const logo = nav?.querySelector('a[href="/"]')
  const desktopLinks = nav?.querySelectorAll('.hidden.md\\:flex a:not([href="/registro"])')
  const mobileBtn = document.getElementById('mobile-menu-btn')

  function updateNav() {
    if (!nav) return
    if (window.scrollY > 50) {
      nav.classList.add('nav-scrolled')
      logo?.classList.remove('text-navy')
      logo?.classList.add('text-white')
      desktopLinks?.forEach((l) => {
        l.classList.remove('text-muted', 'text-navy')
        l.classList.add('text-white/80')
      })
      mobileBtn?.classList.remove('text-muted')
      mobileBtn?.classList.add('text-white')
    } else {
      nav.classList.remove('nav-scrolled')
      logo?.classList.add('text-navy')
      logo?.classList.remove('text-white')
      desktopLinks?.forEach((l) => {
        l.classList.add('text-muted', 'text-navy')
        l.classList.remove('text-white/80')
      })
      mobileBtn?.classList.add('text-muted')
      mobileBtn?.classList.remove('text-white')
    }
  }

  window.addEventListener('scroll', updateNav, { passive: true })
  updateNav()
</script>
