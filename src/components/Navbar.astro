---

---

<nav
  class="fixed top-0 left-0 right-0 z-50 bg-white/80 backdrop-blur-md shadow-sm border-b border-gray-100"
>
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <a
        href="/"
        class="flex items-center gap-2 font-display font-bold text-xl tracking-tight text-navy"
      >
        <svg class="w-9 h-9" viewBox="0 0 40 40" fill="none">
          <rect width="40" height="40" rx="11" fill="#E5553B"></rect>
          <rect
            x="14"
            y="7"
            width="12"
            height="18"
            rx="6"
            stroke="white"
            stroke-width="2.5"
            fill="none"></rect>
          <line x1="17" y1="12" x2="17" y2="20" stroke="white" stroke-width="1.2" opacity="0.5"
          ></line>
          <line x1="20" y1="12" x2="20" y2="20" stroke="white" stroke-width="1.2" opacity="0.5"
          ></line>
          <line x1="23" y1="12" x2="23" y2="20" stroke="white" stroke-width="1.2" opacity="0.5"
          ></line>
          <line x1="14" y1="14" x2="26" y2="14" stroke="white" stroke-width="1.2" opacity="0.5"
          ></line>
          <line x1="14" y1="18" x2="26" y2="18" stroke="white" stroke-width="1.2" opacity="0.5"
          ></line>
          <rect x="18" y="25" width="4" height="8" rx="2" fill="white"></rect>
          <circle cx="32" cy="9" r="4.5" fill="#0D9488"></circle>
          <path
            d="M30 7c1.5 1 2 3 1 4.5"
            stroke="white"
            stroke-width="1"
            opacity="0.6"
            fill="none"
            stroke-linecap="round"></path>
        </svg>
        Score<span class="text-coral">Padel</span>
      </a>

      <!-- Desktop -->
      <div class="hidden md:flex items-center gap-1">
        <a
          href="#quienes-somos"
          class="px-3.5 py-2 text-sm font-medium text-muted hover:text-coral rounded-full hover:bg-coral/5 transition-all"
          >Quiénes somos</a
        >
        <a
          href="#como-funciona"
          class="px-3.5 py-2 text-sm font-medium text-muted hover:text-coral rounded-full hover:bg-coral/5 transition-all"
          >Cómo funciona</a
        >
        <a
          href="#niveles"
          class="px-3.5 py-2 text-sm font-medium text-muted hover:text-coral rounded-full hover:bg-coral/5 transition-all"
          >Niveles</a
        >
        <a
          href="#ventajas"
          class="px-3.5 py-2 text-sm font-medium text-muted hover:text-coral rounded-full hover:bg-coral/5 transition-all"
          >Por qué unirse</a
        >
        <a
          href="/login"
          class="ml-3 px-4 py-2 text-sm font-medium text-navy hover:text-coral transition-colors"
          >Iniciar sesión</a
        >
        <a
          href="/registro"
          class="ml-1 px-5 py-2.5 text-sm font-semibold bg-coral text-white rounded-full hover:bg-coral-dark transition-colors shadow-sm"
          >Crear cuenta</a
        >
      </div>

      <!-- Mobile button -->
      <button
        id="mobile-menu-btn"
        class="md:hidden p-2 text-muted hover:text-coral transition-colors"
        aria-label="Abrir menú"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-gray-100 bg-white shadow-lg">
    <div class="px-6 py-4 space-y-1">
      <a
        href="#quienes-somos"
        class="block py-2.5 text-sm font-medium text-muted hover:text-coral transition-colors"
        >Quiénes somos</a
      >
      <a
        href="#como-funciona"
        class="block py-2.5 text-sm font-medium text-muted hover:text-coral transition-colors"
        >Cómo funciona</a
      >
      <a
        href="#niveles"
        class="block py-2.5 text-sm font-medium text-muted hover:text-coral transition-colors"
        >Niveles</a
      >
      <a
        href="#ventajas"
        class="block py-2.5 text-sm font-medium text-muted hover:text-coral transition-colors"
        >Por qué unirse</a
      >
      <a
        href="/login"
        class="block py-2.5 text-sm font-medium text-muted hover:text-coral transition-colors"
        >Iniciar sesión</a
      >
      <a
        href="/registro"
        class="block mt-2 text-center py-2.5 text-sm font-semibold bg-coral text-white rounded-full hover:bg-coral-dark transition-colors"
        >Crear cuenta</a
      >
    </div>
  </div>
</nav>

<script>
  const btn = document.getElementById('mobile-menu-btn')
  const menu = document.getElementById('mobile-menu')
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden')
  })
  menu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      menu?.classList.add('hidden')
    })
  })
</script>
