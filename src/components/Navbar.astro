---

---

<nav class="fixed top-0 left-0 right-0 z-50 bg-bg/70 backdrop-blur-xl border-b border-white/5">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <a href="/" class="font-display font-bold text-lg tracking-tight">
        Score<span class="text-emerald">Padel</span>
      </a>

      <!-- Desktop -->
      <div class="hidden md:flex items-center gap-1">
        <a
          href="#quienes-somos"
          class="px-3.5 py-2 text-sm text-muted hover:text-text rounded-lg hover:bg-white/5 transition-all"
          >Quiénes somos</a
        >
        <a
          href="#como-funciona"
          class="px-3.5 py-2 text-sm text-muted hover:text-text rounded-lg hover:bg-white/5 transition-all"
          >Cómo funciona</a
        >
        <a
          href="#niveles"
          class="px-3.5 py-2 text-sm text-muted hover:text-text rounded-lg hover:bg-white/5 transition-all"
          >Niveles</a
        >
        <a
          href="#ventajas"
          class="px-3.5 py-2 text-sm text-muted hover:text-text rounded-lg hover:bg-white/5 transition-all"
          >Ventajas</a
        >
        <a
          href="#contacto"
          class="ml-3 px-5 py-2 text-sm font-medium bg-emerald text-bg rounded-lg hover:bg-emerald-glow transition-colors"
          >Contacto</a
        >
      </div>

      <!-- Mobile button -->
      <button
        id="mobile-menu-btn"
        class="md:hidden p-2 text-muted hover:text-text transition-colors"
        aria-label="Abrir menú"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="1.5"
            d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-white/5 bg-bg/95 backdrop-blur-xl">
    <div class="px-6 py-4 space-y-1">
      <a
        href="#quienes-somos"
        class="block py-2.5 text-sm text-muted hover:text-emerald transition-colors"
        >Quiénes somos</a
      >
      <a
        href="#como-funciona"
        class="block py-2.5 text-sm text-muted hover:text-emerald transition-colors"
        >Cómo funciona</a
      >
      <a
        href="#niveles"
        class="block py-2.5 text-sm text-muted hover:text-emerald transition-colors">Niveles</a
      >
      <a
        href="#ventajas"
        class="block py-2.5 text-sm text-muted hover:text-emerald transition-colors">Ventajas</a
      >
      <a
        href="#contacto"
        class="block mt-2 text-center py-2.5 text-sm font-medium bg-emerald text-bg rounded-lg hover:bg-emerald-glow transition-colors"
        >Contacto</a
      >
    </div>
  </div>
</nav>

<script>
  const btn = document.getElementById('mobile-menu-btn')
  const menu = document.getElementById('mobile-menu')
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden')
  })
  menu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      menu?.classList.add('hidden')
    })
  })
</script>
